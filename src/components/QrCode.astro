---
/**
 * QrCode.astro — QR-Code zur Build-Zeit als Inline-SVG (kein Client-JS, kein
 * externer Request). Verlinkt auf /go/app (OS-Weiche → richtiger Store). Der
 * QR selbst kodiert die absolute URL (import.meta.env.SITE) → beim Domain-Launch
 * folgt er automatisch der site-Property in astro.config.
 *
 * Exakt gerade (keine Rotation/kein Skew), OHNE eingebettetes Logo → ECC „M"
 * (15 %) genügt für sauberes Scannen. Quiet-Zone = Padding der Kachel.
 * Nur Desktop einsetzen (Aufrufer gated hidden lg:block).
 */
import QRCode from 'qrcode';
import { deployBaseUrl } from '../data/site';

interface Props {
  /** Tracking-/Positionsschlüssel im Ziel-Link (?c=…). */
  campaign?: string;
  /** Bildunterschrift unter der Kachel. */
  caption?: string;
  /** aria-label des umschließenden Links (SVG bleibt aria-hidden). */
  ariaLabel: string;
  /** Kachel-Breite in px (Standard 136). */
  size?: number;
  /** Kachelfarbe: gelb (Standard) oder weiß (z. B. auf gelber Sektion). */
  surface?: 'yellow' | 'white';
  class?: string;
}

const {
  campaign = 'preise_qr',
  caption,
  ariaLabel,
  size = 136,
  surface = 'yellow',
  class: cls = '',
} = Astro.props;

const target = `/go/app?c=${campaign}`;
// Absolute URL für den QR-Inhalt (Handy-Scan braucht die volle Domain). Bewusst
// deployBaseUrl (aktuell live erreichbare Seite), NICHT die kanonische SEO-Domain.
const encodeUrl = `${deployBaseUrl}${target}`;

// Build-Zeit-SVG: dunkle Module #3b3b3a, transparenter Hintergrund (#0000),
// keine Quiet-Zone im SVG (die gelbe Kachel liefert sie als padding).
const qrSvg = await QRCode.toString(encodeUrl, {
  type: 'svg',
  errorCorrectionLevel: 'M',
  margin: 0,
  color: { dark: '#3b3b3a', light: '#0000' },
});
---

<a href={target} class:list={['qr', `qr--${surface}`, cls]} aria-label={ariaLabel} style={`--qr-size:${size}px`}>
  <span class="qr-tile">
    <span class="qr-svg" set:html={qrSvg}></span>
  </span>
  {caption && <span class="qr-caption">{caption}</span>}
</a>

<style>
  .qr {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }
  .qr-tile {
    position: relative;
    display: block;
    width: var(--qr-size, 136px);
    padding: clamp(8px, 11%, 12px); /* Quiet-Zone, skaliert mit der Kachelgröße */
    border-radius: 14px;
    background-color: var(--color-yellow);
    /* Exakt gerade — keine Rotation/kein Skew (sauberes Scannen). */
  }
  /* Weiße Variante (z. B. auf gelber Sektion): Off-White-Kachel. */
  .qr--white .qr-tile {
    background-color: var(--color-offwhite);
  }
  .qr-svg {
    display: block;
  }
  .qr-svg :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .qr-caption {
    max-width: 150px;
    font-size: 0.75rem;
    line-height: 1.4;
    text-align: center;
    color: rgb(59 59 58 / 0.7);
  }
</style>
