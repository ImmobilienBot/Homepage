---
/**
 * SEO.astro — zentrale Head-SEO-Komponente.
 * Rendert: Title, Meta-Description, Canonical, OpenGraph, Twitter Card,
 * robots, hreflang-Alternates, Favicon-Set + JSON-LD-Grundgerüst
 * (MobileApplication + Organization + WebSite).
 *
 * Props laut CLAUDE.md: title, description, canonical, ogImage, noindex.
 */
import {
  site,
  contact,
  storeLinks,
  aggregateRating,
  pricing,
  portals,
  portalCount,
} from '../../data/site';
import { reviews } from '../../data/reviews';
import { getAlternates, hreflangCodes } from '../../i18n';
import type { Locale } from '../../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: Locale;
  /** DE-only-Seite (Rechtsseiten): KEIN hreflang-Paar rendern (self-standing). */
  standalone?: boolean;
  /** Zusätzliche JSON-LD-Knoten, die an den @graph angehängt werden (z. B. AboutPage). */
  extraJsonLd?: unknown[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  noindex = false,
  lang = 'de',
  standalone = false,
  extraJsonLd = [],
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
// Standalone-Seiten (DE-only) tragen bewusst KEINE hreflang-Alternates.
const alternates = standalone ? [] : getAlternates(Astro.url, Astro.site);

// Preview-Builds vor Google schützen: noindex, wenn die noindex-Prop gesetzt ist ODER
// es ein Cloudflare-Preview ist. Cloudflare Pages setzt zur Buildzeit CF_PAGES=1 und
// CF_PAGES_BRANCH; nur der Production-Branch (main) bleibt indexierbar. Lokal ist
// CF_PAGES nicht gesetzt → index, follow. Env buildseitig aus process.env gelesen.
const isPreviewBuild = !!process.env.CF_PAGES && process.env.CF_PAGES_BRANCH !== 'main';
const robotsContent = noindex || isPreviewBuild ? 'noindex, nofollow' : 'index, follow';

// ---- JSON-LD Grundgerüst -------------------------------------------------
// MobileApplication mit Store-Links + aggregateRating aus site.ts.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MobileApplication',
      name: site.name,
      operatingSystem: 'iOS, Android',
      applicationCategory: 'LifestyleApplication',
      description,
      url: site.url,
      downloadUrl: [storeLinks.ios, storeLinks.android],
      // App-Features (konsistent zur Features-Sektion + llms.txt) + überwachte
      // Portale mit voller Domain (für strukturierte Daten).
      featureList: [
        'Suchbereich auf der Karte zeichnen oder per Radius, mehrere Suchorte gleichzeitig',
        'Echtzeit-Push, sobald ein passendes Angebot online geht (auch via Telegram)',
        'Bewerbungsschreiben per Auto-Copy beim Antippen eines Angebots',
        'Favoriten und Status-Filter (Alle, Ungesehen, Favoriten, Beworben)',
        'Erweiterte Filter: möbliert, WG-Zimmer, WBS, Tauschwohnung, Zwischen-/Untermiete, ohne IS24-Plus',
        'Listenansichten S/M/L',
        'Deutsch & Englisch, Light- & Dark-Mode',
        `Überwacht ${portalCount} Immobilienportale in Echtzeit`,
        ...portals.map((p) => `${p.name} (${p.domain})`),
      ],
      offers: pricing.map((p) => ({
        '@type': 'Offer',
        price: p.priceValue.toFixed(2),
        priceCurrency: p.currency,
        name: p.name,
      })),
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: aggregateRating.ratingValue,
        ratingCount: aggregateRating.ratingCount,
        bestRating: aggregateRating.bestRating,
        worstRating: aggregateRating.worstRating,
      },
      // Einzelne Reviews = drei 5-Sterne-Rezensionen (reviewBody = DE-Original).
      review: reviews
        .filter((r) => r.rating === 5)
        .slice(0, 3)
        .map((r) => ({
          '@type': 'Review',
          author: { '@type': 'Person', name: r.author },
          reviewBody: r.text.de,
          reviewRating: {
            '@type': 'Rating',
            ratingValue: r.rating,
            bestRating: 5,
            worstRating: 1,
          },
        })),
    },
    {
      '@type': 'Organization',
      '@id': `${site.url}/#organization`,
      name: site.name,
      url: site.url,
      email: contact.email,
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: contact.email,
        availableLanguage: ['German', 'English'],
      },
    },
    {
      '@type': 'WebSite',
      name: site.name,
      url: site.url,
      inLanguage: hreflangCodes[lang],
    },
    // Seiten-spezifische Zusatzknoten (z. B. AboutPage + Person-Einträge).
    ...extraJsonLd,
  ],
};
---

{/* Grundlegendes */}
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL.href} />
<meta name="robots" content={robotsContent} />

{/* hreflang — reziproke DE/EN-Verlinkung + x-default */}
{
  alternates.map((alt) => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))
}

{/* OpenGraph */}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={ogImageURL.href} />
<meta property="og:locale" content={hreflangCodes[lang]} />

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL.href} />

{/* Favicon-Set — generiert aus dem App-Icon via scripts/gen-favicons.mjs.
    Quelle ist PNG → bewusst kein favicon.svg. */}
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#eaebeb" />

{/* JSON-LD strukturierte Daten */}
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(jsonLd)}
/>
