---
/**
 * Problem „3c" — EINE fokussierte, dunkle Problem-Sektion (~100svh, ein Screen).
 *
 * Lesepfad (zentriert, von oben; nur Roboto Black/Regular, Gelb = einziger Akzent,
 * Größe = Rangordnung):
 *   1. „43.000" — riesige Partikel-Zahl (Display, KEIN Heading). Count-up + auf
 *      Desktop Cursor-Repel der umgebenden Partikel; Mobile spielt nur ab.
 *   2. Statistik-Satz, ENG gekoppelt (kleiner, gedämpft) + Sternchen → Footer-Quelle.
 *   3. H2 „Einer davon ist zuerst da: du." (gelber Marker NUR auf „du").
 *   4. 3 Vorteile mit Icon (kein Fließsatz).
 *   5. Store-Badges (auf Dunkel lesbar).
 *   6. Trust-Zeile (Rating/Downloads aus site.ts bzw. hero.trust).
 *   7. Features-Verweis „Wir zeigen dir wie ↓" → scrollt zur nächsten Sektion.
 *
 * OBERSTES GEBOT (Guardrails): Die GESAMTE Aussage steht als echter, crawlbarer
 * DOM-Text — Zahl (Endwert), Statistik, H2, Vorteile, Badges, Trust, Verweis.
 * Partikel/Canvas sind nur visuelle Zugabe ÜBER dem echten Text. Ohne JS /
 * prefers-reduced-motion: statische „43.000", kein Count-up/keine Partikel,
 * alles sofort sichtbar. Genau EINE H1 bleibt im Hero; hier H2. Fakten aus site.ts.
 */
import StoreBadges from '../StoreBadges.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { portalCountRounded } from '../../data/site';
import type { Locale } from '../../data/site';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const P = t.sections.problem;

// Count-up-Ziel = nur die Ziffern der (locale-formatierten) Zahl.
const countTo = P.bigNumber.replace(/\D/g, '');

// H2-Payoff: Prefix + Nowrap-Klammer(Marker + Suffix) → „du." bricht nie um.
const headMark = P.headlineMark;
const headIdx = P.headline.indexOf(headMark);
const headPrefix = headIdx >= 0 ? P.headline.slice(0, headIdx) : P.headline;
const headSuffix = headIdx >= 0 ? P.headline.slice(headIdx + headMark.length) : '';

// Scanbare Vorteile: {n} → Portalanzahl aus site.ts (wachstumssicher).
const benefits = P.benefits.map((b) => ({
  label: b.label.replace('{n}', String(portalCountRounded)),
}));

// Trust-Zeile: Rating/Downloads aus hero.trust (per-Sprache, Fakten aus site.ts),
// Zusatz („kostenlos, kündbar") aus dem Problem-Block.
const trust = t.hero.trust;

// Schlichte, einfarbige Inline-Line-Icons (keine CD-Icon-Palette im Repo) —
// Reihenfolge = benefits: Glocke (Push) · Ebenen (Portale) · Cursor (Klick).
const ICONS = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3 19 12l-6.5 1.2 3.2 6.3-2.4 1.2-3.2-6.3L5 19Z"/></svg>`,
];
---

<section id="problem" class="problem3c">
  <div class="p3-inner">
    {/* 1 · Partikel-Zahl (Display, KEIN Heading) + eng gekoppelter Statistik-Satz */}
    <div class="p3-stat-block">
      <div class="p3-numwrap" data-p3-numwrap>
        <canvas class="p3-canvas" data-p3-canvas aria-hidden="true"></canvas>
        <span
          class="p3-num"
          data-p3-num
          data-count-to={countTo}
          style={`min-width:${P.bigNumber.length}ch`}>{P.bigNumber}</span
        >
      </div>

      {/* 2 · Statistik-Satz — deutlich kleiner, gedämpft, ENG unter der Zahl */}
      <p class="p3-stat">
        {P.stat}<a
          href="#quelle-statistik"
          class="p3-ast"
          aria-label="Quelle der Statistik (Fußnote)">*</a
        >
      </p>

      {/* Desktop-Hinweis + Replay (nur JS+Motion+Maus sichtbar) */}
      <div class="p3-hint" data-p3-hint aria-hidden="true">
        <span class="p3-hint-move">{P.hintMove}</span>
        <button class="p3-replay" data-p3-replay type="button">
          <span class="p3-replay-ic" aria-hidden="true">↺</span>{P.replay}
        </button>
      </div>
    </div>

    {/* 3 · Umkehr-Headline (H2) — groß, voller Kontrast, Marker nur auf „du" */}
    <h2 class="p3-head">
      <span>{headPrefix}</span><span class="p3-head-nowrap"
        ><span class="mark">{headMark}</span>{headSuffix}</span
      >
    </h2>

    {/* 4 · Vorteils-Reihe (kein Fließsatz), je Icon + Label */}
    <ul class="p3-benefits">
      {
        benefits.map((b, i) => (
          <li class="p3-benefit">
            <span class="p3-benefit-ic" set:html={ICONS[i]} />
            <span class="p3-benefit-label">{b.label}</span>
          </li>
        ))
      }
    </ul>

    {/* 5 · Store-Badges (Hauptaktion) + 6 · Trust-Zeile */}
    <div class="p3-cta">
      <StoreBadges position="problem" lang={lang} />
      <p class="p3-trust">
        <span class="p3-trust-star" aria-hidden="true">★</span>
        <span class="p3-trust-strong">{trust.rating}</span> {trust.ratingLabel}
        <span class="p3-trust-sep" aria-hidden="true">·</span>
        {trust.downloads}
        <span class="p3-trust-sep" aria-hidden="true">·</span>
        {P.trustCancel}
      </p>
    </div>

    {/* 7 · Features-Verweis (Anker leicht repointbar) */}
    <a href="#features" class="p3-more" data-p3-more>
      <span>{P.moreLink}</span>
      <span class="p3-more-arrow" aria-hidden="true">↓</span>
    </a>
  </div>
</section>

<style>
  /* ---- Dunkle 100svh-Bühne, zentriert (ein fokussierter Screen) ---- */
  .problem3c {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(3rem, 8vh, 6rem);
    padding-inline: var(--spacing-inset);
    background-color: var(--color-black);
    color: var(--color-offwhite);
    overflow: hidden;
  }
  .p3-inner {
    width: 100%;
    max-width: 54rem;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ---- 1 · Statistik-Block: Zahl + Satz bilden EINE enge Einheit ---- */
  .p3-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .p3-numwrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* etwas Luft für die Partikel-Aura um die Ziffern (Canvas-Overflow) */
    padding: 0.25em 0.35em;
  }
  .p3-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    /* nur mit JS+Motion sichtbar; ohne JS bleibt die Zahl solo */
    display: none;
  }
  .p3-num {
    position: relative;
    z-index: 1;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-size: clamp(4.5rem, 22vw, 12rem);
    font-variant-numeric: tabular-nums; /* Count-up ohne CLS */
    text-align: center; /* Ziffern zentriert in der reservierten Breite */
    color: var(--color-offwhite);
  }
  /* ENGE Kopplung: kleiner Abstand Zahl → Satz (ein Statistik-Block). */
  .p3-stat {
    margin-top: clamp(0.25rem, 1vw, 0.6rem);
    font-size: clamp(1rem, 2.4vw, 1.4rem);
    font-weight: 400;
    line-height: 1.3;
    max-width: 30ch;
    color: rgb(246 246 246 / 0.72);
  }
  .p3-ast {
    font-size: 0.6em;
    vertical-align: super;
    margin-left: 0.1em;
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
  }

  /* Desktop-Hinweis + Replay — nur JS+Motion+Maus (per JS eingeblendet). */
  .p3-hint {
    display: none;
    margin-top: clamp(0.75rem, 1.6vw, 1.1rem);
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: rgb(246 246 246 / 0.5);
  }
  .p3-hint-move {
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .p3-replay {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    background: none;
    border: 1px solid rgb(246 246 246 / 0.25);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    color: rgb(246 246 246 / 0.75);
    font: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .p3-replay:hover {
    border-color: var(--color-yellow);
    color: var(--color-yellow);
  }
  .p3-replay-ic {
    font-size: 1.05em;
  }
  .p3-replay:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 3px;
  }

  /* ---- 3 · H2-Payoff: groß (kleiner als die Zahl), voller Kontrast, klar abgesetzt ---- */
  .p3-head {
    margin-top: clamp(2.5rem, 6vh, 4.5rem);
    font-size: clamp(1.9rem, 5.2vw, 3.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.02em;
    max-width: 18ch;
    color: var(--color-offwhite);
    text-wrap: balance;
  }
  /* „du." zusammenhalten (kein Umbruch zwischen Marker und Punkt). */
  .p3-head-nowrap {
    white-space: nowrap;
  }
  /* Gelber Marker NUR auf „du" (Brand-Signature). */
  .p3-head :global(.mark) {
    background-color: var(--color-yellow);
    color: var(--color-black);
    padding: 0 0.12em;
    border-radius: 0.08em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  /* ---- 4 · Vorteils-Reihe: Desktop nebeneinander, Mobile umgebrochen ---- */
  .p3-benefits {
    list-style: none;
    margin: clamp(2rem, 4vw, 2.75rem) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.9rem 1.75rem;
  }
  .p3-benefit {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: clamp(1rem, 1.9vw, 1.15rem);
    font-weight: 500;
    color: var(--color-offwhite);
  }
  .p3-benefit-ic {
    display: inline-flex;
    color: var(--color-yellow);
  }
  .p3-benefit-ic :global(svg) {
    width: 1.35rem;
    height: 1.35rem;
    display: block;
  }

  /* ---- 5/6 · CTA + Trust ---- */
  .p3-cta {
    margin-top: clamp(2.25rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.9rem, 2vw, 1.15rem);
  }
  .p3-trust {
    font-size: clamp(0.8rem, 1.5vw, 0.9rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: rgb(246 246 246 / 0.62);
    max-width: 44rem;
    line-height: 1.5;
  }
  .p3-trust-star {
    color: var(--color-yellow);
  }
  .p3-trust-strong {
    font-weight: 700;
    color: rgb(246 246 246 / 0.85);
  }
  .p3-trust-sep {
    margin-inline: 0.35em;
    opacity: 0.5;
  }

  /* ---- 7 · Features-Verweis („Wir zeigen dir wie ↓") ---- */
  .p3-more {
    margin-top: clamp(2rem, 5vh, 3.25rem);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(246 246 246 / 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .p3-more:hover {
    color: var(--color-yellow);
  }
  .p3-more-arrow {
    font-size: 1.15rem;
    line-height: 1;
  }

  /* Sanftes Idle am Pfeil (nur JS+Motion). */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .p3-canvas {
      display: block;
    }
    .p3-more-arrow {
      animation: p3ArrowBob 1.8s ease-in-out infinite;
    }
  }
  @keyframes p3ArrowBob {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: translateY(4px);
      opacity: 1;
    }
  }

  /* Mobile: Vorteile dürfen umbrechen, Zahl etwas kompakter. */
  @media (max-width: 767.98px) {
    .p3-num {
      font-size: clamp(4rem, 26vw, 7rem);
    }
    .p3-benefits {
      gap: 0.75rem 1.25rem;
    }
  }
</style>
