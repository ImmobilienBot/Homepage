---
/**
 * Problem „3c" — EINE fokussierte, dunkle Problem-Sektion (~100svh, ein Screen).
 *
 * Lesepfad (zentriert, von oben; nur Roboto Black/Regular, Gelb = einziger Akzent,
 * Größe = Rangordnung):
 *   1. „43.000" — riesige Partikel-Zahl (Display, KEIN Heading). Count-up + auf
 *      Desktop Cursor-Repel der umgebenden Partikel; Mobile spielt nur ab.
 *   2. Statistik-Satz, ENG gekoppelt (kleiner, gedämpft) + Sternchen → Footer-Quelle.
 *   3. H2 „Einer davon ist zuerst da: du." (gelber Marker NUR auf „du").
 *   4. 3 Vorteile mit Icon (kein Fließsatz).
 *   5. Store-Badges (auf Dunkel lesbar).
 *   6. Trust-Zeile (Rating/Downloads aus site.ts bzw. hero.trust).
 *   7. Features-Verweis „Wir zeigen dir wie ↓" → scrollt zur nächsten Sektion.
 *
 * OBERSTES GEBOT (Guardrails): Die GESAMTE Aussage steht als echter, crawlbarer
 * DOM-Text — Zahl (Endwert), Statistik, H2, Vorteile, Badges, Trust, Verweis.
 * Partikel/Canvas sind nur visuelle Zugabe ÜBER dem echten Text. Ohne JS /
 * prefers-reduced-motion: statische „43.000", kein Count-up/keine Partikel,
 * alles sofort sichtbar. Genau EINE H1 bleibt im Hero; hier H2. Fakten aus site.ts.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import { portalCount, problemStat } from '../../data/site';
import type { Locale } from '../../data/site';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const P = t.sections.problem;

// H2-Payoff: Prefix + Nowrap-Klammer(Marker + Suffix) → „du." bricht nie um.
const headMark = P.headlineMark;
const headIdx = P.headline.indexOf(headMark);
const headPrefix = headIdx >= 0 ? P.headline.slice(0, headIdx) : P.headline;
const headSuffix = headIdx >= 0 ? P.headline.slice(headIdx + headMark.length) : '';

// Scanbare Vorteile: {n} → exakte Portalanzahl aus site.ts.
const benefits = P.benefits.map((b) => ({
  label: b.label.replace('{n}', String(portalCount)),
}));

// EINE Zahlenquelle: site.ts problemStat, locale-formatiert. Der Desktop-Satz UND das
// Mobile-Scoreboard rendern daraus — keine zweite Zahlenquelle, keine abweichende
// Formatierung. Ohne JS / reduced-motion stehen die Endwerte statisch im DOM.
const nf = new Intl.NumberFormat(lang === 'en' ? 'en-US' : 'de-DE');
const bigNumber = nf.format(problemStat.applicants); // „43.000" / „43,000"
const statText = P.stat
  .replace('{flats}', nf.format(problemStat.flats))
  .replace('{minutes}', nf.format(problemStat.minutes));
const countLocale = lang === 'en' ? 'en' : 'de';

// Mobile-Scoreboard: drei uniforme Stat-Zeilen (Zahl groß + Label). 43.000 = Emphasis.
const boardRows = [
  { value: problemStat.applicants, display: bigNumber, label: P.board.applicants, accent: true },
  { value: problemStat.minutes, display: nf.format(problemStat.minutes), label: P.board.minutes, accent: false },
  { value: problemStat.flats, display: nf.format(problemStat.flats), label: P.board.flats, accent: false },
];

// Lottie-Animationen je Vorteil (lazy via animations.ts geladen). Reihenfolge =
// benefits: Glocke (Push) · Globus (Portale) · Stift (Bewerbung). Als ?url →
// bleibt aus dem Main-Bundle draußen; JS fetcht + färbt auf CD-Gelb (Dunkel-BG).
import bellUrl from '../../assets/icons/system-regular-46-notification-bell-hover-bell.json?url';
import globeUrl from '../../assets/icons/system-regular-73-world-globe-wikis-hover-world.json?url';
import editUrl from '../../assets/icons/system-regular-114-edit-pencil-rename-hover-edit.json?url';
const LOTTIE = [bellUrl, globeUrl, editUrl];

// Statische Inline-Line-Icons = Fallback (No-JS / reduced-motion / Lottie-Fehler).
// Reihenfolge = benefits: Glocke (Push) · Globus (Portale) · Stift (Bewerbung).
const ICONS = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.5 2.5 3.8 5.7 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
];
---

<section id="problem" class="problem3c">
  {/* Vollflächiges Partikel-Canvas: die „43.000" formt sich hier (Deko-Ebene über dem
      dunklen Sektions-BG, unter dem Inhalt, z-0). Ohne JS/reduced-motion aus. */}
  <canvas class="p3-canvas" data-p3-canvas aria-hidden="true"></canvas>

  {/* Übergangs-Fläche: solide Hero-Grau (#eaebeb) deckt die Sektion im Ruhezustand
      LÜCKENLOS ab (nahtlos zum Hero, keine Kante). Beim Eintritt wischt sie per
      Clip-Path weg und gibt den dunklen BG frei. Nur mit JS+Motion sichtbar. */}
  <div class="section-wipe" data-p3-wipe aria-hidden="true"></div>

  <div class="p3-inner">
    {/* 1 · Partikel-Zahl (Display, KEIN Heading) + eng gekoppelter Statistik-Satz.
        Die „Stage" reserviert nur die Layout-Position der Zahl (Canvas zeichnet die
        Zahl dort). Ohne JS/reduced-motion: statische DOM-„43.000" sichtbar. */}
    <div class="p3-stat-block">
      <div class="p3-stage" data-p3-stage>
        {/* Desktop: Partikel-Fallback-Zahl. Mobile: sr-only (das Scoreboard zeigt sie). */}
        <span class="p3-num" data-p3-num>{bigNumber}</span>
      </div>

      {/* Statistik-Satz — Desktop sichtbar; auf Mobile sr-only, damit der Zusammenhang
          (inkl. 43.000 aus der Zahl darüber) vorlesbar bleibt, während das Scoreboard
          ihn visuell ersetzt. data-p3-reveal wie bisher. */}
      <p class="p3-stat" data-p3-reveal>
        {statText}<a href="#quelle-statistik" class="p3-ast" aria-label="Quelle der Statistik (Fußnote)">1</a>
      </p>

      {/* Mobile-Scoreboard (nur <lg, aria-hidden — der sr-only Satz oben trägt die
          Aussage). EIN typografisches System: drei uniforme Zeilen, Zahl groß
          (tabular-nums) + Label klein uppercase. Sequentieller Count-up per JS
          (initProblemMobile); ohne JS/reduced-motion stehen die Endwerte statisch. */}
      <div class="p3-board" data-p3-board data-p3-locale={countLocale} aria-hidden="true">
        {
          boardRows.map((row) => (
            <div class="p3-row">
              <span
                class:list={['p3-row-num', row.accent && 'is-accent']}
                data-p3-board-num
                data-target={row.value}
              >
                {row.display}
              </span>
              {/* Quellen-Fußnote (klein) an der Emphasis-Zahl; der reale Link steckt im
                  sr-only Satz. Geschwister des Count-up-Spans → wird nicht überschrieben. */}
              {row.accent && <sup class="p3-row-fn" aria-hidden="true">1</sup>}
              <span class="p3-row-label">{row.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    {/* 3 · Umkehr-Headline (H2) — groß, voller Kontrast, Marker nur auf „du".
        [data-p3-reveal]: wird per JS nach dem „du"-Moment eingeblendet; ohne JS /
        reduced-motion sofort sichtbar. */}
    <h2 class="p3-head" data-p3-reveal>
      <span>{headPrefix}</span><span class="p3-head-nowrap"
        ><span class="marker"
          ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
            >{headMark}</span
          ></span
        >{headSuffix}</span
      >
    </h2>

    {/* 4 · Vorteils-Reihe (kein Fließsatz), je Icon + Label */}
    <ul class="p3-benefits" data-p3-reveal>
      {
        benefits.map((b, i) => (
          <li class="p3-benefit">
            <span
              class="p3-benefit-ic"
              data-p3-lottie
              data-lottie-src={LOTTIE[i]}
              aria-hidden="true"
            >
              {/* Fallback-SVG: No-JS / reduced-motion / Lottie-Fehler. JS ersetzt es
                  durch die (auf Gelb umgefärbte) Lottie-Animation. */}
              <span class="p3-ic-fallback" set:html={ICONS[i]} />
            </span>
            <span class="p3-benefit-label">{b.label}</span>
          </li>
        ))
      }
    </ul>

    {/* 5 · Features-Verweis — direkt unter der Vorteils-Reihe. Scrollt smooth zur
        nächsten Sektion. BEWUSSTE PillButton-Ausnahme (dunkle Sektion): gelbe Pille,
        schwarzer Text + PERMANENTER Pfeil ↓ (dunkle Dot-Füllung auf dunklem BG geht
        nicht). Hover: Pille lifted, Pfeil tippt nach unten. */}
    <div class="p3-more-wrap" data-p3-reveal>
      <a class="p3-more" href="#portale">
        <span class="p3-more-label">{P.moreLink}</span>
        <svg
          class="p3-more-arrow"
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#3b3b3a"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 4v16" />
          <path d="m6 14 6 6 6-6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* ---- Dunkle 100svh-Bühne, zentriert (ein fokussierter Screen) ---- */
  .problem3c {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(3rem, 8vh, 6rem);
    /* Schmaler Inline-Rand (statt des großen Content-Insets) → die Partikel-„43.000"
       kann ~78% der SEKTIONSBREITE einnehmen. Text-Blöcke begrenzen sich selbst. */
    padding-inline: clamp(1rem, 3vw, 2.5rem);
    background-color: var(--color-black);
    color: var(--color-offwhite);
    overflow: hidden;
  }
  .p3-inner {
    position: relative;
    z-index: 1; /* über dem vollflächigen Partikel-Canvas (z-0) */
    width: 100%;
    /* Volle Sektionsbreite → die Partikel-„43.000" rendert dominant (~66%).
       Text-Blöcke (Satz/Trust/H2) begrenzen sich selbst über eigene max-widths. */
    max-width: none;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ---- 1 · Statistik-Block: Zahl + Satz bilden EINE enge Einheit ---- */
  .p3-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* WICHTIG: volle Breite — sonst schrumpft der Block (align-items:center des
       Inner) auf die Satzbreite und die Partikel-Stage/Zahl bleibt klein. */
    width: 100%;
  }
  /* Partikel-„Stage": Container, in dem sich die Zahl formt. Höhe wird per JS an
     die gesampelte Zahl gekoppelt (enge Kopplung zum Satz); die CSS-Höhe ist der
     Fallback (ohne JS zeigt sie die statische DOM-Zahl mittig). */
  .p3-stage {
    position: relative;
    width: 100%;
    height: clamp(140px, 34vw, 300px);
  }
  /* Vollflächiges Partikel-Canvas: hier formt sich die Zahl.
     Über dem dunklen Sektions-BG, unter dem Inhalt (.p3-inner z-1). Größe setzt JS. */
  .p3-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    /* nur mit JS+Motion sichtbar; ohne JS bleibt die statische Zahl auf Dunkel */
    display: none;
  }
  /* Übergangs-Fläche (Hero-Grau) — deckt im Ruhezustand die ganze Sektion ab, über
     Canvas UND Inhalt (z-5), aber unter der Nav-Pille (Header z-40). JS wischt sie
     per Clip-Path weg. Nur mit JS+Motion sichtbar (sonst nie ein grauer Vorhang). */
  .section-wipe {
    position: absolute;
    inset: 0;
    z-index: 5;
    background-color: var(--color-grey); /* #eaebeb = exakte Hero-BG-Farbe */
    pointer-events: none;
    clip-path: inset(0% 0% 0% 0%);
    display: none;
  }
  /* Echte DOM-Zahl: Fallback (No-JS/reduced-motion), mittig in der Stage. Bei
     aktiver Animation blendet JS sie aus (opacity 0) und das Canvas übernimmt. */
  .p3-num {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-size: clamp(3.5rem, 18vw, 9rem);
    font-variant-numeric: tabular-nums;
    color: var(--color-offwhite);
    white-space: nowrap;
  }
  /* ENGE Kopplung: sehr kleiner Abstand Zahl → Satz (ein Statistik-Block). */
  .p3-stat {
    margin-top: clamp(0.1rem, 0.5vw, 0.35rem);
    font-size: clamp(1rem, 2.4vw, 1.4rem);
    font-weight: 400;
    line-height: 1.3;
    max-width: 30ch; /* Mobile: darf umbrechen */
    color: rgb(246 246 246 / 0.72);
  }
  /* Desktop: Statistik-Satz EINZEILIG (unter der breiten Zahl ist reichlich Platz). */
  @media (min-width: 768px) {
    .p3-stat {
      max-width: none;
      white-space: nowrap;
    }
  }
  .p3-ast {
    font-size: 0.6em;
    vertical-align: super;
    margin-left: 0.1em;
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
  }

  /* ---- 3 · H2-Payoff: groß (kleiner als die Zahl), voller Kontrast, klar abgesetzt.
     Desktop EINZEILIG (nowrap); mobil natürlicher Umbruch. ---- */
  .p3-head {
    margin-top: clamp(2.5rem, 6vh, 4.5rem);
    font-size: clamp(1.9rem, 5.2vw, 3.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.02em;
    max-width: 18ch;
    color: var(--color-offwhite);
    text-wrap: balance;
  }
  @media (min-width: 768px) {
    .p3-head {
      /* einzeilig groß halten; Größe skaliert mit der Breite → kein Overflow */
      font-size: clamp(1.9rem, 4vw, 3rem);
      max-width: none;
      white-space: nowrap;
    }
  }
  /* „du." zusammenhalten (kein Umbruch zwischen Marker und Punkt).
     Gelber Marker NUR auf „du" → globale .marker-Klassen (siehe global.css). */
  .p3-head-nowrap {
    white-space: nowrap;
  }

  /* ---- 4 · Vorteils-Reihe: Desktop nebeneinander, Mobile umgebrochen ---- */
  .p3-benefits {
    list-style: none;
    margin: clamp(2rem, 4vw, 2.75rem) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.9rem 1.75rem;
  }
  .p3-benefit {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: clamp(1rem, 1.9vw, 1.15rem);
    font-weight: 500;
    color: var(--color-offwhite);
  }
  .p3-benefit-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    flex: none;
    color: var(--color-yellow); /* Fallback-SVG nutzt currentColor */
  }
  .p3-ic-fallback {
    display: inline-flex;
    width: 100%;
    height: 100%;
  }
  /* Fallback-SVG UND injizierte Lottie-SVG füllen die Icon-Box. */
  .p3-benefit-ic :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ---- 5 · Features-Verweis („Wir zeigen dir wie") — direkt unter den Vorteilen.
     Einheitliche PillButton (surface=dark). Der Wrapper trägt nur Abstand + Zentrierung
     (die Pille selbst bringt ihre Optik/States mit). data-p3-reveal blendet ihn ein. */
  .p3-more-wrap {
    margin-top: clamp(2rem, 5vh, 3.25rem);
    display: flex;
    justify-content: center;
  }
  /* Custom-CTA (gelbe Pille, schwarzer Text, permanenter Pfeil ↓). Kein Dot-Fill. */
  .p3-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 54px;
    padding: 0 26px;
    border-radius: 999px;
    background: var(--color-yellow);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 12px 34px -14px rgb(0 0 0 / 0.45);
    transition:
      transform 0.25s ease-out,
      box-shadow 0.25s ease-out;
  }
  .p3-more-arrow {
    display: block;
    flex: none;
    transition: transform 0.25s ease-out;
  }
  @media (max-width: 767.98px) {
    .p3-more {
      height: 50px;
      font-size: 14px;
    }
  }
  @media (hover: hover) and (pointer: fine) {
    .p3-more:hover {
      transform: translateY(-2px);
      box-shadow: 0 22px 48px -16px rgb(0 0 0 / 0.55);
    }
    .p3-more:hover .p3-more-arrow {
      transform: translateY(3px);
    }
  }
  .p3-more:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 2px var(--color-black),
      0 0 0 4px var(--color-yellow);
  }
  /* reduced-motion: keine Transform-Transition (nur Schatten-Feedback). */
  @media (prefers-reduced-motion: reduce) {
    .p3-more {
      transition: box-shadow 0.25s ease-out;
    }
    .p3-more-arrow {
      transition: none;
    }
    .p3-more:hover {
      transform: none;
    }
  }

  /* Partikel-Canvas + Übergangs-Fläche nur mit JS + erlaubter Bewegung UND ab lg
     sichtbar. WICHTIG (Mobile-Guardrail): Formung und Wisch werden ausschließlich
     ≥1024px per JS (initProblem3c) getrieben — unterhalb lg kehrt der Init früh
     zurück. Würde die graue .section-wipe hier per CSS eingeblendet, bliebe sie
     mangels JS-Wisch DAUERHAFT als grauer Vorhang (z-5) über der Sektion stehen =
     unsichtbare Problem-Sektion. Darum an dieselbe 1024px-Grenze wie der JS-Gate
     koppeln → mobil kein Canvas/Vorhang, der statische DOM-Inhalt steht sofort. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 1024px) {
    :global(html.js) .p3-canvas,
    :global(html.js) .section-wipe {
      display: block;
    }
  }

  /* Mobile: Vorteile dürfen umbrechen, Zahl etwas kompakter. */
  @media (max-width: 767.98px) {
    .p3-num {
      font-size: clamp(4rem, 26vw, 7rem);
    }
    .p3-benefits {
      gap: 0.75rem 1.25rem;
    }
  }

  /* =====================================================================
     Block 3 (Runde 4) — Mobile-„Anzeigetafel". EIN typografisches System: drei
     uniforme Stat-Zeilen (Zahl groß, tabular-nums, EINE Größe · Label klein
     uppercase). Nur <lg sichtbar; ≥lg bleibt der Desktop (Partikel-Zahl + Satz)
     unverändert. Auf Mobile werden die Desktop-Zahl (.p3-num) und der Satz
     (.p3-stat) sr-only → Aussage bleibt vorlesbar, Scoreboard trägt sie visuell.
     ===================================================================== */
  .p3-board {
    display: none; /* ≥lg: aus (Desktop nutzt Partikel-Zahl + Satz) */
    width: 100%;
    max-width: 22rem;
    margin: clamp(0.75rem, 3vw, 1.5rem) auto 0;
    text-align: left;
  }
  @media (max-width: 1023.98px) {
    /* Desktop-Zahl + Satz sr-only (Position kollabiert). */
    .p3-stage {
      min-height: 0;
      height: 0;
    }
    .p3-num,
    .p3-stat {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      white-space: nowrap;
      margin: -1px;
      padding: 0;
      border: 0;
    }
    .p3-board {
      display: block;
    }
  }
  .p3-row {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    padding-block: clamp(0.55rem, 2.4vw, 0.95rem);
    border-top: 1px solid rgb(246 246 246 / 0.1);
  }
  .p3-row:last-of-type {
    border-bottom: 1px solid rgb(246 246 246 / 0.1);
  }
  .p3-row-num {
    font-weight: 900;
    font-size: clamp(3rem, 13vw, 3.75rem); /* EINE Größe für alle drei Zeilen */
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums; /* kein Breiten-Zappeln beim Count-up */
    color: var(--color-offwhite);
  }
  .p3-row-num.is-accent {
    color: var(--color-yellow); /* nur 43.000 = Emphasis */
  }
  .p3-row-fn {
    align-self: flex-start;
    margin-left: -0.15rem;
    font-size: 0.85rem;
    line-height: 1;
    color: rgb(246 246 246 / 0.5);
  }
  .p3-row-label {
    margin-left: auto; /* Label rechts, Zahlen an EINER linken Kante */
    font-size: clamp(0.72rem, 3vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(246 246 246 / 0.55);
  }
</style>
