---
/**
 * Problem → Lösung — gepinnte Dark-to-Light-Scroll-Story.
 *
 * Die dunklen Beats liegen in EINEM gepinnten 100svh-Stage („mitte mitte"),
 * absolut gestapelt; beim Scrollen wird per GSAP ScrollTrigger (pin + scrub,
 * sauber über Lenis) durch die Beats GESCRUBBT — alter Beat blendet unscharf
 * (Desktop) + transparent nach oben aus, neuer scharf von unten in die Mitte
 * (Crossfade). Ein schlanker Fortschrittsbalken hängt am Scrub. Am Ende: harter
 * „Licht-an"-Cut → Lösung. KEIN Scroll-Hijack (kein preventDefault), frei scrollbar.
 *
 * OBERSTES GEBOT (Guardrails): Ruhezustand = HELL. Ohne JS / prefers-reduced-
 * motion sind die Beats einfach statisch UNTEREINANDER (voller Kontrast, Zahlen
 * ENDWERT), die Lösung + CTA sichtbar — KEIN Pin/Scrub/Blur/Counter/Blitz/Kette.
 * Die gepinnte Mechanik ist reine JS-Zugabe (animations.ts: initProblemStory).
 *
 * Genau EINE H1 bleibt im Hero; dieser Block nutzt H2. Fakten aus site.ts.
 */
import StoreBadges from '../StoreBadges.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { portalCountRounded } from '../../data/site';
import type { Locale } from '../../data/site';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const P = t.sections.problem;
const S = t.sections.solution;

/* --- Beats in Wort-Einheiten zerlegen; **…** = reine Zahl (gelb + Counter). --- */
type Unit = { text: string; em: boolean };
function tokenize(src: string): Unit[] {
  let plain = '';
  const ranges: Array<[number, number]> = [];
  src.split('**').forEach((part, i) => {
    const start = plain.length;
    plain += part;
    if (i % 2 === 1) ranges.push([start, plain.length]);
  });
  const units: Unit[] = [];
  const re = /\S+/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(plain)) !== null) {
    const s = m.index;
    const e = s + m[0].length;
    const em = ranges.some(([rs, reEnd]) => s < reEnd && e > rs);
    units.push({ text: m[0], em });
  }
  return units;
}

const beatUnits = P.beats.map((b) => tokenize(b));
const subUnits = tokenize(P.beat2Sub);
const turnUnits = tokenize(P.turn);

/* --- Heller Lösungs-Teil: **…** → gelber Marker (Phrase, statisch). --- */
const solText = S.text.replace('{n}', String(portalCountRounded));
function splitEmphasis(src: string) {
  return src.split('**').map((seg, i) => ({ text: seg, mark: i % 2 === 1 }));
}
const solSegs = splitEmphasis(solText);

function splitMark(line: string, keyword: string) {
  const idx = line.indexOf(keyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: keyword, mark: true },
    { text: line.slice(idx + keyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
const headlineSegs = splitMark(S.headline, S.headlineMark);

// Zahl als eigenes, zählbares Element rendern (Rest = Klartext).
const LAMP_LINKS = 6; // gestapelte Kettenglieder → biegbare Welle
---

<div class="story" data-story>
  {/* Fixe Overlay-Ebene (dimmen) + Weiß-Blitz (Licht-Cut). Default aus. */}
  <div class="story-overlay" data-story-overlay aria-hidden="true"></div>
  <div class="story-flash" data-story-flash aria-hidden="true"></div>

  {/* ---- PROBLEM (gepinnte Beat-Story) ---- */}
  <section id="problem" class="story-sec story-dark">
    <h2 class="sr-only">{P.title}</h2>

    <div class="pin-stage" data-pin-stage>
      <div class="beat-track" data-problem>
        {
          beatUnits.map((units, bi) => (
            <div class="beat-slide" data-beat>
              <p class="beat">
                {units.map((u, i) => (
                  <>
                    {i > 0 && ' '}
                    {u.em ? (
                      <span
                        class="fill-num"
                        data-count-to={u.text.replace(/\D/g, '')}
                        style={`min-width:${u.text.length}ch`}
                      >
                        {u.text}
                      </span>
                    ) : (
                      u.text
                    )}
                  </>
                ))}
                {bi === 1 && (
                  <a
                    href="#quelle-statistik"
                    class="stat-ast"
                    aria-label="Quelle der Statistik (Fußnote)"
                  >
                    *
                  </a>
                )}
              </p>
              {bi === 1 && (
                <p class="beat-sub">
                  {subUnits.map((u, i) => (
                    <>{i > 0 && ' '}{u.text}</>
                  ))}
                </p>
              )}
            </div>
          ))
        }

        {/* Wendepunkt-Beat + Lampenkette */}
        <div class="beat-slide beat-slide--turn" data-beat>
          <p class="beat beat-turn">
            {turnUnits.map((u, i) => (
              <>{i > 0 && ' '}{u.text}</>
            ))}
          </p>

          <button class="lamp" data-lamp type="button" aria-label={S.lightOn}>
            <span class="lamp-chain" aria-hidden="true">
              {
                Array.from({ length: LAMP_LINKS }).map((_, i) => (
                  <span class="lamp-link" style={`--i:${i}`}></span>
                ))
              }
              <span class="lamp-knob" style={`--i:${LAMP_LINKS}`}>
                <span class="lamp-glow"></span>
              </span>
            </span>
            <span class="lamp-hint" aria-hidden="true">
              {S.clickHint}<span class="lamp-hint-arrow">↓</span>
            </span>
          </button>
        </div>
      </div>

      {/* Fortschrittsbalken (nur JS+Motion, hängt am Scrub der gepinnten Story). */}
      <div class="story-progress" data-progress aria-hidden="true">
        <span class="story-progress-fill" data-progress-fill></span>
      </div>
    </div>
  </section>

  {/* ---- LÖSUNG (Licht an, 100svh, zentriert) ---- */}
  <section id="loesung" class="story-sec story-light">
    <div class="panel">
      <div class="panel-inner">
        <h2 class="sol-headline" data-sol-item>
          {
            headlineSegs.map((seg) =>
              seg.mark ? <span class="mark">{seg.text}</span> : <span>{seg.text}</span>,
            )
          }
        </h2>
        <p class="sol-text" data-sol-item>
          {
            solSegs.map((seg) =>
              seg.mark ? <span class="mark">{seg.text}</span> : <span>{seg.text}</span>,
            )
          }
        </p>
        <div class="sol-cta" data-sol-item>
          <StoreBadges position="loesung" lang={lang} />
          <span class="sol-cta-note">{t.cta.tryFree}</span>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* ---- Bühne + Ebenen ---- */
  .story {
    position: relative;
    background-color: var(--color-grey);
  }
  .story-overlay {
    position: fixed;
    inset: 0;
    z-index: 5;
    background-color: var(--color-black);
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }
  .story-flash {
    position: fixed;
    inset: 0;
    z-index: 30;
    background-color: var(--color-offwhite);
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }
  .story-sec {
    position: relative;
    z-index: 20;
  }

  /* ---- Pin-Stage / Beats ----
     DEFAULT (ohne JS / reduced-motion): normaler Fluss, Beats UNTEREINANDER,
     voll sichtbar & lesbar. Kein Pin. */
  .pin-stage {
    position: relative;
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
  }
  .beat-track {
    max-width: 52rem;
    margin-inline: auto;
    text-align: center;
  }
  .beat-slide + .beat-slide {
    margin-top: clamp(3rem, 10vh, 6rem);
  }

  .beat {
    font-size: clamp(1.9rem, 5.4vw, 3.6rem);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.01em;
    text-wrap: balance;
    max-width: 22ch;
    margin-inline: auto;
    color: var(--color-black); /* Default dunkel (lesbar auf hell) */
  }
  .beat-sub {
    margin: clamp(1rem, 2.5vw, 1.5rem) auto 0;
    font-size: clamp(1rem, 2.4vw, 1.4rem);
    font-weight: 400;
    line-height: 1.35;
    max-width: 36rem;
    color: var(--color-black);
  }
  .beat-turn {
    font-size: clamp(2.1rem, 6vw, 4rem);
    max-width: 20ch;
  }
  .fill-num {
    color: var(--color-black); /* Default dunkel; JS+Motion → gelb (Counter) */
    font-weight: 900;
    display: inline-block;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .stat-ast {
    font-size: 0.5em;
    vertical-align: super;
    margin-left: 0.1em;
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
  }

  /* JS + Motion: gepinnter, absolut gestapelter Crossfade-Stage + weißer Text. */
  @media (prefers-reduced-motion: no-preference) {
    html.js .pin-stage {
      height: 100svh;
      padding-block: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden; /* Blur-Bleed am Rand klippen */
    }
    html.js .beat-track {
      position: relative;
      width: 100%;
      height: 100%;
    }
    html.js .beat-slide {
      position: absolute;
      inset: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding-inline: var(--spacing-inset);
      will-change: transform, opacity;
    }
    /* Vor GSAP-Init: nur der erste Beat sichtbar (kein Überlappungs-Blitz). */
    html.js .beat-slide:not(:first-child) {
      opacity: 0;
    }
    html.js .story-dark .beat,
    html.js .story-dark .beat-sub {
      color: var(--color-offwhite); /* #f6f6f6 auf Dunkel */
    }
    html.js .story-dark .fill-num {
      color: var(--color-yellow);
    }
  }

  /* ---- Fortschrittsbalken (nur JS+Motion; hängt am Scrub) ---- */
  .story-progress {
    display: none;
    position: absolute;
    right: clamp(10px, 2.5vw, 22px);
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: clamp(84px, 24vh, 190px);
    border-radius: 999px;
    background-color: rgb(246 246 246 / 0.2);
    overflow: hidden;
    opacity: 0; /* per JS ein-/ausgeblendet */
    z-index: 22;
    pointer-events: none;
  }
  .story-progress-fill {
    position: absolute;
    inset: 0;
    display: block;
    background-color: var(--color-yellow);
    transform: scaleY(0);
    transform-origin: top center;
  }
  @media (prefers-reduced-motion: no-preference) {
    html.js .story-progress {
      display: block;
    }
  }

  /* ---- Lampenkette (Licht-an-Trigger) — nur JS+Motion sichtbar ---- */
  .lamp {
    display: none;
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 6vh, 4rem);
    transform: translateX(-50%);
    flex-direction: column;
    align-items: center;
    background: none;
    border: 0;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    z-index: 23;
  }
  .lamp-chain {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .lamp-link {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background-color: var(--color-grey-yellow);
    will-change: transform;
  }
  .lamp-knob {
    position: relative;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    border-radius: 9999px;
    background-color: var(--color-yellow);
    will-change: transform;
  }
  .lamp-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 34px;
    height: 34px;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgb(255 240 60 / 0.4), rgb(255 240 60 / 0));
    z-index: -1;
    opacity: 0.4;
  }
  .lamp-hint {
    margin-top: 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(246 246 246 / 0.92);
    text-shadow: 0 1px 6px rgb(0 0 0 / 0.45);
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
  }
  .lamp-hint-arrow {
    font-size: 0.9em;
  }
  .lamp:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 4px;
    border-radius: 6px;
  }
  @media (prefers-reduced-motion: no-preference) {
    html.js .lamp {
      display: flex;
    }
    /* Idle „Zupfer" als WELLE: jedes Glied gleiche Bewegung, nach unten gestaffelt
       (animation-delay über --i) → die Kette biegt sich (nur transform). */
    html.js .lamp-link,
    html.js .lamp-knob {
      animation: lampTug 3.2s ease-in-out infinite;
      animation-delay: calc(var(--i) * 0.045s);
    }
    html.js .lamp-glow {
      animation: lampGlowPulse 2.8s ease-in-out infinite;
    }
  }
  @keyframes lampTug {
    0%, 58% { transform: translateY(0); }
    70% { transform: translateY(6px); }
    84% { transform: translateY(-1.5px); } /* Überschwingen zurück */
    92% { transform: translateY(0.5px); }
    100% { transform: translateY(0); }
  }
  @keyframes lampGlowPulse {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.55; transform: translate(-50%, -50%) scale(1.12); }
  }

  /* ---- Heller Lösungs-Teil (100svh, zentriert) ---- */
  .panel {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(4rem, 10vh, 7rem);
    padding-inline: var(--spacing-inset);
  }
  .panel-inner {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    text-align: center;
  }
  .sol-headline {
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    max-width: 20ch;
    margin-inline: auto;
    color: var(--color-black);
  }
  .sol-text {
    margin: clamp(1.25rem, 3vw, 2rem) auto 0;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.4;
    max-width: 42rem;
    color: var(--color-black);
  }
  .sol-cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem 1.25rem;
  }
  .sol-cta-note {
    font-size: 0.95rem;
    font-weight: 700;
    color: rgb(59 59 58 / 0.75);
  }
</style>
