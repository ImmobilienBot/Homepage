---
/**
 * Problem → Lösung — cinematischer Dark-to-Light-Scroll (Storytelling-Bogen).
 *
 * ZWEI eigenständige <section>-Elemente (#problem, #loesung) für SEO/Struktur.
 * Jeder Story-Beat + der Lösungs-Screen ist ein eigenes 100svh-Panel; sanftes
 * Einrasten NUR via CSS-Scroll-Snap (scroll-snap-type: y proximity) — KEIN
 * JS-Snapping, KEIN wheel/touch-preventDefault → volle Scroll-Kontrolle bleibt.
 *
 * Dunkel→Hell via fixe Overlay-Ebene, deren OPACITY gescrubbt wird: 0→1 (spät &
 * stark), halten, 1→0 (harter, schneller „Licht-an"-Cut + kurzer Weiß-Blitz).
 *
 * OBERSTES GEBOT (Guardrails): Ruhezustand = HELL. Ohne JS / prefers-reduced-
 * motion: Overlay-Opacity 0, kein Snap, kein Counter, kein Dimm-/Licht-Wechsel,
 * kein Blitz, keine Kette; alle Beats + Zahlen (ENDWERT) + Lösung + CTA sichtbar.
 * Snap/Cursor-Invert/Counter/Kette/Flash = reine JS-Zugabe (initProblemStory).
 *
 * Genau EINE H1 bleibt im Hero; dieser Block nutzt H2. Fakten aus site.ts.
 */
import StoreBadges from '../StoreBadges.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { portalCountRounded } from '../../data/site';
import type { Locale } from '../../data/site';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const P = t.sections.problem;
const S = t.sections.solution;

/* --- Dunkle Beats: in Wort-Einheiten zerlegen; **…** = reine Zahl (gelb + Counter). --- */
type Unit = { text: string; em: boolean };
function tokenize(src: string): Unit[] {
  let plain = '';
  const ranges: Array<[number, number]> = [];
  src.split('**').forEach((part, i) => {
    const start = plain.length;
    plain += part;
    if (i % 2 === 1) ranges.push([start, plain.length]);
  });
  const units: Unit[] = [];
  const re = /\S+/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(plain)) !== null) {
    const s = m.index;
    const e = s + m[0].length;
    const em = ranges.some(([rs, reEnd]) => s < reEnd && e > rs);
    units.push({ text: m[0], em });
  }
  return units;
}

const beatUnits = P.beats.map((b) => tokenize(b));
const subUnits = tokenize(P.beat2Sub);
const turnUnits = tokenize(P.turn);

/* --- Heller Lösungs-Teil: **…** → gelber Marker (Phrase, statisch). --- */
const solText = S.text.replace('{n}', String(portalCountRounded));
function splitEmphasis(src: string) {
  return src.split('**').map((seg, i) => ({ text: seg, mark: i % 2 === 1 }));
}
const solSegs = splitEmphasis(solText);

/* Headline mit gelbem Keyword-Marker. */
function splitMark(line: string, keyword: string) {
  const idx = line.indexOf(keyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: keyword, mark: true },
    { text: line.slice(idx + keyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
const headlineSegs = splitMark(S.headline, S.headlineMark);
---

<div class="story" data-story>
  {/* Dunkle Overlay-Ebene (fixed): Opacity gescrubbt (0→1→0). Default 0. */}
  <div class="story-overlay" data-story-overlay aria-hidden="true"></div>
  {/* Weiß-Blitz für den „Licht-an"-Cut (EIN kurzer Impuls, kein Stroboskop). */}
  <div class="story-flash" data-story-flash aria-hidden="true"></div>

  {/* ---- PROBLEM (dunkle 100svh-Panels) ---- */}
  <section id="problem" class="story-sec story-dark">
    <h2 class="sr-only">{P.title}</h2>

    <div class="beats" data-problem>
      {
        beatUnits.map((units, bi) => (
          <div class="panel" data-panel-first={bi === 0 ? true : undefined}>
            <div class="panel-inner">
              <p class="beat">
                {units.map((u, i) => (
                  <>
                    {i > 0 && ' '}
                    {u.em ? (
                      <span
                        class="fill-num"
                        data-count-to={u.text.replace(/\D/g, '')}
                        style={`min-width:${u.text.length}ch`}
                      >
                        {u.text}
                      </span>
                    ) : (
                      <span class="fill-word">{u.text}</span>
                    )}
                  </>
                ))}
                {bi === 1 && (
                  <a
                    href="#quelle-statistik"
                    class="stat-ast"
                    aria-label="Quelle der Statistik (Fußnote)"
                  >
                    *
                  </a>
                )}
              </p>

              {bi === 1 && (
                <p class="beat-sub">
                  {subUnits.map((u, i) => (
                    <>
                      {i > 0 && ' '}
                      <span class="fill-word">{u.text}</span>
                    </>
                  ))}
                </p>
              )}
            </div>

            {/* Dezenter Scroll-Cue am unteren Panel-Rand (hell auf dunkel). */}
            <span class="scroll-cue scroll-cue--beat" aria-hidden="true">
              <span class="scroll-cue-dot"></span>
            </span>
          </div>
        ))
      }

      {/* Wendepunkt-Panel — alle Wörter weiß; unten die Lampenkette. */}
      <div class="panel panel--turn">
        <div class="panel-inner">
          <p class="beat beat-turn">
            {turnUnits.map((u, i) => (
              <>
                {i > 0 && ' '}
                <span class="fill-word">{u.text}</span>
              </>
            ))}
          </p>
        </div>

        {/* Lampenkette (Licht-an) — nur mit JS+Motion sichtbar (CSS-gated).
            Klick ODER Weiterscrollen schalten das Licht an. */}
        <button class="lamp" data-lamp type="button" aria-label={S.lightOn}>
          <span class="lamp-swing" aria-hidden="true">
            <span class="lamp-cord"></span>
            <span class="lamp-knob"><span class="lamp-glow"></span></span>
          </span>
          <span class="lamp-hint" aria-hidden="true">
            {S.clickHint}<span class="lamp-hint-arrow">↓</span>
          </span>
        </button>
      </div>
    </div>
  </section>

  {/* ---- LÖSUNG (Licht an, 100svh-Panel, zentriert) ---- */}
  <section id="loesung" class="story-sec story-light">
    <div class="panel">
      <div class="panel-inner">
        <h2 class="sol-headline" data-sol-item>
          {
            headlineSegs.map((seg) =>
              seg.mark ? <span class="mark">{seg.text}</span> : <span>{seg.text}</span>,
            )
          }
        </h2>

        <p class="sol-text" data-sol-item>
          {
            solSegs.map((seg) =>
              seg.mark ? <span class="mark">{seg.text}</span> : <span>{seg.text}</span>,
            )
          }
        </p>

        <div class="sol-cta" data-sol-item>
          <StoreBadges position="loesung" lang={lang} />
          <span class="sol-cta-note">{t.cta.tryFree}</span>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* ---- Bühne + Ebenen ---- */
  .story {
    position: relative;
    background-color: var(--color-grey); /* #eaebeb — heller Ruhezustand */
  }
  .story-overlay {
    position: fixed;
    inset: 0;
    z-index: 5;
    background-color: var(--color-black); /* #3b3b3a */
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }
  /* Weiß-Blitz: über dem Story-Text (z-20), unter der Nav (z-40). Default aus. */
  .story-flash {
    position: fixed;
    inset: 0;
    z-index: 30;
    background-color: var(--color-offwhite);
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }
  .story-sec {
    position: relative;
    z-index: 20;
  }

  /* ---- 100svh-Panels + sanftes CSS-Scroll-Snap (proximity, kein Hijack) ---- */
  .panel {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center; /* mitte-mitte */
    justify-content: center;
    padding-block: clamp(4rem, 10vh, 7rem);
    padding-inline: var(--spacing-inset);
  }
  .panel-inner {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    text-align: center; /* Content horizontal + (via flex) vertikal zentriert */
  }
  /* KEIN CSS-Scroll-Snap: kollidiert mit Lenis (Totzone/„plopp"). Freie
     Lenis-Scrollbewegung; jedes 100svh-Panel enthüllt seinen Inhalt beim
     Eintritt (on-enter reveal in animations.ts), nicht scroll-gescrubbt. */

  /* ---- Beats (Roboto Black, zentriert, fluten Wort für Wort ein) ---- */
  .beat {
    font-size: clamp(1.9rem, 5.4vw, 3.6rem);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.01em;
    text-wrap: balance;
    max-width: 22ch;
    margin-inline: auto;
  }
  .beat-sub {
    margin: clamp(1rem, 2.5vw, 1.5rem) auto 0;
    font-size: clamp(1rem, 2.4vw, 1.4rem);
    font-weight: 400;
    line-height: 1.35;
    max-width: 36rem;
  }
  .beat-turn {
    font-size: clamp(2.1rem, 6vw, 4rem);
    max-width: 20ch;
  }

  /* Reguläre Wörter: Default dunkel (lesbar auf hell). JS+Motion → flood auf WEISS. */
  .fill-word {
    color: var(--color-black);
  }
  /* Reine ZAHL: Default dunkel; JS+Motion → gelb + Counter. tabular-nums +
     reservierte Breite (inline min-width) → kein CLS beim Hochzählen. */
  .fill-num {
    color: var(--color-black);
    font-weight: 900;
    display: inline-block;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .stat-ast {
    font-size: 0.5em;
    vertical-align: super;
    margin-left: 0.1em;
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
  }

  /* Pre-Mute NUR bei JS + Motion. Ohne JS / reduced-motion → voller Kontrast. */
  @media (prefers-reduced-motion: no-preference) {
    html.js .story-dark .fill-word {
      color: rgb(246 246 246 / 0.16);
    }
    html.js .story-dark .fill-num {
      color: var(--color-yellow);
    }
  }

  /* ---- Scroll-Cue („Maus"-Kontur mit gleitendem Punkt), unten im Beat-Panel ---- */
  .scroll-cue--beat {
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 4vh, 2.5rem);
    transform: translateX(-50%);
    display: block;
    width: 20px;
    height: 32px;
    border: 2px solid var(--color-offwhite);
    border-radius: 12px;
    color: var(--color-offwhite);
    opacity: 0.35;
  }
  .scroll-cue-dot {
    position: absolute;
    left: 50%;
    top: 6px;
    width: 4px;
    height: 7px;
    border-radius: 2px;
    background-color: currentColor;
    transform: translateX(-50%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue-dot {
      animation: cueDot 1.8s ease-in-out infinite;
    }
  }
  @keyframes cueDot {
    0% { opacity: 0; transform: translate(-50%, 0); }
    25% { opacity: 1; }
    75% { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%, 10px); }
  }

  /* ---- Lampenkette (Licht-an-Trigger) ----
     Nur mit JS + Motion sichtbar; ohne JS / reduced-motion ausgeblendet
     (Lösung dort ohnehin statisch sichtbar → niemand hängt fest). */
  .lamp {
    display: none;
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 5vh, 3.5rem);
    transform: translateX(-50%);
    flex-direction: column;
    align-items: center;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
    z-index: 21;
  }
  .lamp-swing {
    display: flex;
    flex-direction: column;
    align-items: center;
    transform-origin: top center;
  }
  .lamp-cord {
    width: 2px;
    height: clamp(36px, 8vw, 60px);
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-grey-yellow) 0 4px,
      transparent 4px 7px
    );
  }
  .lamp-knob {
    position: relative;
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    background-color: var(--color-yellow);
  }
  /* Dezenter, weicher Gelb-Schimmer um den Knauf (KEIN greller Leucht-Ball). */
  .lamp-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 34px;
    height: 34px;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgb(255 240 60 / 0.4), rgb(255 240 60 / 0));
    z-index: -1;
    opacity: 0.4;
  }
  /* Mikro-Label „Klick" + Pfeil — gut lesbar (heller, leichter Schatten). */
  .lamp-hint {
    margin-top: 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(246 246 246 / 0.92);
    text-shadow: 0 1px 6px rgb(0 0 0 / 0.45);
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
  }
  .lamp-hint-arrow {
    font-size: 0.9em;
  }
  @media (prefers-reduced-motion: no-preference) {
    html.js .lamp {
      display: flex;
    }
    /* Periodischer vertikaler „Zupfer" (ziehen/klicken) statt Deko-Schaukeln. */
    html.js .lamp-swing {
      animation: lampTug 3s ease-in-out infinite;
    }
    /* Sehr dezenter Schimmer-Puls (klein). */
    html.js .lamp-glow {
      animation: lampGlowPulse 2.8s ease-in-out infinite;
    }
  }
  .lamp:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 4px;
    border-radius: 6px;
  }
  /* „Zupfer": kurz nach unten ziehen, mit leichtem Überschwingen zurück. */
  @keyframes lampTug {
    0%, 62% { transform: translateY(0); }
    72% { transform: translateY(8px); }
    84% { transform: translateY(-2px); }
    92% { transform: translateY(1px); }
    100% { transform: translateY(0); }
  }
  @keyframes lampGlowPulse {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.55; transform: translate(-50%, -50%) scale(1.12); }
  }

  /* ---- Heller Lösungs-Teil (zentriert) ---- */
  .sol-headline {
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    max-width: 20ch;
    margin-inline: auto;
    color: var(--color-black);
  }
  .sol-text {
    margin: clamp(1.25rem, 3vw, 2rem) auto 0;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.4;
    max-width: 42rem;
    color: var(--color-black);
  }
  .sol-cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem 1.25rem;
  }
  .sol-cta-note {
    font-size: 0.95rem;
    font-weight: 700;
    color: rgb(59 59 58 / 0.75);
  }
</style>
