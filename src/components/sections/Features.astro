---
/**
 * Features — zwei Ebenen auf hellem CD-Grund (#eaebeb), einheitlicher
 * Sektions-Rhythmus. Folgt direkt auf die Portale-Sektion, vor den Preisen.
 *
 * TIER 1 (content-first, progressive enhancement): drei Schritte als gestapelte
 * Blöcke (Nummer-Chip · H3 · Body · Checkmark-Liste · zugehöriges Phone). Der
 * Basis-Stapel gilt IMMER (ohne JS, reduced-motion, mobil): alle drei Bodies
 * offen, jedes Phone sichtbar. Nur ≥lg + JS schaltet auf ein zweispaltiges
 * Autoplay-Accordion: links EIN gemeinsames Phone (voller Rahmen, Crossfade der
 * drei Screens), rechts die drei Schritte als Accordion (Disclosure-Buttons in
 * den H3, ein Item offen, 8s-Autoplay mit Fortschrittsbalken). Das gemeinsame
 * Phone ist Deko (aria-hidden, leere Alts); die inhaltlichen Bilder mit Alt-Texten
 * bleiben die in den Blöcken. Beide Phone-Ebenen werden AUSSCHLIESSLICH per
 * JS-Klasse (.is-enhanced) umgeschaltet — nie per CSS-Default.
 *
 * TIER 2: Bento „Und das steckt noch drin." — 5 Kacheln (Elevation, weiche
 * Schatten). Easter-Eggs: Listenansichten S/M/L (Hover-Zyklus + wandernder
 * Marker), Sprach-Globus (Lottie auf Hover) und eine Dark-Mode-Kachel mit
 * Lichtschalter-Kette (harter Farb-Toggle, choreografierter Icon-Wechsel).
 *
 * Fakten/Texte aus i18n. Genau EINE H1 bleibt im Hero → hier H2/H3/H4.
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenMap from '../../assets/images/immobilien-bot-suchbereich-karte-zeichnen.png';
import screenConfig from '../../assets/images/immobilien-bot-suche-konfigurieren.png';
import screenList from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import screenLetter from '../../assets/images/immobilien-bot-bewerbungsschreiben.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

// Sprach-Kachel: Globus als Lottie (lazy via animations.ts). ?url → bleibt aus
// dem Main-Bundle; JS fetcht + spielt die Instanz. Die JSON-Farben sind bereits
// CD-Schwarz #3b3b3a → passt direkt auf den hellen Chip (keine Umfärbung nötig).
import globeUrl from '../../assets/icons/system-regular-73-world-globe-wikis-hover-world.json?url';

const t = useTranslations(getLangFromUrl(Astro.url));
const F = t.sections.features;

// Screens je Schritt (Reihenfolge = steps): Karte, Kriterien, Angebotsliste, Bewerbung.
const shots = [screenMap, screenConfig, screenList, screenLetter];

// Marker-Split: Prefix + markiertes Keyword + Suffix (wie Hero/Problem/Portale).
function markParts(text: string, mark: string) {
  const i = text.indexOf(mark);
  if (i < 0) return { pre: text, mark: '', post: '' };
  return { pre: text.slice(0, i), mark, post: text.slice(i + mark.length) };
}
const h2 = markParts(F.h2, F.h2Mark);
const bento = markParts(F.bentoTitle, F.bentoMark);

// Inline-Häkchen (currentColor) für die Check-Listen.
const CHECK_SVG = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>`;

// Fallback-Globus (No-JS / reduced-motion / Lottie-Fehler) — CD-Schwarz.
const GLOBE_SVG = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9.2"/><path d="M2.8 12h18.4"/><path d="M12 2.8c2.6 2.6 4 5.9 4 9.2s-1.4 6.6-4 9.2c-2.6-2.6-4-5.9-4-9.2s1.4-6.6 4-9.2Z"/></svg>`;
---

<section id="features" class="ft-section">
  <div class="ft-inner">
    {/* ---- Sektions-Header: Eyebrow · H2 (Mask-Reveal + Marker) · Subline ---- */}
    <header class="ft-head">
      <p class="ft-eyebrow">{F.eyebrow}</p>
      <h2 class="ft-h2">
        <span class="ft-mask"
          ><span class="ft-mask-in"
            >{h2.pre}<span class="marker"
              ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
                >{h2.mark}</span
              ></span
            >{h2.post}</span
          ></span
        >
      </h2>
      <p class="ft-sub" data-ft-sub>{F.subline}</p>
    </header>

    {/* ================= TIER 1 — drei Schritte ================= */}
    <div class="ft-steps" data-ft-steps>
      {/* Gemeinsames Phone (nur Desktop-Enhancement, per JS eingeblendet). Voller
          Rahmen, alle drei Screens absolut übereinander (Opacity-Crossfade).
          Deko-Duplikat: aria-hidden + leere Alts + lazy. Default per CSS versteckt. */}
      <div class="ft-shared-phone" data-ft-shared aria-hidden="true">
        <div class="ft-phone-stage">
          <div class="ft-glow" aria-hidden="true"></div>
          <div class="ft-phone">
            {/* Screen-Maske: die Screens sliden HIER hinein (overflow:hidden) →
                der Slide (translateY 103% → 0) bleibt aufs Display beschränkt. */}
            <div class="ft-screen" data-ft-screen>
              {
                shots.map((src, i) => (
                  <div class="ft-shot" data-ft-shot={i}>
                    <Image src={src} alt="" class="ft-shot-img" loading="lazy" />
                  </div>
                ))
              }
              {/* Signature: Push-Karte auf dem „Sofort benachrichtigt"-Slide.
                  Federt ~0,7 s nach dem Settle oben herein (JS). */}
              <div class="ft-push" data-ft-push>
                <Image src={appIcon} alt="" width={96} height={96} class="ft-push-icon" />
                <div class="ft-push-txt">
                  <p class="ft-push-head">
                    <span class="truncate">{F.notif.app}</span>
                    <span class="ft-push-time">{F.notif.time}</span>
                  </p>
                  <p class="ft-push-body">{F.notif.body}</p>
                </div>
              </div>
            </div>
            <PhoneFrame class="ft-frame" />
          </div>
        </div>
      </div>

      {/* Basis-Blöcke = Accordion-Items. SERVER-HTML: alle Bodies offen, jedes
          Phone sichtbar. Phones werden NUR per JS-Klasse (.is-enhanced) versteckt.
          H3 trägt den Disclosure-Button (Nummer-Chip + Titel). */}
      <ol class="ft-blocks">
        {
          F.steps.map((s, i) => (
            <li class:list={['ft-block', i === 0 && 'is-open']} data-ft-block data-index={i}>
              <div class="ft-block-copy">
                <h3 class="ft-h3">
                  <button
                    type="button"
                    class="ft-acc-head"
                    data-ft-acc-head
                    id={`ft-head-${i}`}
                    aria-expanded="true"
                    aria-controls={`ft-body-${i}`}
                  >
                    <span class="ft-chip">{s.num}</span>
                    <span class="ft-h3-title">{s.h3}</span>
                  </button>
                </h3>

                <div
                  class="ft-acc-body"
                  id={`ft-body-${i}`}
                  role="region"
                  aria-labelledby={`ft-head-${i}`}
                  data-ft-acc-body
                >
                  <div class="ft-acc-body-inner">
                    <p class="ft-body">{s.body}</p>
                    <ul class="ft-checks">
                      {s.checks.map((c) => (
                        <li class="ft-check">
                          <span class="ft-check-ic" set:html={CHECK_SVG} />
                          <span>{c}</span>
                        </li>
                      ))}
                    </ul>
                    {/* Autoplay-Fortschritt (dekorativ). Server: versteckt; JS zeigt
                        ihn erst, wenn Autoplay aktiv wird. Füllung per transform:scaleX. */}
                    <div class="ft-progress" data-ft-progress aria-hidden="true">
                      <span class="ft-progress-fill" data-ft-progress-fill></span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ft-block-phone" data-ft-base-phone>
                <div class="ft-phone-stage ft-phone-stage--inline">
                  <div class="ft-glow" aria-hidden="true" />
                  <div class="ft-phone">
                    <div class="ft-shot is-active">
                      <Image src={shots[i]} alt={s.alt} class="ft-shot-img" loading="lazy" />
                    </div>
                    <PhoneFrame class="ft-frame" />
                  </div>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    {/* ================= TIER 2 — Bento ================= */}
    <div class="ft-bento-wrap">
      <h3 class="ft-bento-title">
        <span class="ft-mask"
          ><span class="ft-mask-in"
            >{bento.pre}<span class="marker"
              ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
                >{bento.mark}</span
              ></span
            >{bento.post}</span
          ></span
        >
      </h3>

      <div class="ft-bento">
        {/* Filter (span 8) */}
        <article class="ft-tile ft-tile--filter">
          <h4 class="ft-tile-h4">{F.filter.h4}</h4>
          <p class="ft-tile-body">{F.filter.body}</p>
          <ul class="ft-chips">
            {F.filter.chips.map((c) => <li class="ft-pill">{c}</li>)}
          </ul>
        </article>

        {/* Light & Dark Mode (span 4) — Easter-Egg B: Lichtschalter-Kette */}
        <article class="ft-tile ft-tile--dark" data-ft-darktile>
          <button
            type="button"
            class="ft-chain"
            data-ft-chain
            aria-pressed="false"
            aria-label={F.darkmode.ariaChain}
          >
            {/* Perlen-/Kugelkette: 9 Kügelchen + länglicher Griff. fill=currentColor
                → Farbe steuert der Zustand (#3b3b3a hell, #fff03c dunkel). */}
            <svg class="ft-chain-svg" viewBox="0 0 10 70" fill="currentColor" aria-hidden="true">
              <circle cx="5" cy="4" r="2.5" />
              <circle cx="5" cy="10" r="2.5" />
              <circle cx="5" cy="16" r="2.5" />
              <circle cx="5" cy="22" r="2.5" />
              <circle cx="5" cy="28" r="2.5" />
              <circle cx="5" cy="34" r="2.5" />
              <circle cx="5" cy="40" r="2.5" />
              <circle cx="5" cy="46" r="2.5" />
              <circle cx="5" cy="52" r="2.5" />
              <rect x="1" y="55" width="8" height="14" rx="4" />
            </svg>
          </button>
          <span class="ft-tile-icon" data-ft-dark-icon aria-hidden="true">
            {/* Beide Icons liegen in derselben Grid-Zelle (1/1) übereinander und
                crossfaden choreografiert (rotate/scale/opacity). Zustand steuert
                die Klasse .is-dark. Default (No-JS): Sonne sichtbar, Mond versteckt
                — über Zustandsklassen, NICHT display:none. */}
            <svg class="ft-ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.2M12 19.3v2.2M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"/></svg>
            <svg class="ft-ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"/></svg>
          </span>
          <h4 class="ft-tile-h4">{F.darkmode.h4}</h4>
          <p class="ft-tile-body">{F.darkmode.body}</p>
        </article>

        {/* Telegram (span 4) */}
        <article class="ft-tile ft-tile--tg">
          <span class="ft-tile-icon" aria-hidden="true">
            {/* Monochromer Papierflieger (CD-Schwarz, KEIN Markenlogo/keine Fremdfarbe) */}
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.7 3.3a1 1 0 0 0-1.05-.16L2.9 10.6c-.86.36-.8 1.6.09 1.87l4.5 1.38 1.7 5.2c.26.79 1.28.98 1.8.33l2.4-2.94 4.42 3.25c.6.44 1.46.12 1.62-.6l3.02-14.8a1 1 0 0 0-.4-1.02ZM9.53 13.9l8.2-6.03-6.86 7.36a1 1 0 0 0-.26.52l-.36 1.9-.72-3.75Z"/></svg>
          </span>
          <h4 class="ft-tile-h4">{F.telegram.h4}</h4>
          <p class="ft-tile-body">{F.telegram.body}</p>
        </article>

        {/* Listenansichten (span 4) — Reihe aus DREI Icon-Chips (S/M/L). Desktop-
            Hover baut M (0ms) und L (+130ms) gestaffelt auf; Touch/reduced-motion:
            alle drei dauerhaft sichtbar. Platz immer reserviert (kein Layout-Shift). */}
        <article class="ft-tile ft-tile--views">
          <div class="ft-views-row" aria-hidden="true">
            {/* S = 4 dünne Zeilen */}
            <span class="ft-view-chip ft-view-chip--s">
              <span class="ft-glyph ft-glyph--s">
                <span class="ft-lrow"></span><span class="ft-lrow"></span>
                <span class="ft-lrow"></span><span class="ft-lrow"></span>
              </span>
            </span>
            {/* M = 2 Zeilen mit kleinem Thumbnail-Quadrat */}
            <span class="ft-view-chip ft-view-chip--m">
              <span class="ft-glyph ft-glyph--m">
                <span class="ft-lline"><span class="ft-lthumb"></span><span class="ft-ltext"></span></span>
                <span class="ft-lline"><span class="ft-lthumb"></span><span class="ft-ltext"></span></span>
              </span>
            </span>
            {/* L = großer Bildblock + 1 Zeile */}
            <span class="ft-view-chip ft-view-chip--l">
              <span class="ft-glyph ft-glyph--l">
                <span class="ft-lbig"></span><span class="ft-lrow ft-lrow--wide"></span>
              </span>
            </span>
          </div>
          <h4 class="ft-tile-h4">{F.listviews.h4Label} S / M / L</h4>
          <p class="ft-tile-body">{F.listviews.body}</p>
        </article>

        {/* Deutsch & Englisch (span 4) — Sprach-Globus als Lottie (Hover). */}
        <article class="ft-tile ft-tile--lang">
          <span class="ft-tile-icon" aria-hidden="true">
            {/* Innerer 24px-Glyph-Container = Lottie-Mount. Lottie füllt seinen
                Container (nicht den 40er-Chip) → sichtbare Kugel ≈ 20px (die JSON
                zeichnet die Kugel auf ~83 % ihrer 500er-Canvas: 24 × 0.833 ≈ 20). */}
            <span class="ft-lang-glyph" data-ft-lang-lottie data-lottie-src={globeUrl}>
              {/* Fallback-SVG: No-JS / reduced-motion / Lottie-Fehler = statischer
                  Globus (Frame 0). JS ersetzt es durch die Lottie-Instanz. */}
              <span class="ft-ic-fallback" set:html={GLOBE_SVG} />
            </span>
          </span>
          <h4 class="ft-tile-h4">{F.language.h4}</h4>
          <p class="ft-tile-body">{F.language.body}</p>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  /* =====================================================================
     Basis & Layout — heller CD-Grund, zentrale Rhythmus-/Inset-Tokens.
     ===================================================================== */
  .ft-section {
    position: relative;
    background-color: var(--color-grey);
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
    /* overflow: clip klippt Glow-/Reveal-Überstände, ohne einen Scroll-Container
       zu erzeugen (im Gegensatz zu hidden). */
    overflow: clip;
  }
  .ft-inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  /* ---- Header ---- */
  .ft-head {
    text-align: center;
    margin-bottom: clamp(2.75rem, 6vw, 4.5rem);
  }
  .ft-eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* barrierefreies Text-Grau (Kontrast auf #eaebeb); Hierarchie unverändert */
    color: var(--color-grey-text);
  }
  .ft-h2 {
    font-weight: 900;
    font-size: clamp(2.1rem, 5.4vw, 3.75rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--color-black);
  }
  /* Mask-Reveal-Wrapper: klippt NUR die einfahrende Zeile (JS). Ruhezustand voll
     sichtbar (kein CSS-Vorverstecken). padding/margin schützen Ober-/Unterlängen. */
  .ft-mask {
    display: inline-block;
    overflow: hidden;
    padding-block: 0.12em;
    margin-block: -0.12em;
    padding-inline: 0.14em;
    margin-inline: -0.14em;
    vertical-align: top;
  }
  .ft-mask-in {
    display: inline-block;
    will-change: transform;
  }
  /* Keyword-Marker (H2 + Bento): globale .marker-Klassen (siehe global.css).
     Wipe fährt .marker__bg per gsap.from() herein (scaleX 0→1, skewX:-8 mitgeführt). */
  .ft-sub {
    margin-top: clamp(1rem, 2vw, 1.4rem);
    margin-inline: auto;
    max-width: 55ch;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.5;
    color: rgb(59 59 58 / 0.78);
    text-wrap: balance;
  }

  /* =====================================================================
     TIER 1 — Basis-Stapel (gilt IMMER). Blöcke untereinander, je mit Phone,
     alle Bodies offen. Der Disclosure-Button rendert hier als zentrierte
     Chip-über-Titel-Einheit (wie zuvor).
     ===================================================================== */
  .ft-blocks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(3.5rem, 8vw, 5.5rem);
  }
  .ft-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .ft-block-copy {
    max-width: 34rem;
  }

  /* Disclosure-Kopf. Basis: Chip über Titel (Flex-Spalte, zentriert), Button
     optisch neutral (kein eigener Rahmen/BG). */
  .ft-acc-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: center;
    cursor: default;
  }
  .ft-acc-head:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .ft-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.6rem;
    height: 2.1rem;
    padding: 0 0.7rem;
    border-radius: 0.6rem;
    background-color: var(--color-yellow);
    color: var(--color-black);
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    flex: none;
  }
  .ft-h3 {
    margin: 0;
    font-weight: 900;
    font-size: clamp(1.5rem, 3.4vw, 2.1rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-black);
  }
  .ft-h3-title {
    display: inline-block;
  }
  .ft-body {
    margin-top: 0.85rem;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.5;
    color: rgb(59 59 58 / 0.78);
  }
  .ft-checks {
    list-style: none;
    margin: 1.4rem 0 0;
    padding: 0;
    display: inline-flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
  }
  .ft-check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    font-weight: 500;
    color: var(--color-black);
  }
  .ft-check-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    flex: none;
    border-radius: 999px;
    background-color: var(--color-yellow);
    color: var(--color-black);
  }
  .ft-check-ic :global(svg) {
    width: 0.85rem;
    height: 0.85rem;
    display: block;
  }

  /* Fortschrittsbalken: im Basis-Stapel nie sichtbar (nur Autoplay-Enhancement). */
  .ft-progress {
    display: none;
    width: 100%;
    height: 3px;
    margin-top: 1.4rem;
    border-radius: 999px;
    overflow: hidden;
    background-color: var(--color-darkgrey);
  }
  .ft-progress-fill {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background-color: var(--color-yellow);
    transform: scaleX(0);
    transform-origin: left center;
  }

  /* ---- Phone-Bühne (Basis-Block-Phone + gemeinsames Phone teilen dieselbe Optik) ---- */
  .ft-phone-stage {
    position: relative;
    width: clamp(240px, 30vw, 320px);
  }
  .ft-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 210%;
    height: 150%;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, #fff03c, rgba(255, 240, 60, 0) 74%);
    filter: blur(70px);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  .ft-phone {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .ft-frame {
    position: relative;
    z-index: 10;
    display: block;
    width: 100%;
    height: auto;
  }
  /* Screenshots absolut übereinander (Crossfade). Geometrie = exakt Hero/Portale.
     Gilt für die BASIS-Block-Phones (jeweils ein statischer Screen). */
  .ft-shot {
    position: absolute;
    left: 2.4%;
    top: 0.6%;
    width: 95.4%;
    height: 98.9%;
    border-radius: 11.5% / 5.3%;
    overflow: hidden;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .ft-shot.is-active {
    opacity: 1;
  }

  /* ---- Shared-Phone: Screen-Maske + Slide-Transition (Desktop-Enhancement) ---- */
  .ft-screen {
    position: absolute;
    left: 2.4%;
    top: 0.6%;
    width: 95.4%;
    height: 98.9%;
    border-radius: 11.5% / 5.3%;
    overflow: hidden;
    z-index: 0;
  }
  /* Screens füllen die Maske; Position/Opacity steuert GSAP (Slide). KEINE
     CSS-Transition (GSAP setzt inline). Ohne JS ist das Shared-Phone ohnehin
