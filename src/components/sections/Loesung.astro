---
/**
 * Lösung (Bridge) — IB dreht den Spieß um: überwacht 24/7 alle Portale, pingt zuerst.
 * [Platzhalter.]
 */
import Section from '../Section.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

const t = useTranslations(getLangFromUrl(Astro.url));
---

<Section id="loesung" title={t.sections.solution.title}>
  <p class="text-body opacity-80">
    [Platzhalter] Immobilien Bot überwacht rund um die Uhr alle Portale und
    benachrichtigt dich als Erste:n.
  </p>
</Section>
