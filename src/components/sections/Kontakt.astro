---
/**
 * Kontakt (#kontakt) — dunkle Sektion (#3b3b3a), geht nahtlos in den dunklen Footer
 * über. Rollentausch-Idee: die ganze Seite über pusht der Bot dem Nutzer Angebote —
 * hier schickt der Nutzer uns eine Nachricht, gerahmt als „Push-Karte" (gleiche
 * visuelle Sprache wie Hero/Portale).
 *
 * Guardrails (CLAUDE.md): Genau EINE H1 bleibt im Hero → hier H2. OHNE JS voll
 * nutzbar (natives <form method=POST action=/api/contact> → Function antwortet mit
 * 303 auf die Danke-Seite). Alle Texte aus i18n, alle Fakten (E-Mail/Telegram/
 * Instagram) aus site.ts (contact). Reveal nur transform/opacity, reduced-motion
 * sofort im Endzustand. Cursor: Lupe über Interaktiven, Text-Caret über Feldern,
 * Ring auf Dunkel sichtbar (data-cursor-dark → html.cursor-invert).
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { contact } from '../../data/site';
import PillButton from '../ui/PillButton.astro';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const C = t.sections.contact;
// Rechtsseiten sind DE-only (kein /en-Pendant) → immer die DE-Route verlinken.
const privacyHref = '/datenschutz';

// Keyword-Marker im Headline-Text (Marker = Gelb-Fläche, Text #3b3b3a → auf Dunkel ok).
function markParts(text: string, mark: string) {
  const i = text.indexOf(mark);
  if (i < 0) return { pre: text, mark: '', post: '' };
  return { pre: text.slice(0, i), mark, post: text.slice(i + mark.length) };
}
const h = markParts(C.headline, C.headlineMark);

// DSGVO-Zeile: {link} → Anchor auf die Datenschutz-Route (Rest bleibt Text).
const privIdx = C.form.privacy.indexOf('{link}');
const privPre = privIdx >= 0 ? C.form.privacy.slice(0, privIdx) : C.form.privacy;
const privPost = privIdx >= 0 ? C.form.privacy.slice(privIdx + '{link}'.length) : '';

// Themen-Chips (Reihenfolge = Bedeutung; erster ist default checked).
const topicKeys = ['app', 'feedback', 'problem', 'presse', 'sonstiges'] as const;

// Icons 20×20, gelb, einheitliche Strichstärke (wie übrige Line-Icons der Seite).
const IC_MAIL = `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff03c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 6 8-6"/></svg>`;
const IC_TELEGRAM = `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff03c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 4.5 2.8 11.4c-.6.2-.6 1.1 0 1.3l4.7 1.5 1.8 5.4c.2.5.8.6 1.2.2l2.6-2.5 4.6 3.4c.4.3 1 .1 1.1-.4L21.9 5.2c.1-.6-.4-1-.9-.7Z"/><path d="m7.5 14.2 9-6.4-6.5 7.1"/></svg>`;
const IC_INSTAGRAM = `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff03c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="#fff03c" stroke="none"/></svg>`;
---

<section id="kontakt" aria-labelledby="kontakt-heading" class="kt-section" data-cursor-dark>
  <div class="kt-inner">
    <div class="kt-grid">
      {/* ================= LINKS: Text + Kanäle ================= */}
      <div class="kt-left">
        <p class="kt-kicker" data-k-reveal>{C.kicker}</p>

        <h2 id="kontakt-heading" class="kt-h2" data-k-reveal>
          {h.pre}<span class="marker"
            ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
              >{h.mark}</span
            ></span
          >{h.post}
        </h2>

        <p class="kt-copy" data-k-reveal>{C.copy}</p>

        <ul class="kt-channels" data-k-reveal>
          <li class="kt-channel">
            <span class="kt-ch-ic" aria-hidden="true" set:html={IC_MAIL} />
            <a class="kt-ch-link" href={`mailto:${contact.email}`}>
              <span class="kt-ch-label">{C.channels.email}</span>
              <span class="kt-ch-sub">{contact.email}</span>
            </a>
          </li>
          <li class="kt-channel">
            <span class="kt-ch-ic" aria-hidden="true" set:html={IC_TELEGRAM} />
            <a
              class="kt-ch-link"
              href={contact.telegramSupport}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="kt-ch-label">{C.channels.telegram}</span>
              <span class="kt-ch-sub">{C.channels.telegramSub}</span>
            </a>
          </li>
          <li class="kt-channel">
            <span class="kt-ch-ic" aria-hidden="true" set:html={IC_INSTAGRAM} />
            <a
              class="kt-ch-link"
              href={contact.instagram}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="kt-ch-label">{C.channels.instagram}</span>
              <span class="kt-ch-sub">{C.channels.instagramSub}</span>
            </a>
          </li>
        </ul>
      </div>

      {/* ================= RECHTS: Push-Karte mit Formular ================= */}
      <div
        class="kt-card"
        data-k-card
        data-k-root
        data-contact-email={contact.email}
        data-error={C.error.replace('{email}', contact.email)}
      >
        {/* Kartenkopf (Push-Sprache) */}
        <div class="kt-card-head">
          <Image src={appIcon} alt={C.card.iconAlt} width={96} height={96} class="kt-card-icon" />
          <div class="kt-card-id">
            <span class="kt-card-app">{C.card.app}</span>
            <span class="kt-card-sub">{C.card.sub}</span>
          </div>
        </div>

        {/* ---- Formularbereich (No-JS: natives POST → Function → 303 Danke) ---- */}
        <div class="kt-formwrap" data-k-formwrap>
          <form class="kt-form" method="POST" action="/api/contact" data-k-form>
            <input type="hidden" name="lang" value={lang} />
            {/* Honeypot — visuell versteckt, aus dem A11y-Baum genommen. */}
            <input
              type="text"
              name="website"
              class="kt-hp"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            {/* Themen-Chips */}
            <fieldset class="kt-fieldset">
              <legend class="kt-legend">{C.form.topicLegend}</legend>
              <div class="kt-chips">
                {
                  topicKeys.map((key, i) => (
                    <label class="kt-chip">
                      <input
                        class="kt-chip-input"
                        type="radio"
                        name="topic"
                        value={key}
                        checked={i === 0}
                      />
                      <span class="kt-chip-label">{C.form.topics[key]}</span>
                    </label>
                  ))
                }
              </div>
            </fieldset>

            {/* Name + E-Mail */}
            <div class="kt-row2">
              <div class="kt-field">
                <label class="kt-label" for="kt-name">{C.form.name}</label>
                <input
                  class="kt-input"
                  id="kt-name"
                  name="name"
                  type="text"
                  required
                  maxlength="100"
                  autocomplete="name"
                  placeholder={C.form.namePlaceholder}
                />
              </div>
              <div class="kt-field">
                <label class="kt-label" for="kt-email">{C.form.email}</label>
                <input
                  class="kt-input"
                  id="kt-email"
                  name="email"
                  type="email"
                  required
                  maxlength="200"
                  autocomplete="email"
                  placeholder={C.form.emailPlaceholder}
                />
              </div>
            </div>

            {/* Nachricht */}
            <div class="kt-field">
              <label class="kt-label" for="kt-message">{C.form.message}</label>
              <textarea
                class="kt-input kt-textarea"
                id="kt-message"
                name="message"
                required
                maxlength="3000"
                rows="5"
                placeholder={C.form.messagePlaceholder}></textarea>
            </div>

            <PillButton
              type="submit"
              surface="invert"
              size="md"
              block
              class="kt-submit"
              data-k-submit
              data-sending={C.form.sending}
            >
              {C.form.submit}
            </PillButton>

            {/* Fehler-/Statusbereich (JS) */}
            <div class="kt-status" role="status" aria-live="polite" data-k-status></div>

            <p class="kt-privacy">
              {privPre}<a class="kt-privacy-link" href={privacyHref}>{C.form.privacyLink}</a>{privPost}
            </p>
          </form>
        </div>

        {/* ---- Success-State (Zustands-UI, initial versteckt) ---- */}
        <div class="kt-success is-hidden" data-k-success hidden>
          <span class="kt-success-badge" aria-hidden="true">
            <Image src={appIcon} alt="" width={96} height={96} class="kt-success-icon" />
          </span>
          <p class="kt-success-title">{C.success.title}</p>
          <p class="kt-success-copy">{C.success.copy}</p>
          <button type="button" class="kt-again" data-k-again>{C.success.again}</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ---- Kontakt-Island: Progressive Enhancement des Formulars ----
    // Ohne JS: natives POST → Function → 303 auf die Danke-Seite. Mit JS: fetch mit
    // Accept: application/json, Pending-/Success-/Error-States. Fehler behält alle
    // Eingaben. Nur diese Sektion; crasht nie an fehlendem GTM.
    const root = document.querySelector<HTMLElement>('[data-k-root]');
    const form = root?.querySelector<HTMLFormElement>('[data-k-form]');
    if (root && form) {
      const formwrap = root.querySelector<HTMLElement>('[data-k-formwrap]');
      const success = root.querySelector<HTMLElement>('[data-k-success]');
      const status = root.querySelector<HTMLElement>('[data-k-status]');
      const submit = root.querySelector<HTMLButtonElement>('[data-k-submit]');
      const again = root.querySelector<HTMLButtonElement>('[data-k-again]');
      const submitLabel = submit?.querySelector<HTMLElement>('.pill-btn__label');
      const t = {
        sending: submit?.getAttribute('data-sending') || 'Sending…',
        submit: submitLabel?.textContent?.trim() || 'Send',
        error: root.getAttribute('data-error') || '',
        email: root.getAttribute('data-contact-email') || '',
      };

      const setStatus = (msg: string) => {
        if (!status) return;
        status.textContent = '';
        if (!msg) return;
        // Fehlertext mit mailto-Link auf die Kontaktadresse.
        const i = t.email && msg.includes(t.email) ? msg.indexOf(t.email) : -1;
        if (i >= 0) {
          status.append(document.createTextNode(msg.slice(0, i)));
          const a = document.createElement('a');
          a.href = `mailto:${t.email}`;
          a.textContent = t.email;
          a.className = 'kt-status-link';
          status.append(a, document.createTextNode(msg.slice(i + t.email.length)));
        } else {
          status.textContent = msg;
        }
      };

      const setSending = (on: boolean) => {
        if (!submit) return;
        submit.disabled = on;
        if (submitLabel) submitLabel.childNodes[0] &&
          (submitLabel.childNodes[0].textContent = on ? t.sending : t.submit);
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        setStatus('');
        setSending(true);
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          let ok = res.ok;
          try {
            const data = await res.clone().json();
            ok = !!data.ok;
          } catch {
            /* kein JSON → Status entscheidet */
          }
          if (ok) {
            formwrap?.setAttribute('hidden', '');
            formwrap?.classList.add('is-hidden');
            success?.removeAttribute('hidden');
            success?.classList.remove('is-hidden');
            try {
              (window as unknown as { dataLayer?: unknown[] }).dataLayer?.push({ event: 'contact_submit' });
            } catch {
              /* GTM optional */
            }
          } else {
            setSending(false);
            setStatus(t.error);
          }
        } catch {
          setSending(false);
          setStatus(t.error);
        }
      });

      // „Weitere Nachricht schreiben": Formular zurücksetzen + wieder einblenden.
      again?.addEventListener('click', () => {
        form.reset();
        setStatus('');
        setSending(false);
        success?.setAttribute('hidden', '');
        success?.classList.add('is-hidden');
        formwrap?.removeAttribute('hidden');
        formwrap?.classList.remove('is-hidden');
        form.querySelector<HTMLElement>('input[name="name"]')?.focus();
      });
    }
  </script>
</section>

<style>
  /* =====================================================================
     Basis — dunkle Sektion, geht in den Footer über (kein sichtbarer Bruch).
     Standard-Rhythmus + Content-Einschub.
     ===================================================================== */
  .kt-section {
    position: relative;
    background-color: var(--color-black);
    color: var(--color-offwhite);
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
  }
  .kt-inner {
    max-width: 72rem;
    margin-inline: auto;
  }
  .kt-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .kt-grid {
      grid-template-columns: minmax(0, 440px) minmax(0, 560px);
      gap: 64px;
      justify-content: space-between;
    }
  }

  /* =====================================================================
     Links — Text + Kanäle.
     ===================================================================== */
  .kt-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .kt-kicker {
    margin: 0 0 14px;
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-yellow);
  }
  .kt-h2 {
    margin: 0;
    font-weight: 900;
    font-size: clamp(2.1rem, 5.4vw, 3.75rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--color-offwhite);
  }
  .kt-copy {
    margin: 20px 0 0;
    max-width: 440px;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.55;
    color: var(--color-darkgrey);
  }
  .kt-channels {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    width: 100%;
    max-width: 440px;
  }
  .kt-channel {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-block: 10px;
    border-top: 1px solid rgb(246 246 246 / 0.12);
  }
  .kt-ch-ic {
    flex: none;
    display: inline-flex;
  }
  .kt-ch-ic :global(svg) {
    display: block;
  }
  .kt-ch-link {
    display: flex;
    flex-direction: column;
    gap: 1px;
    text-decoration: none;
  }
  .kt-ch-label {
    font-weight: 700;
    font-size: 14px;
    color: var(--color-offwhite);
  }
  .kt-ch-sub {
    font-size: 12.5px;
    color: var(--color-grey-yellow);
  }
  @media (hover: hover) and (pointer: fine) {
    .kt-ch-link:hover .kt-ch-label {
      color: var(--color-yellow);
    }
  }
  .kt-ch-link:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* =====================================================================
     Rechts — Push-Karte (hell auf Dunkel, weiche große Elevation).
     ===================================================================== */
  .kt-card {
    width: 100%;
    max-width: 560px;
    background: var(--color-offwhite);
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 24px 60px rgb(0 0 0 / 0.35);
  }
  @media (max-width: 1023.98px) {
    .kt-card {
      padding: 22px;
    }
  }

  /* ---- Kartenkopf ---- */
  .kt-card-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-darkgrey);
    margin-bottom: 16px;
  }
  .kt-card-icon {
    flex: none;
    width: 36px;
    height: 36px;
    border-radius: 9px;
  }
  .kt-card-id {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-right: auto;
  }
  .kt-card-app {
    font-weight: 900;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-black);
  }
  .kt-card-sub {
    font-size: 12px;
    color: #8a8a88;
  }

  /* =====================================================================
     Formular.
     ===================================================================== */
  .kt-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .kt-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* ---- Themen-Chips ---- */
  .kt-fieldset {
    border: 0;
    margin: 0;
    padding: 0;
    min-inline-size: 0;
  }
  .kt-legend {
    padding: 0;
    margin-bottom: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6f6f6d;
  }
  .kt-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .kt-chip {
    display: inline-flex;
  }
  /* Radio visuell versteckt (natives Verhalten bleibt) */
  .kt-chip-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .kt-chip-label {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 7px 13px;
    border: 1.5px solid rgb(59 59 58 / 0.28);
    border-radius: 999px;
    font-weight: 700;
    font-size: 13px;
    color: var(--color-black);
    cursor: pointer;
    transition:
      background-color 0.18s ease,
      border-color 0.18s ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .kt-chip-label:hover {
      border-color: var(--color-black);
    }
  }
  .kt-chip-input:checked + .kt-chip-label {
    background: var(--color-yellow);
    border-color: var(--color-yellow);
  }
  .kt-chip-input:focus-visible + .kt-chip-label {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
  }

  /* ---- Felder ---- */
  .kt-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 639.98px) {
    .kt-row2 {
      grid-template-columns: 1fr;
    }
  }
  .kt-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kt-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6f6f6d;
  }
  .kt-input {
    width: 100%;
    background: var(--color-grey);
    border: 2px solid transparent;
    border-radius: 12px;
    padding: 12px 14px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-black);
    transition:
      border-color 0.18s ease,
      background-color 0.18s ease;
  }
  .kt-input::placeholder {
    color: #9a9a98;
  }
  .kt-input:focus-visible {
    outline: none;
    border-color: var(--color-yellow);
    background: #fff;
  }
  .kt-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
  }

  /* ---- Submit + DSGVO + Status ---- */
  .kt-submit {
    margin-top: 4px;
  }
  .kt-status {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: #b4342e;
  }
  .kt-status:empty {
    display: none;
  }
  .kt-status-link {
    color: inherit;
    font-weight: 700;
  }
  .kt-privacy {
    margin: 0;
    font-size: 12px;
    line-height: 1.5;
    color: #8a8a88;
  }
  .kt-privacy-link {
    color: #6f6f6d;
    font-weight: 700;
    text-underline-offset: 2px;
  }

  /* =====================================================================
     Success-State (Zustands-UI). Initial versteckt (kein Inhalt).
     ===================================================================== */
  .is-hidden {
    display: none !important;
  }
  .kt-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    padding-block: 16px 8px;
  }
  .kt-success-badge {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 999px;
    background: var(--color-yellow);
    margin-bottom: 4px;
  }
  .kt-success-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
  }
  .kt-success-title {
    margin: 0;
    font-weight: 900;
    font-size: 20px;
    color: var(--color-black);
  }
  .kt-success-copy {
    margin: 0;
    max-width: 34ch;
    font-size: 14px;
    line-height: 1.5;
    color: #6f6f6d;
  }
  .kt-again {
    margin-top: 4px;
    border: 0;
    background: none;
    padding: 6px 4px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 14px;
    color: var(--color-black);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
  .kt-again:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* =====================================================================
     prefers-reduced-motion — keine Feld-/Chip-Transitions (Fokus bleibt hart).
     ===================================================================== */
  @media (prefers-reduced-motion: reduce) {
    .kt-input,
    .kt-chip-label {
      transition: none;
    }
  }
</style>
