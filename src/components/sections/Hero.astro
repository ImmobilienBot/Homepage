---
/**
 * Hero — Awwwards Visual Language (siehe CLAUDE.md → Motion-System), Layout A:
 * kinetische Headline links, aufgefächerter 3-Phone-Cluster rechts.
 *
 * OBERSTES GEBOT: Inhalte sind IMMER sichtbar, auch ohne JS/GSAP.
 * - Headline steht per Default vollständig da (KEIN CSS-Vorverstecken); der
 *   Reveal ist rein additiv via gsap.from() in animations.ts.
 * - Phone-Cluster: Front-Phone (Angebotsliste) vorne, zwei kleinere Phones
 *   dahinter aufgefächert (Karte links, Suche rechts). Die Fächer-Ruhelage
 *   liegt in CSS → ohne JS sofort korrekt; JS fährt sie nur additiv heraus.
 * - Notifications: echter vertikaler Stapel oben am Front-Phone, ploppen
 *   nacheinander rein, halten, faden gemeinsam weg — Endlosschleife (JS).
 * - Hintergrund: cleanes Grau. Gelb kommt NUR von den schwebenden Punkten
 *   (Desktop-only, weichen dem Cursor aus — in animations.ts).
 *
 * Alles prefers-reduced-motion-fest (JS-Guard) und Performance-Budget
 * (nur transform/opacity). Store-Links aus site.ts, Texte aus i18n.
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import type { Locale } from '../../data/site';
import StoreBadges from '../StoreBadges.astro';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenList from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import screenMap from '../../assets/images/immobilien-bot-suchbereich-karte-zeichnen.png';
import screenConfig from '../../assets/images/immobilien-bot-suche-konfigurieren.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { headlineLines, markKeyword, notification } = t.hero;

// Höchstens 4 Karten im Stapel (i18n liefert mehr Meldungen als gezeigt werden).
const notifItems = notification.items.slice(0, 4);

// Zeile in Segmente zerlegen; das Keyword bekommt den animierten Marker.
function splitLine(line: string) {
  const idx = line.indexOf(markKeyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: markKeyword, mark: true },
    { text: line.slice(idx + markKeyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
---

<section id="hero" class="relative overflow-hidden px-inset py-section">
  {/* Canvas-Partikelfeld (Desktop-only, per JS): dichte gelbe Welle + Cursor-Repel.
      Hinter Inhalten/Phones, über dem grauen Hintergrund. Mobile/reduced-motion: leer. */}
  <canvas class="hero-canvas" data-hero-canvas aria-hidden="true"></canvas>

  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
    {/* ---- Links: kinetische Headline + CTAs ---- */}
    <div class="order-2 md:order-1">
      <h1 class="hero-headline font-black">
        {
          headlineLines.map((line) => (
            <span class="line-mask">
              <span class="line-inner">
                {splitLine(line).map((seg) =>
                  seg.mark ? (
                    <span class="mark-word">
                      <span class="mark-hl" aria-hidden="true" />
                      <span class="mark-text">{seg.text}</span>
                    </span>
                  ) : (
                    <span>{seg.text}</span>
                  ),
                )}
              </span>
            </span>
          ))
        }
      </h1>

      <p class="hero-sub mt-6" data-hero-sub>{t.hero.subline}</p>

      <div class="mt-8" data-hero-cta>
        <StoreBadges position="hero" lang={lang} />
      </div>

      {/* Trust-Reihe: Stern + Rating + Label · Trenner · Downloads (klein, gedämpft) */}
      <div class="trust-row mt-6" data-hero-trust>
        <span class="trust-star" aria-hidden="true">★</span>
        <span class="trust-rating">{t.hero.trust.rating}</span>
        <span class="trust-label">{t.hero.trust.ratingLabel}</span>
        <span class="trust-sep" aria-hidden="true"></span>
        <span class="trust-downloads">{t.hero.trust.downloads}</span>
      </div>
    </div>

    {/* ---- Rechts: aufgefächerter Phone-Cluster (3 Phones) ---- */}
    <div class="order-1 flex justify-center md:order-2">
      <div data-phone-stage class="phone-stage relative w-[clamp(230px,74vw,320px)]">
        {/* Sanftes gelbes Glühen hinter dem Cluster (statisch, warmer Fokus) */}
        <div class="phone-glow" aria-hidden="true"></div>

        {/* Scroll-Choreografie-Ebene (scale/translate beim Scrollen) — enthält alle 3 Phones */}
        <div data-phone-choreo class="phone-choreo relative w-full">
            {/* Hinteres Phone links: Karte / Suchbereich zeichnen */}
            <div class="phone phone--back phone--back-left" data-phone-back data-fan="left">
              <Image
                src={screenMap}
                alt={t.hero.mapAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Hinteres Phone rechts: Suche konfigurieren */}
            <div class="phone phone--back phone--back-right" data-phone-back data-fan="right">
              <Image
                src={screenConfig}
                alt={t.hero.configAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Front-Phone: Angebotsliste + Notification-Stapel */}
            <div class="phone phone--front" data-phone-front>
              <Image
                src={screenList}
                alt={t.hero.mockupAlt}
                class="phone-screen"
                loading="eager"
                fetchpriority="high"
              />
              <PhoneFrame class="phone-frame" />

              {/* Echter vertikaler Notification-Stapel (oben, überlagert die Liste) */}
              <div class="notif-stack" data-notif-stack aria-hidden="true">
                {
                  notifItems.map((item) => (
                    <div class="notif" data-notif>
                      <div class="notif-inner">
                        <div class="flex items-start gap-2.5">
                          <Image
                            src={appIcon}
                            alt=""
                            width={96}
                            height={96}
                            class="notif-icon"
                          />
                          <div class="min-w-0 flex-1">
                            <p class="notif-head">
                              <span class="truncate">{notification.app}</span>
                              <span class="notif-time">{notification.time}</span>
                            </p>
                            <p class="notif-body">{notification.lead} {item}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Kinetische Typografie (der Blickfang, links) ----
     Sichtbar per Default. Die Maske klippt nur die von unten einfahrende Zeile
     WÄHREND der Animation; im Ruhezustand (yPercent 0) ist die Zeile voll da.
     padding/margin-block schützen Ober-/Unterlängen vor dem overflow-Clip. */
  .hero-headline {
    font-size: var(--text-h1); /* eingepasste Display-Größe (max 4.5rem, fittet die Spalte) */
    line-height: 0.95; /* enge Zeilenhöhe */
    letter-spacing: -0.02em; /* enges Tracking */
  }
  .line-mask {
    display: block;
    /* overflow:hidden klippt NUR die vertikal einfahrende Zeile. Horizontales
       Breathing (padding/margin-inline) stellt sicher, dass Marker-Überstände
       und Glyphen NIE horizontal beschnitten werden. */
    overflow: hidden;
    padding-block: 0.12em;
    margin-block: -0.12em;
    padding-inline: 0.14em;
    margin-inline: -0.14em;
  }
  .line-inner {
    display: block;
    will-change: transform;
  }
  .mark-word {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .mark-hl {
    position: absolute;
    inset: 0.08em -0.06em 0.04em -0.06em;
    background-color: var(--color-yellow);
    border-radius: 0.08em;
    transform-origin: left center;
    z-index: 0;
    /* Default: voll sichtbar. gsap.from() wischt beim Reveal von scaleX(0) herein. */
  }
  .mark-text {
    position: relative;
    z-index: 1;
  }

  /* ---- Subline: bewusster Sekundär-Block (nicht Fließtext) ----
     Etwas größer, luftige Zeilenhöhe, engere max-Breite (sauberer 2–3-Zeiler),
     kräftiger Grauton — präsent, aber klar sekundär zur schwarzen Headline.
     Gilt DE + EN (Text aus i18n). */
  .hero-sub {
    font-size: clamp(1.25rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    max-width: 34rem;
    color: rgb(59 59 58 / 0.8);
  }

  /* ---- Trust-Reihe (klein, gedämpftes Grau, leicht letter-spaced) ---- */
  .trust-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem; /* ~13px */
    letter-spacing: 0.03em;
    /* WCAG AA: 0.78-Deckkraft ≈ #616160 auf #eaebeb ≈ 5,2:1 (vorher 0.55 ≈ 2,9:1). */
    color: rgb(59 59 58 / 0.78);
  }
  .trust-star {
    color: var(--color-black); /* dunkel — gelb ging auf hellem Grau unter */
    font-size: 1.05em;
    line-height: 1;
  }
  .trust-rating {
    font-weight: 700;
  }
  .trust-label {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 0.82em;
  }
  .trust-sep {
    width: 1px;
    height: 0.95em;
    background-color: currentColor;
    opacity: 0.45;
  }

  /* ---- Canvas-Partikelfeld (Hero-Hintergrund) ----
     Nur Desktop; per JS bespielt (animations.ts → initHeroCanvas). Ohne JS bleibt
     das Canvas leer (cleanes Grau). Hinter den Inhalten (z-0), über dem Grau. */
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ---- Phone-Cluster: Perspektive (Tilt) + gefächerte Ruhelage ---- */
  .phone-stage {
    perspective: 1200px;
  }

  /* Großes, kräftiges gelbes Glühen hinter dem GESAMTEN 3-Phone-Cluster (statisch).
     Ersetzt den harten Schlagschatten — warmer Fokus, hebt die Phones vom Netz ab.
     z-0 (hinter den Phones, über dem Canvas/Grau). Deutlich größer als der Cluster,
     damit es auch im Endzustand (alle 3 Phones) klar sichtbar bleibt. */
  .phone-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 210%;
    height: 140%;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, #fff03c, rgba(255, 240, 60, 0) 72%);
    filter: blur(70px);
    opacity: 0.55;
    z-index: 0;
    pointer-events: none;
  }
  /* Scroll-Choreografie-Ebene (scale/translate beim Scrollen) — umfasst alle 3 Phones. */
  .phone-choreo {
    will-change: transform;
  }

  /* Front-Phone definiert die Cluster-Größe (in-flow), hintere Phones liegen
     absolut deckungsgleich darüber und werden per transform aufgefächert. */
  .phone {
    position: relative;
    width: 100%;
  }
  .phone--back {
    position: absolute;
    inset: 0;
    z-index: 1;
    /* Unterkante als Skalier-Ankerpunkt → alle drei Phones stehen unten bündig. */
    transform-origin: bottom center;
    will-change: transform, opacity;
  }
  .phone--front {
    position: relative;
    z-index: 2;
    will-change: transform;
  }

  /* Ruhelage: hintere Phones AUFRECHT (Rotation 0), EXAKT spiegelgleich —
     identischer vertikaler Versatz (-7%), identische Skalierung (0.9), symmetrischer
     Peek ±38 %. transform-origin bottom → Unterkanten auf gleicher Höhe. Fallback
     ohne JS = sofort korrekt; Werte spiegeln FAN_REST in animations.ts. */
  .phone--back-left {
    transform: translate(-38%, -7%) scale(0.9);
  }
  .phone--back-right {
    transform: translate(38%, -7%) scale(0.9);
  }

  .phone-frame {
    position: relative;
    z-index: 10;
    display: block;
    height: auto;
    width: 100%;
  }

  /* Screenshot exakt in den transparenten Screen-Ausschnitt (Geometrie aus
     smartphone-rahmen.svg). Der dunkle Bezel (z-10) verdeckt die Ecken. */
  .phone-screen {
    position: absolute;
    left: 2.83%;
    top: 1.05%;
    width: 94.1%;
    height: 97.8%;
    object-fit: cover;
    object-position: top center;
    border-radius: 9%;
    z-index: 0;
    /* Kein harter Schlagschatten mehr — die Tiefe kommt jetzt vom gelben
       Glühen hinter dem Cluster (.phone-glow). */
  }

  /* ---- Notification-Stapel: oben am Front-Phone, überlagert die Liste ----
     Feste Slots im Fluss (flex column): Karten poppen per JS nacheinander in
     ihre Position, kein Reflow. Leichter Überhang über den Rahmenrand (Tiefe). */
  .notif-stack {
    position: absolute;
    top: 5%;
    left: -3%;
    right: -3%;
    z-index: 30;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .notif {
    /* GSAP steuert transform/opacity der Karte; Hover-Scale liegt auf .notif-inner
       (kein Konflikt). pointer-events aktiv, damit Hover greift. */
    pointer-events: auto;
    will-change: transform, opacity;
  }
  .notif-inner {
    border-radius: 1rem;
    background-color: color-mix(in srgb, var(--color-offwhite) 92%, transparent);
    border: 1px solid rgb(59 59 58 / 0.06);
    /* weiche, große Elevation mit niedriger Opacity */
    box-shadow: 0 18px 40px -16px rgb(59 59 58 / 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.6rem 0.7rem;
    color: var(--color-black);
    transform-origin: center;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  /* Hover: Karte hebt sich leicht an (nur transform — CD-Schutzplanke). */
  .notif:hover .notif-inner {
    transform: scale(1.07);
    box-shadow: 0 22px 48px -16px rgb(59 59 58 / 0.45);
  }
  /* Ohne JS / reduced-motion: nur die erste Notification statisch zeigen.
     Läuft JS, übernimmt die GSAP-Schleife (autoAlpha) alle Karten. */
  .notif {
    opacity: 0;
  }
  .notif:first-child {
    opacity: 1;
  }
  .notif-icon {
    height: 2.25rem;
    width: 2.25rem;
    flex-shrink: 0;
    border-radius: 24%;
  }
  .notif-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.1;
  }
  .notif-time {
    flex-shrink: 0;
    font-weight: 400;
    opacity: 0.5;
  }
  .notif-body {
    margin-top: 0.1rem;
    font-size: 12.5px;
    line-height: 1.3;
  }

  /* Mobile reduziert: engerer Cluster (spiegelgleich), kompakterer Stapel (3 Karten). */
  @media (max-width: 640px) {
    .phone--back-left {
      transform: translateX(-30%) scale(0.9);
    }
    .phone--back-right {
      transform: translateX(30%) scale(0.9);
    }
    .notif-stack {
      left: 0;
      right: 0;
    }
    .notif:nth-child(4) {
      display: none;
    }
  }
</style>
