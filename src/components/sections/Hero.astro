---
/**
 * Hero — Awwwards Visual Language (siehe CLAUDE.md → Motion-System).
 *
 * - Dramatische kinetische Headline: riesig, Roboto Black, enges Tracking/Leading,
 *   Mask-Reveal zeilenweise + animierter gelber Marker (scaleX-Wisch).
 * - Phone-Mockup mit weichem gelbem Glow dahinter + leichtem 3D-Tilt
 *   (reagiert dezent auf Maus/Scroll, nur Desktop).
 * - Endlosschleife mehrerer schwebender Push-Benachrichtigungen (elevated,
 *   über den Phone-Rand überlappend), Texte aus i18n.
 *
 * Alles mit prefers-reduced-motion-Fallback (Anfangszustände nur unter
 * `html.js` + no-preference versteckt) und Performance-Budget (nur
 * transform/opacity). Store-Links aus site.ts, Texte aus i18n.
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import type { Locale } from '../../data/site';
import StoreBadges from '../StoreBadges.astro';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenshot from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { headlineLines, markKeyword, notification } = t.hero;

// Zeile in Segmente zerlegen; das Keyword bekommt den animierten Marker.
function splitLine(line: string) {
  const idx = line.indexOf(markKeyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: markKeyword, mark: true },
    { text: line.slice(idx + markKeyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
---

<section id="hero" class="relative overflow-hidden px-inset py-section">
  <div class="mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
    {/* ---- Links: kinetische Headline + CTAs ---- */}
    <div class="order-2 md:order-1">
      <h1 class="hero-headline font-black">
        {
          headlineLines.map((line) => (
            <span class="line-mask">
              <span class="line-inner">
                {splitLine(line).map((seg) =>
                  seg.mark ? (
                    <span class="mark-word">
                      <span class="mark-hl" aria-hidden="true" />
                      <span class="mark-text">{seg.text}</span>
                    </span>
                  ) : (
                    <span>{seg.text}</span>
                  ),
                )}
              </span>
            </span>
          ))
        }
      </h1>

      <p class="mt-6 max-w-prose text-subhead" data-hero-sub>{t.hero.subline}</p>

      <div class="mt-8" data-hero-cta>
        <StoreBadges position="hero" lang={lang} />
      </div>

      <p class="mt-4 text-body opacity-70" data-hero-trust>{t.hero.trustMicroline}</p>
    </div>

    {/* ---- Rechts: Phone-Stage (Glow + Tilt + Notifications) ---- */}
    <div class="order-1 flex justify-center md:order-2">
      <div data-phone-stage class="phone-stage relative w-[clamp(230px,72vw,320px)]">
        {/* Weiches gelbes Glow (atmend) — eigener Wrapper für Scroll-Parallax */}
        <div class="glow-wrap" data-glow-wrap aria-hidden="true">
          <div class="phone-glow" data-phone-glow></div>
        </div>

        {/* Scroll-Choreografie-Ebene (rotate/scale/translate beim Scrollen) */}
        <div data-phone-choreo class="phone-choreo relative w-full">
          {/* Tilt-Ebene: Screenshot hinter dem Rahmen (Maus-Tilt) */}
          <div data-phone class="phone relative w-full">
            <Image
              src={screenshot}
              alt={t.hero.mockupAlt}
              class="phone-screen"
              loading="eager"
              fetchpriority="high"
            />
            <PhoneFrame class="relative z-10 block h-auto w-full" />
          </div>
        </div>

        {/* Endlosschleife schwebender Push-Benachrichtigungen (kein Bild) */}
        <div class="notif-stack" data-notif-stack aria-hidden="true">
          {
            notification.items.map((item) => (
              <div class="notif" data-notif>
                <div class="flex items-start gap-3">
                  <Image
                    src={appIcon}
                    alt=""
                    width={96}
                    height={96}
                    class="notif-icon"
                  />
                  <div class="min-w-0">
                    <p class="notif-head">
                      <span class="truncate">{notification.app}</span>
                      <span class="notif-time">{notification.time}</span>
                    </p>
                    <p class="notif-body">{notification.lead} {item}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Kinetische Typografie ---- */
  .hero-headline {
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.92; /* enge Zeilenhöhe */
    letter-spacing: -0.02em; /* enges Tracking */
    text-wrap: balance;
  }
  .line-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.03em; /* schützt Ober-/Unterlängen vor dem Clip */
  }
  .line-inner {
    display: block;
    will-change: transform;
  }
  .mark-word {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .mark-hl {
    position: absolute;
    inset: 0.08em -0.06em 0.04em -0.06em;
    background-color: var(--color-yellow);
    border-radius: 0.08em;
    transform-origin: left center;
    z-index: 0;
  }
  .mark-text {
    position: relative;
    z-index: 1;
  }

  /* ---- Phone-Stage: Glow + Choreografie + Tilt ---- */
  .phone-stage {
    perspective: 1200px;
  }
  /* zwei verschachtelte 3D-Ebenen: Scroll-Choreografie außen, Maus-Tilt innen */
  .phone-choreo {
    transform-style: preserve-3d;
    will-change: transform;
  }
  .phone {
    transform-style: preserve-3d;
    will-change: transform;
  }
  .glow-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .phone-glow {
    position: absolute;
    inset: -14% -20%;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--color-yellow) 85%, transparent),
      transparent 72%
    );
    filter: blur(48px);
    opacity: 0.55;
    transform-origin: center;
    will-change: transform, opacity;
  }

  /* Screenshot exakt in den transparenten Screen-Ausschnitt (Geometrie aus
     smartphone-rahmen.svg). Der dunkle Bezel (z-10) verdeckt die Ecken. */
  .phone-screen {
    position: absolute;
    left: 2.83%;
    top: 1.05%;
    width: 94.1%;
    height: 97.8%;
    object-fit: cover;
    object-position: top center;
    border-radius: 9%;
    z-index: 0;
  }

  /* ---- Schwebende Notifications ---- */
  .notif-stack {
    position: absolute;
    top: 8%;
    left: -8%;
    right: -4%;
    z-index: 30;
    pointer-events: none;
  }
  .notif {
    position: absolute;
    inset-inline: 0;
    top: 0;
    border-radius: 1rem;
    background-color: color-mix(in srgb, var(--color-offwhite) 92%, transparent);
    border: 1px solid rgb(59 59 58 / 0.06);
    /* weiche, große Elevation mit niedriger Opacity */
    box-shadow: 0 24px 50px -18px rgb(59 59 58 / 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.75rem 0.85rem;
    color: var(--color-black);
    will-change: transform, opacity;
  }
  .notif-icon {
    height: 2.5rem;
    width: 2.5rem;
    flex-shrink: 0;
    border-radius: 24%;
  }
  .notif-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.1;
  }
  .notif-time {
    flex-shrink: 0;
    font-weight: 400;
    opacity: 0.5;
  }
  .notif-body {
    margin-top: 0.15rem;
    font-size: 13px;
    line-height: 1.3;
  }

  /* ---- Fallback: ohne JS / bei reduzierter Bewegung nur EINE Notification ---- */
  .notif {
    opacity: 0;
  }
  .notif:first-child {
    opacity: 1;
  }

  /* ---- Anfangszustände NUR bei aktivem JS + erlaubter Bewegung verstecken.
     Sonst bleibt alles sofort sichtbar (kein Content-Verlust). ---- */
  @media (prefers-reduced-motion: no-preference) {
    html.js .line-inner {
      transform: translateY(110%);
    }
    html.js .mark-hl {
      transform: scaleX(0);
    }
    html.js [data-hero-sub],
    html.js [data-hero-trust] {
      opacity: 0;
    }
    html.js .notif:first-child {
      opacity: 0; /* im JS-Fall steuert die GSAP-Schleife alle Karten */
    }
  }
</style>
