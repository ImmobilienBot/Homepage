---
/**
 * Hero — Awwwards Visual Language (siehe CLAUDE.md → Motion-System), Layout A:
 * kinetische Headline links, aufgefächerter 3-Phone-Cluster rechts.
 *
 * OBERSTES GEBOT: Inhalte sind IMMER sichtbar, auch ohne JS/GSAP.
 * - Headline steht per Default vollständig da (KEIN CSS-Vorverstecken); der
 *   Reveal ist rein additiv via gsap.from() in animations.ts.
 * - Phone-Cluster: Front-Phone (Angebotsliste) vorne, zwei kleinere Phones
 *   dahinter aufgefächert (Karte links, Suche rechts). Die Fächer-Ruhelage
 *   liegt in CSS → ohne JS sofort korrekt; JS fährt sie nur additiv heraus.
 * - Notifications: echter vertikaler Stapel oben am Front-Phone, ploppen
 *   nacheinander rein, halten, faden gemeinsam weg — Endlosschleife (JS).
 * - Hintergrund: cleanes Grau. Gelb kommt NUR von den schwebenden Punkten
 *   (Desktop-only, weichen dem Cursor aus — in animations.ts).
 *
 * Alles prefers-reduced-motion-fest (JS-Guard) und Performance-Budget
 * (nur transform/opacity). Store-Links aus site.ts, Texte aus i18n.
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import type { Locale } from '../../data/site';
import StoreBadges from '../StoreBadges.astro';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenList from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import screenMap from '../../assets/images/immobilien-bot-suchbereich-karte-zeichnen.png';
import screenConfig from '../../assets/images/immobilien-bot-suche-konfigurieren.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { headlineLines, markKeyword, notification } = t.hero;

// Höchstens 4 Karten im Stapel (i18n liefert mehr Meldungen als gezeigt werden).
const notifItems = notification.items.slice(0, 4);

// Zeile in Segmente zerlegen; das Keyword bekommt den animierten Marker.
function splitLine(line: string) {
  const idx = line.indexOf(markKeyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: markKeyword, mark: true },
    { text: line.slice(idx + markKeyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
---

<section id="hero" class="relative overflow-hidden px-inset py-section">
  {/* Schwebende gelbe Punkte (Desktop-only, per JS befüllt; weichen dem Cursor aus) */}
  <div class="hero-dots" data-dots aria-hidden="true"></div>

  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
    {/* ---- Links: kinetische Headline + CTAs ---- */}
    <div class="order-2 md:order-1">
      <h1 class="hero-headline font-black">
        {
          headlineLines.map((line) => (
            <span class="line-mask">
              <span class="line-inner">
                {splitLine(line).map((seg) =>
                  seg.mark ? (
                    <span class="mark-word">
                      <span class="mark-hl" aria-hidden="true" />
                      <span class="mark-text">{seg.text}</span>
                    </span>
                  ) : (
                    <span>{seg.text}</span>
                  ),
                )}
              </span>
            </span>
          ))
        }
      </h1>

      <p class="mt-6 max-w-prose text-subhead" data-hero-sub>{t.hero.subline}</p>

      <div class="mt-8" data-hero-cta>
        <StoreBadges position="hero" lang={lang} />
      </div>

      <p class="mt-4 text-body opacity-70" data-hero-trust>{t.hero.trustMicroline}</p>
    </div>

    {/* ---- Rechts: aufgefächerter Phone-Cluster (3 Phones) ---- */}
    <div class="order-1 flex justify-center md:order-2">
      <div data-phone-stage class="phone-stage relative w-[clamp(230px,74vw,320px)]">
        {/* Scroll-Choreografie-Ebene (rotate/scale/translate beim Scrollen) */}
        <div data-phone-choreo class="phone-choreo relative w-full">
          {/* Cluster-Ebene: Idle-Float + Maus-Tilt gelten für ALLE Phones als Gruppe */}
          <div data-phone-fan class="phone-fan relative w-full">
            {/* Hinteres Phone links: Karte / Suchbereich zeichnen */}
            <div class="phone phone--back phone--back-left" data-phone-back data-fan="left">
              <Image
                src={screenMap}
                alt={t.hero.mapAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Hinteres Phone rechts: Suche konfigurieren */}
            <div class="phone phone--back phone--back-right" data-phone-back data-fan="right">
              <Image
                src={screenConfig}
                alt={t.hero.configAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Front-Phone: Angebotsliste + Notification-Stapel */}
            <div class="phone phone--front" data-phone-front>
              <Image
                src={screenList}
                alt={t.hero.mockupAlt}
                class="phone-screen"
                loading="eager"
                fetchpriority="high"
              />
              <PhoneFrame class="phone-frame" />

              {/* Echter vertikaler Notification-Stapel (oben, überlagert die Liste) */}
              <div class="notif-stack" data-notif-stack aria-hidden="true">
                {
                  notifItems.map((item) => (
                    <div class="notif" data-notif>
                      <div class="flex items-start gap-2.5">
                        <Image
                          src={appIcon}
                          alt=""
                          width={96}
                          height={96}
                          class="notif-icon"
                        />
                        <div class="min-w-0 flex-1">
                          <p class="notif-head">
                            <span class="truncate">{notification.app}</span>
                            <span class="notif-time">{notification.time}</span>
                          </p>
                          <p class="notif-body">{notification.lead} {item}</p>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Kinetische Typografie (der Blickfang, links) ----
     Sichtbar per Default. Die Maske klippt nur die von unten einfahrende Zeile
     WÄHREND der Animation; im Ruhezustand (yPercent 0) ist die Zeile voll da.
     padding/margin-block schützen Ober-/Unterlängen vor dem overflow-Clip. */
  .hero-headline {
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.9; /* enge Zeilenhöhe */
    letter-spacing: -0.03em; /* enges Tracking */
  }
  .line-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.12em;
    margin-block: -0.12em;
  }
  .line-inner {
    display: block;
    will-change: transform;
  }
  .mark-word {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .mark-hl {
    position: absolute;
    inset: 0.08em -0.06em 0.04em -0.06em;
    background-color: var(--color-yellow);
    border-radius: 0.08em;
    transform-origin: left center;
    z-index: 0;
    /* Default: voll sichtbar. gsap.from() wischt beim Reveal von scaleX(0) herein. */
  }
  .mark-text {
    position: relative;
    z-index: 1;
  }

  /* ---- Schwebende gelbe Punkte (Hero-Hintergrund) ----
     Nur Desktop; per JS befüllt. Ohne JS bleibt der Layer leer (cleanes Grau). */
  .hero-dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-dot {
    position: absolute;
    top: 0;
    left: 0;
    border-radius: 9999px;
    background-color: var(--color-yellow);
    will-change: transform;
  }

  /* ---- Phone-Cluster: Perspektive (Tilt) + gefächerte Ruhelage ---- */
  .phone-stage {
    perspective: 1200px;
  }
  /* Zwei verschachtelte 3D-Ebenen: außen Scroll-Choreografie, innen Maus-Tilt/Idle. */
  .phone-choreo {
    transform-style: preserve-3d;
    will-change: transform;
  }
  .phone-fan {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Front-Phone definiert die Cluster-Größe (in-flow), hintere Phones liegen
     absolut deckungsgleich darüber und werden per transform aufgefächert. */
  .phone {
    position: relative;
    width: 100%;
  }
  .phone--back {
    position: absolute;
    inset: 0;
    z-index: 1;
    will-change: transform, opacity;
  }
  .phone--front {
    position: relative;
    z-index: 2;
    will-change: transform;
  }

  /* Fächer-Ruhelage (Fallback ohne JS = sofort korrekt).
     Diese Werte spiegeln REST in animations.ts (xPercent/yPercent/rotation/scale). */
  .phone--back-left {
    transform: translate(-34%, 6%) rotate(-8deg) scale(0.84);
  }
  .phone--back-right {
    transform: translate(33%, 9%) rotate(8deg) scale(0.82);
  }

  .phone-frame {
    position: relative;
    z-index: 10;
    display: block;
    height: auto;
    width: 100%;
  }

  /* Screenshot exakt in den transparenten Screen-Ausschnitt (Geometrie aus
     smartphone-rahmen.svg). Der dunkle Bezel (z-10) verdeckt die Ecken.
     box-shadow = phone-förmige, weiche große Elevation (hebt das Phone vom Grau ab). */
  .phone-screen {
    position: absolute;
    left: 2.83%;
    top: 1.05%;
    width: 94.1%;
    height: 97.8%;
    object-fit: cover;
    object-position: top center;
    border-radius: 9%;
    z-index: 0;
    box-shadow: 0 28px 44px -14px rgb(59 59 58 / 0.32);
  }

  /* ---- Notification-Stapel: oben am Front-Phone, überlagert die Liste ----
     Feste Slots im Fluss (flex column): Karten poppen per JS nacheinander in
     ihre Position, kein Reflow. Leichter Überhang über den Rahmenrand (Tiefe). */
  .notif-stack {
    position: absolute;
    top: 5%;
    left: -3%;
    right: -3%;
    z-index: 30;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .notif {
    border-radius: 1rem;
    background-color: color-mix(in srgb, var(--color-offwhite) 92%, transparent);
    border: 1px solid rgb(59 59 58 / 0.06);
    /* weiche, große Elevation mit niedriger Opacity */
    box-shadow: 0 18px 40px -16px rgb(59 59 58 / 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.6rem 0.7rem;
    color: var(--color-black);
    will-change: transform, opacity;
  }
  .notif-icon {
    height: 2.25rem;
    width: 2.25rem;
    flex-shrink: 0;
    border-radius: 24%;
  }
  .notif-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.1;
  }
  .notif-time {
    flex-shrink: 0;
    font-weight: 400;
    opacity: 0.5;
  }
  .notif-body {
    margin-top: 0.1rem;
    font-size: 12.5px;
    line-height: 1.3;
  }

  /* Mobile reduziert: engerer Cluster, kompakterer Stapel (nur 3 Karten sichtbar). */
  @media (max-width: 640px) {
    .phone--back-left {
      transform: translate(-26%, 6%) rotate(-7deg) scale(0.86);
    }
    .phone--back-right {
      transform: translate(25%, 8%) rotate(7deg) scale(0.85);
    }
    .notif-stack {
      left: 0;
      right: 0;
    }
    .notif:nth-child(4) {
      display: none;
    }
  }
</style>
