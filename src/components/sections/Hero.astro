---
/**
 * Hero — Awwwards Visual Language (siehe CLAUDE.md → Motion-System), Layout A:
 * kinetische Headline links, aufgefächerter 3-Phone-Cluster rechts.
 *
 * OBERSTES GEBOT: Inhalte sind IMMER sichtbar, auch ohne JS/GSAP.
 * - Headline steht per Default vollständig da (KEIN CSS-Vorverstecken); der
 *   Reveal ist rein additiv via gsap.from() in animations.ts.
 * - Phone-Cluster: Front-Phone (Angebotsliste) vorne, zwei kleinere Phones
 *   dahinter aufgefächert (Karte links, Suche rechts). Die Fächer-Ruhelage
 *   liegt in CSS → ohne JS sofort korrekt; JS fährt sie nur additiv heraus.
 * - Notifications: echter vertikaler Stapel oben am Front-Phone, ploppen
 *   nacheinander rein, halten, faden gemeinsam weg — Endlosschleife (JS).
 * - Hintergrund: cleanes Grau. Gelb kommt NUR von den schwebenden Punkten
 *   (Desktop-only, weichen dem Cursor aus — in animations.ts).
 *
 * Alles prefers-reduced-motion-fest (JS-Guard) und Performance-Budget
 * (nur transform/opacity). Store-Links aus site.ts, Texte aus i18n.
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import type { Locale } from '../../data/site';
import StoreBadges from '../StoreBadges.astro';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenList from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import screenMap from '../../assets/images/immobilien-bot-suchbereich-karte-zeichnen.png';
import screenConfig from '../../assets/images/immobilien-bot-suche-konfigurieren.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { headlineLines, markKeyword, notification } = t.hero;

// Höchstens 4 Karten im Stapel (i18n liefert mehr Meldungen als gezeigt werden).
const notifItems = notification.items.slice(0, 4);

// Zeile in Segmente zerlegen; das Keyword bekommt den animierten Marker.
function splitLine(line: string) {
  const idx = line.indexOf(markKeyword);
  if (idx < 0) return [{ text: line, mark: false }];
  return [
    { text: line.slice(0, idx), mark: false },
    { text: markKeyword, mark: true },
    { text: line.slice(idx + markKeyword.length), mark: false },
  ].filter((s) => s.mark || s.text.length > 0);
}
---

<section id="hero" class="hero-section relative overflow-hidden px-inset py-section">
  {/* Canvas-Partikelfeld (Desktop-only, per JS): dichte gelbe Welle + Cursor-Repel.
      Hinter Inhalten/Phones, über dem grauen Hintergrund. Mobile/reduced-motion: leer. */}
  <canvas class="hero-canvas" data-hero-canvas aria-hidden="true"></canvas>

  <div class="hero-grid relative z-10 mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
    {/* ---- Links: kinetische Headline + CTAs (mobil zuerst im DOM/Stapel) ---- */}
    <div class="hero-copy order-1">
      <h1 class="hero-headline font-black">
        {
          headlineLines.map((line) => (
            <span class="line-mask">
              <span class="line-inner">
                {splitLine(line).map((seg) =>
                  seg.mark ? (
                    <span class="mark-word">
                      <span class="mark-hl" aria-hidden="true" />
                      <span class="mark-text">{seg.text}</span>
                    </span>
                  ) : (
                    <span>{seg.text}</span>
                  ),
                )}
              </span>
            </span>
          ))
        }
      </h1>

      <p class="hero-sub mt-6" data-hero-sub>{t.hero.subline}</p>

      <div class="hero-cta mt-8" data-hero-cta>
        <StoreBadges position="hero" lang={lang} />
      </div>

      {/* Trust-Reihe: Stern + Rating + Label · Trenner · Downloads (klein, gedämpft) */}
      <div class="trust-row mt-6" data-hero-trust>
        <span class="trust-star" aria-hidden="true">★</span>
        <span class="trust-rating">{t.hero.trust.rating}</span>
        <span class="trust-label">{t.hero.trust.ratingLabel}</span>
        <span class="trust-sep" aria-hidden="true"></span>
        <span class="trust-downloads">{t.hero.trust.downloads}</span>
      </div>
    </div>

    {/* ---- Rechts (Desktop) / unten (Mobile): Phone-Visual ----
        Desktop: aufgefächerter 3-Phone-Cluster. Mobile: nur EIN Phone
        (Front/Angebotsliste), lugt angeschnitten von unten in den Viewport;
        die hinteren Phones sind mobil ausgeblendet (hidden md:block). */}
    <div class="hero-visual order-2 flex justify-center">
      <div data-phone-stage class="phone-stage relative w-[clamp(230px,74vw,320px)]">
        {/* Sanftes gelbes Glühen hinter dem Cluster (statisch, warmer Fokus) */}
        <div class="phone-glow" aria-hidden="true"></div>

        {/* Scroll-Choreografie-Ebene (scale/translate beim Scrollen) — enthält alle 3 Phones */}
        <div data-phone-choreo class="phone-choreo relative w-full">
            {/* Hinteres Phone links: Karte / Suchbereich zeichnen (mobil aus) */}
            <div class="phone phone--back phone--back-left hidden md:block" data-phone-back data-fan="left">
              <Image
                src={screenMap}
                alt={t.hero.mapAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Hinteres Phone rechts: Suche konfigurieren (mobil aus) */}
            <div class="phone phone--back phone--back-right hidden md:block" data-phone-back data-fan="right">
              <Image
                src={screenConfig}
                alt={t.hero.configAlt}
                class="phone-screen"
                loading="eager"
              />
              <PhoneFrame class="phone-frame" />
            </div>

            {/* Front-Phone: Angebotsliste + Notification-Stapel */}
            <div class="phone phone--front" data-phone-front>
              <Image
                src={screenList}
                alt={t.hero.mockupAlt}
                class="phone-screen"
                loading="eager"
                fetchpriority="high"
              />
              <PhoneFrame class="phone-frame" />

              {/* Echter vertikaler Notification-Stapel (oben, überlagert die Liste) */}
              <div class="notif-stack" data-notif-stack aria-hidden="true">
                {
                  notifItems.map((item) => (
                    <div class="notif" data-notif>
                      <div class="notif-inner">
                        <div class="flex items-start gap-2.5">
                          <Image
                            src={appIcon}
                            alt=""
                            width={96}
                            height={96}
                            class="notif-icon"
                          />
                          <div class="min-w-0 flex-1">
                            <p class="notif-head">
                              <span class="truncate">{notification.app}</span>
                              <span class="notif-time">{notification.time}</span>
                            </p>
                            <p class="notif-body">{notification.lead} {item}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>

  {/* Scroll-Indikator („Maus"): dunkel auf Hellgrau, zentriert am unteren Rand.
      Fadet beim ersten Wegscrollen aus (initHeroScrollCue). Rein dekorativ. */}
  <span class="hero-scroll-cue" data-hero-cue aria-hidden="true">
    <span class="hero-scroll-dot"></span>
  </span>
</section>

<style>
  /* ---- Scroll-Cue unter dem Hero („Maus"-Kontur mit gleitendem Punkt) ---- */
  .hero-scroll-cue {
    /* Fixiert am unteren Rand des ERSTEN Viewports (Fold) — unabhängig von der
       Hero-Höhe. Fadet beim Wegscrollen aus (initHeroScrollCue) und ist dann
       weg, bevor die dunkle Story kommt. pointer-events:none stört nichts.
       Default AUS: nur mit JS + erlaubter Bewegung sichtbar (sonst würde der
       fixierte Cue ohne Fade-JS dauerhaft am Bildschirm kleben). */
    position: fixed;
    left: 50%;
    bottom: clamp(1.75rem, 3.2vh, 2.25rem); /* ~28–36px */
    transform: translateX(-50%);
    z-index: 41;
    display: none;
    width: 24px;
    height: 38px;
    border: 2px solid var(--color-black);
    border-radius: 12px;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .hero-scroll-cue {
      display: block;
    }
  }
  .hero-scroll-dot {
    position: absolute;
    left: 50%;
    top: 7px;
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background-color: var(--color-black);
    transform: translateX(-50%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-scroll-dot {
      animation: heroCueDot 1.8s ease-in-out infinite;
    }
  }
  @keyframes heroCueDot {
    0% {
      opacity: 0;
      transform: translate(-50%, 0);
    }
    25% {
      opacity: 1;
    }
    75% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate(-50%, 11px);
    }
  }
</style>

<style>
  /* ---- Kinetische Typografie (der Blickfang, links) ----
     Sichtbar per Default. Die Maske klippt nur die von unten einfahrende Zeile
     WÄHREND der Animation; im Ruhezustand (yPercent 0) ist die Zeile voll da.
     padding/margin-block schützen Ober-/Unterlängen vor dem overflow-Clip. */
  .hero-headline {
    font-size: var(--text-h1); /* eingepasste Display-Größe (max 4.5rem, fittet die Spalte) */
    line-height: 0.95; /* enge Zeilenhöhe */
    letter-spacing: -0.02em; /* enges Tracking */
  }
  .line-mask {
    display: block;
    /* overflow:hidden klippt NUR die vertikal einfahrende Zeile. Horizontales
       Breathing (padding/margin-inline) stellt sicher, dass Marker-Überstände
       und Glyphen NIE horizontal beschnitten werden. */
    overflow: hidden;
    padding-block: 0.12em;
    margin-block: -0.12em;
    padding-inline: 0.14em;
    margin-inline: -0.14em;
  }
  .line-inner {
    display: block;
    will-change: transform;
  }
  .mark-word {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .mark-hl {
    position: absolute;
    inset: 0.08em -0.06em 0.04em -0.06em;
    background-color: var(--color-yellow);
    border-radius: 0.08em;
    transform-origin: left center;
    z-index: 0;
    /* Default: voll sichtbar. gsap.from() wischt beim Reveal von scaleX(0) herein. */
  }
  .mark-text {
    position: relative;
    z-index: 1;
  }

  /* ---- Subline: bewusster Sekundär-Block (nicht Fließtext) ----
     Etwas größer, luftige Zeilenhöhe, engere max-Breite (sauberer 2–3-Zeiler),
     kräftiger Grauton — präsent, aber klar sekundär zur schwarzen Headline.
     Gilt DE + EN (Text aus i18n). */
  .hero-sub {
    font-size: clamp(1.25rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    max-width: 34rem;
    color: rgb(59 59 58 / 0.8);
  }

  /* ---- Trust-Reihe (klein, gedämpftes Grau, leicht letter-spaced) ---- */
  .trust-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem; /* ~13px */
    letter-spacing: 0.03em;
    /* WCAG AA: 0.78-Deckkraft ≈ #616160 auf #eaebeb ≈ 5,2:1 (vorher 0.55 ≈ 2,9:1). */
    color: rgb(59 59 58 / 0.78);
  }
  .trust-star {
    color: var(--color-black); /* dunkel — gelb ging auf hellem Grau unter */
    font-size: 1.05em;
    line-height: 1;
  }
  .trust-rating {
    font-weight: 700;
  }
  .trust-label {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 0.82em;
  }
  .trust-sep {
    width: 1px;
    height: 0.95em;
    background-color: currentColor;
    opacity: 0.45;
  }

  /* ---- Canvas-Partikelfeld (Hero-Hintergrund) ----
     Nur Desktop; per JS bespielt (animations.ts → initHeroCanvas). Ohne JS bleibt
     das Canvas leer (cleanes Grau). Hinter den Inhalten (z-0), über dem Grau. */
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ---- Phone-Cluster: Perspektive + gefächerte Ruhelage ---- */
  .phone-stage {
    perspective: 1200px;
    /* Gesamter Cluster etwas tiefer (statisch, kein Layout-Shift). */
    transform: translateY(24px);
  }

  /* Großes, kräftiges gelbes Glühen hinter dem GESAMTEN 3-Phone-Cluster (statisch).
     Ersetzt den harten Schlagschatten — warmer Fokus, hebt die Phones vom Netz ab.
     z-0 (hinter den Phones, über dem Canvas/Grau). Deutlich größer als der Cluster,
     damit es auch im Endzustand (alle 3 Phones) klar sichtbar bleibt. */
  .phone-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 220%;
    height: 145%;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, #fff03c, rgba(255, 240, 60, 0) 74%);
    filter: blur(72px);
    opacity: 0.7;
    z-index: 0;
    pointer-events: none;
  }
  /* Scroll-Choreografie-Ebene (scale/translate beim Scrollen) — umfasst alle 3 Phones. */
  .phone-choreo {
    will-change: transform;
  }

  /* Front-Phone definiert die Cluster-Größe (in-flow), hintere Phones liegen
     absolut deckungsgleich darüber und werden per transform aufgefächert. */
  .phone {
    position: relative;
    width: 100%;
  }
  .phone--back {
    position: absolute;
    inset: 0;
    z-index: 1; /* beide hinteren Phones identischer z-index (hinter dem Front) */
    /* Oberkante als Skalier-Ankerpunkt: mit positivem yPercent liegt die Oberkante
       unter der Notch des Front-Phones → keine Ecken-Fragmente oben. */
    transform-origin: top center;
    will-change: transform, opacity;
  }
  .phone--front {
    position: relative;
    z-index: 2;
    will-change: transform;
  }

  /* Ruhelage: hintere Phones AUFRECHT (Rotation 0), EXAKT spiegelgleich (nur
     Vorzeichen X unterschiedlich) — identischer vertikaler Versatz (+12 %),
     identische Skalierung (0.86), symmetrischer Peek ±44 %. transform-origin oben
     → Oberkanten unter der Notch; +12 % hält die Unterkanten INNERHALB des Front-
     Phones (bottom ≈ 98 %) → keine überstehenden/gekreuzten Rahmen unten. Größerer
     Außen-Versatz (±44) → klarer Spalt zwischen den hinteren Phones. Fallback ohne
     JS = sofort korrekt; spiegelt FAN_REST. */
  .phone--back-left {
    transform: translate(-44%, 12%) scale(0.86);
  }
  .phone--back-right {
    transform: translate(44%, 12%) scale(0.86);
  }

  .phone-frame {
    position: relative;
    z-index: 10;
    display: block;
    height: auto;
    width: 100%;
  }

  /* Screenshot füllt die transparente Screen-Aussparung (Geometrie aus
     smartphone-rahmen.svg: Innenfläche ~2.83%/1.05%, r≈56px). Der Screenshot ist
     bewusst LEICHT größer als die Aussparung (Übermaß ~0.5% rundum, verschwindet
     hinter dem dunklen Bezel z-10) → kein heller Spalt zwischen Bild und Rahmen.
     border-radius als Zwei-Wert-Syntax → RUNDE ~58px-Ecken (statt vorher 9% =
     elliptisch 45×98px, das die Ecken zu stark abrundete und Lücken hinterließ). */
  .phone-screen {
    position: absolute;
    left: 2.4%;
    top: 0.6%;
    width: 95.4%;
    height: 98.9%;
    object-fit: cover;
    object-position: top center;
    border-radius: 11.5% / 5.3%;
    z-index: 0;
    /* Tiefe kommt vom gelben Glühen hinter dem Cluster (.phone-glow), kein Schatten. */
  }

  /* ---- Notification-Stapel: oben am Front-Phone, überlagert die Liste ----
     Feste Slots im Fluss (flex column): Karten poppen per JS nacheinander in
     ihre Position, kein Reflow. Leichter Überhang über den Rahmenrand (Tiefe). */
  .notif-stack {
    position: absolute;
    top: 5%;
    left: -3%;
    right: -3%;
    z-index: 30;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .notif {
    /* GSAP steuert transform/opacity der Karte; Hover-Scale liegt auf .notif-inner
       (kein Konflikt). pointer-events aktiv, damit Hover greift. */
    pointer-events: auto;
    will-change: transform, opacity;
  }
  .notif-inner {
    border-radius: 1rem;
    background-color: color-mix(in srgb, var(--color-offwhite) 92%, transparent);
    border: 1px solid rgb(59 59 58 / 0.06);
    /* weiche, große Elevation mit niedriger Opacity */
    box-shadow: 0 18px 40px -16px rgb(59 59 58 / 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.6rem 0.7rem;
    color: var(--color-black);
    transform-origin: center;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  /* Hover: Karte hebt sich leicht an (nur transform — CD-Schutzplanke). */
  .notif:hover .notif-inner {
    transform: scale(1.07);
    box-shadow: 0 22px 48px -16px rgb(59 59 58 / 0.45);
  }
  /* Ohne JS / reduced-motion: nur die erste Notification statisch zeigen.
     Läuft JS, übernimmt die GSAP-Schleife (autoAlpha) alle Karten. */
  .notif {
    opacity: 0;
  }
  .notif:first-child {
    opacity: 1;
  }
  .notif-icon {
    height: 2.25rem;
    width: 2.25rem;
    flex-shrink: 0;
    border-radius: 24%;
  }
  .notif-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.1;
  }
  .notif-time {
    flex-shrink: 0;
    font-weight: 400;
    opacity: 0.5;
  }
  .notif-body {
    margin-top: 0.1rem;
    font-size: 12.5px;
    line-height: 1.3;
  }

  /* =====================================================================
     MOBILE-HERO (Option A: Text zuerst) — greift NUR unterhalb des
     Desktop-Breakpoints (md = 768px). Der Desktop-Hero (≥768px) bleibt
     komplett unberührt (kein einziges Property leckt nach oben).

     Reihenfolge im ersten Viewport: H1 → Subline → Store-Badges →
     Trust-Microline (alle above the fold) → EIN Phone, das angeschnitten
     von unten hereinlugt. Ruhiger, flacher CD-Hintergrund + ein weiches
     gelbes Glow hinter dem Phone. Kein Cluster-/Partikel-Bleed.
     ===================================================================== */
  @media (max-width: 767.98px) {
    /* Voller (kleiner) Viewport, Browser-UI-Leiste eingerechnet (svh):
       Text oben, Phone füllt den Rest und läuft unter den Falz. */
    .hero-section {
      display: flex;
      flex-direction: column;
      min-height: 100svh;
      /* Header ist position:sticky → reserviert seine Höhe bereits im Flow.
         Daher nur ein kleiner Abstand (~24px) zwischen Header und H1 statt
         großem Padding. Unten 0 → Phone bleibt an der Viewport-Kante angeschnitten. */
      padding-block: 1.5rem 0;
    }

    /* Grid → Flex-Spalte in Quell-Reihenfolge (Text-Block → Phone).
       gap = Rhythmus Trust-Zeile → Phone (~36px) — etwas mehr Luft, damit die
       obere Copy atmet, jetzt wo das Phone schlanker steht. */
    .hero-grid {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      flex: 1;
      gap: 2.25rem;
    }

    /* ---- Text-Block: kompakterer 8px-Rhythmus, damit Badges + Trust
       above the fold bleiben. ---- */
    .hero-copy {
      flex: 0 0 auto;
      /* Über dem Phone-Visual (späteres DOM) stapeln → das weiche Gelb-Glow
         wäscht nie über die Trust-Zeile; Text bleibt jederzeit klar lesbar. */
      position: relative;
      z-index: 1;
    }
    .hero-headline {
      /* Etwas gedämpfter als der Token-Min (36px), damit die 2 Zeilen auf
         schmalen Handys nicht zu hoch werden. Roboto Black, enge LH bleibt. */
      font-size: clamp(2rem, 8.5vw, 2.75rem);
    }
    /* Vertikaler Rhythmus (8px-System): H1→Sub 16px · Sub→Badges 24px ·
       Badges→Trust 12px (Header→H1 bleibt kompakt, Trust→Phone via .hero-grid gap). */
    .hero-sub {
      margin-top: 1rem; /* 16px */
      font-size: 1.0625rem;
      line-height: 1.4;
    }
    .hero-cta {
      margin-top: 1.5rem; /* 24px */
    }
    .trust-row {
      margin-top: 0.75rem; /* 12px */
    }

    /* ---- Phone-Visual: füllt den Rest, Phone absolut → expandiert die
       Sektion NICHT; die Unterkante wird von der Sektion (overflow:hidden)
       angeschnitten = „hier geht's weiter". ---- */
    .hero-visual {
      position: relative;
      flex: 1 1 0;
      min-height: 30svh;
    }
    /* Phone als mittige, SCHLANKERE „Bühne": ~82–83% der Content-Breite (statt
       voll) → sichtbare Luft an den Seiten, ruhiger/premiumiger. Weiterhin
       zentriert. top:0 → Abstand zur Trust-Zeile kommt aus dem .hero-grid gap. */
    .phone-stage {
      position: absolute;
      left: 50%;
      top: 0;
      width: clamp(220px, 72vw, 300px);
      transform: translateX(-50%);
    }

    /* Nur EINE reale Notification (echter iOS-Push oben am Screen), volle Breite.
       ~11% unter der Oberkante → authentischer iOS-Banner-Abstand, klar unter
       der Notch (statt der 5%-Desktop-Ruhelage, die zu hoch klebte). */
    .notif-stack {
      top: 11%;
      left: 0;
      right: 0;
    }
    .notif:not(:first-child) {
      display: none;
    }
    /* B2 FEED-HINT: rein dekorative zweite Karte HINTER der realen (iOS-Gruppen-
       Push). Als ::after-Pseudo → kein Markup/keine Semantik (nicht im a11y-Tree),
       verändert Heading-Struktur nicht. Minimal schmaler (5% je Seite) + nach unten
       versetzt → nur die abgedunkelte Unterkante lugt hervor. Bewegt sich mit der
       realen Karte mit (ein Layer). B1 (strikt reduziert): diesen Block entfernen. */
    .notif:first-child {
      position: relative;
    }
    .notif:first-child::after {
      content: '';
      position: absolute;
      left: 5%;
      right: 5%;
      top: 9px;
      bottom: -9px;
      z-index: -1; /* hinter .notif-inner, über dem Phone-Screen */
      border-radius: 0.85rem;
      background-color: var(--color-darkgrey);
      box-shadow: 0 10px 24px -14px rgb(59 59 58 / 0.35);
    }

    /* Breites, weiches gelbes Aurora-Glow hinter dem schlankeren Phone: größerer
       Radius + stärkerer Blur, niedrige Opacity → hellt das Grau spürbar auf und
       trägt das Phone, ohne hart zu werden. Dezentes „Atmen" (~9s ease-in-out).
       Nur transform/opacity (composited); Basis-Zentrierung in den Keyframes. */
    .phone-glow {
      width: 240%;
      height: 150%;
      opacity: 0.55;
      filter: blur(90px);
      animation: heroGlowBreath 9s ease-in-out infinite;
    }

    /* „Lebendiger" Ruhezustand: das Phone (nur die Phone-Ebene, NICHT das Glow)
       schwebt sehr dezent vertikal — ±5px, ~5.5s ease-in-out, phasenverschoben
       zum 9s-Glow-Atmen. Nur transform, kein Layout/CLS. Auf Mobile hat
       .phone-choreo sonst keinen Transform (Desktop-Parallax ist pointer:fine). */
    .phone-choreo {
      animation: heroPhoneFloat 5.5s ease-in-out infinite;
    }
  }

  @keyframes heroPhoneFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }

  @keyframes heroGlowBreath {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.55;
    }
    50% {
      transform: translate(-50%, -53%) scale(1.07);
      opacity: 0.7;
    }
  }

  /* Ruhezustand bei prefers-reduced-motion: keine Loops (Glow-Atmen UND
     Phone-Schweben aus), alles statisch im Endzustand sichtbar. */
  @media (max-width: 767.98px) and (prefers-reduced-motion: reduce) {
    .phone-glow,
    .phone-choreo {
      animation: none;
    }
  }
</style>
