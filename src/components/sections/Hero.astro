---
/**
 * Hero — Layout Variante A.
 * Links: Headline (mit gelbem Marker-Highlight) + Subline + Store-Buttons +
 * Trust-Microline. Rechts: Phone-Mockup = App-Screenshot (frameless) hinter
 * dem Geräterahmen (smartphone-rahmen.svg), darüber eine echte HTML-Push-
 * Benachrichtigungskarte (kein Bild), die per GSAP dezent hereingleitet.
 *
 * Texte aus i18n, Store-Links aus site.ts, Design-Tokens/Sektions-Rhythmus
 * aus der CLAUDE.md. prefers-reduced-motion wird respektiert (siehe
 * scripts/animations.ts + Style unten).
 */
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { getStoreLinks } from '../../data/site';
import type { Locale } from '../../data/site';

import PhoneFrame from '../../assets/images/smartphone-rahmen.svg';
import screenshot from '../../assets/images/immobilien-bot-app-angebotsliste.png';
import appIcon from '../../assets/images/immobilien-bot-app-icon.png';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const links = getStoreLinks('hero');

// Gelber Marker-Highlight auf dem Keyword in der Headline.
const { headline, markKeyword } = t.hero;
const idx = headline.indexOf(markKeyword);
const headBefore = idx >= 0 ? headline.slice(0, idx) : headline;
const headMark = idx >= 0 ? markKeyword : '';
const headAfter = idx >= 0 ? headline.slice(idx + markKeyword.length) : '';
---

<section id="hero" class="px-inset py-section">
  <div class="mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
    {/* ---- Links: Text + CTAs ---- */}
    <div class="order-2 md:order-1">
      <h1 class="text-headline font-black text-balance">
        {headBefore}{headMark && <span class="mark">{headMark}</span>}{headAfter}
      </h1>

      <p class="mt-6 max-w-prose text-subhead">{t.hero.subline}</p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={links.ios}
          data-store="ios"
          class="rounded-pill bg-black px-6 py-3 font-bold text-offwhite transition-transform hover:-translate-y-0.5"
        >
          {t.cta.appStore}
        </a>
        <a
          href={links.android}
          data-store="android"
          class="rounded-pill bg-black px-6 py-3 font-bold text-offwhite transition-transform hover:-translate-y-0.5"
        >
          {t.cta.playStore}
        </a>
      </div>

      <p class="mt-4 text-body opacity-70">{t.hero.trustMicroline}</p>
    </div>

    {/* ---- Rechts: Phone-Mockup ---- */}
    <div class="order-1 flex justify-center md:order-2">
      <div class="phone relative w-[clamp(220px,70vw,300px)]">
        {/* Screenshot hinter dem Rahmen (Ecken sind bereits abgerundet) */}
        <Image
          src={screenshot}
          alt={t.hero.mockupAlt}
          class="phone-screen"
          loading="eager"
          fetchpriority="high"
        />

        {/* Geräterahmen (transparenter Screen-Ausschnitt) über dem Screenshot */}
        <PhoneFrame class="phone-frame relative z-10 block h-auto w-full" />

        {/* Echte HTML-Push-Benachrichtigung */}
        <div
          data-hero-notification
          class="notification absolute inset-x-[6%] top-[13%] z-20 rounded-2xl border border-black/5 bg-offwhite/95 p-3 shadow-lg backdrop-blur-sm"
          role="status"
        >
          <div class="flex items-start gap-3">
            <Image
              src={appIcon}
              alt=""
              width={96}
              height={96}
              class="h-10 w-10 shrink-0 rounded-[24%]"
            />
            <div class="min-w-0">
              <p class="flex items-baseline justify-between gap-2 text-[13px] font-bold leading-tight">
                <span class="truncate">{t.hero.notification.app}</span>
                <span class="shrink-0 font-normal opacity-50">
                  {t.hero.notification.time}
                </span>
              </p>
              <p class="mt-0.5 text-[13px] leading-snug">
                {t.hero.notification.body}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Screenshot exakt in den transparenten Screen-Ausschnitt des Rahmens legen.
    Werte aus der Geometrie von smartphone-rahmen.svg (Innen-Screen):
    left 2.83% · top 1.05% · width 94.1% · height 97.8%. Der dunkle Bezel
    (z-10) verdeckt die Screenshot-Ecken.
  */
  .phone-screen {
    position: absolute;
    left: 2.83%;
    top: 1.05%;
    width: 94.1%;
    height: 97.8%;
    object-fit: cover;
    object-position: top center;
    border-radius: 9%;
    z-index: 0;
  }

  /* Anfangszustand der Notification nur, wenn Animation erlaubt ist —
     unter prefers-reduced-motion bleibt die Karte sofort sichtbar. */
  @media (prefers-reduced-motion: no-preference) {
    .notification {
      opacity: 0;
    }
  }
</style>
