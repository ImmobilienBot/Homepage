---
/**
 * Bewertungen — Proof-Header (H2 + Keyword-Marker + abgeleitete Zahlen) über drei
 * Rating-Kacheln (App Store / Google Play / Google Maps) und zwei gegenläufigen,
 * rein CSS-animierten Marquee-Reihen mit Zitat-Sprechblasen.
 *
 * Guardrails: Genau EINE H1 bleibt im Hero → hier H2. Alle Zahlen aus site.ts
 * (Scores/Counts/totalReviewCount — nichts hart), Zitate aus site.ts (Wortlaut
 * unangetastet), Texte aus i18n. Marquee ist CSS-only (kein JS) und läuft ohne JS
 * identisch; nur Auftritts-Reveal per GSAP (transform/opacity). Keine Anbieter-Logos.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import {
  ratings,
  formatDownloads,
  totalReviewCount,
  storeLinks,
  googleMapsReviewsUrl,
} from '../../data/site';
import { reviews, reviewPlatformLabel } from '../../data/reviews';
import StarRating from '../ui/StarRating.astro';
import QuoteCard from '../ui/QuoteCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const B = t.sections.bewertungen;

// Keyword-Marker-Split (wie Ablauf/Features/Portale/Preise).
function markParts(text: string, mark: string) {
  const i = text.indexOf(mark);
  if (i < 0) return { pre: text, mark: '', post: '' };
  return { pre: text.slice(0, i), mark, post: text.slice(i + mark.length) };
}
const h = markParts(B.headline, B.headlineMark);

// Score locale-abhängig, feste 1 Nachkommastelle: DE „4,6"/„5,0" · EN „4.6"/„5.0".
const fmtScore = (v: number) =>
  new Intl.NumberFormat(lang === 'de' ? 'de-DE' : 'en-US', {
    minimumFractionDigits: 1,
    maximumFractionDigits: 1,
  }).format(v);

const subline = B.subline
  .replace('{total}', String(totalReviewCount))
  .replace('{downloads}', formatDownloads(lang));

// Rating-Kacheln → Links (App Store · Google Play · Google Maps). URLs aus site.ts.
const tiles = [
  { rating: ratings.appStore, href: storeLinks.ios },
  { rating: ratings.playStore, href: storeLinks.android },
  { rating: ratings.googleMaps, href: googleMapsReviewsUrl },
];

// Quellen-Durchmischung — DETERMINISTISCH zur Buildzeit (KEIN Math.random → stabile
// Reihenfolge über Builds, kein Diff-Rauschen). Jede Quelle wird per „even spread"-
// Schlüssel (i+0.5)/n gleichmäßig über die Sequenz verteilt (round-robin, gewichtet
// nach Anzahl je Quelle) → höchstens 2 gleiche Quellen in Folge; ein Sicherheits-Pass
// garantiert die Regel. Danach in zwei Reihen (11/10) geteilt — die zwei Maps-Reviews
// landen durch die gleichmäßige Verteilung automatisch in verschiedenen Reihen.
function interleaveBySource<T extends { platform: string }>(list: T[]): T[] {
  const groups = new Map<string, T[]>();
  for (const r of list) {
    if (!groups.has(r.platform)) groups.set(r.platform, []);
    groups.get(r.platform)!.push(r);
  }
  const scored: { r: T; key: number; plat: string }[] = [];
  for (const [plat, items] of groups) {
    items.forEach((r, i) => scored.push({ r, key: (i + 0.5) / items.length, plat }));
  }
  scored.sort((a, b) => a.key - b.key || a.plat.localeCompare(b.plat));
  const seq = scored.map((s) => s.r);
  // Sicherheits-Pass: 3 gleiche Quellen in Folge → das dritte mit dem nächsten
  // andersartigen Eintrag tauschen (deterministisch, kein random).
  for (let i = 2; i < seq.length; i++) {
    if (seq[i].platform === seq[i - 1].platform && seq[i - 1].platform === seq[i - 2].platform) {
      for (let j = i + 1; j < seq.length; j++) {
        if (seq[j].platform !== seq[i].platform) {
          [seq[i], seq[j]] = [seq[j], seq[i]];
          break;
        }
      }
    }
  }
  return seq;
}
const ordered = interleaveBySource(reviews);
const splitAt = Math.ceil(ordered.length / 2); // 11 / 10
const rows = [
  { items: ordered.slice(0, splitAt), mod: 'bw-row--1' },
  { items: ordered.slice(splitAt), mod: 'bw-row--2' },
];
---

<section id="bewertungen" aria-labelledby="bewertungen-heading" class="bw-section">
  <div class="bw-inner">
    {/* ---- Proof-Header: H2 (Mask-Reveal + Marker) + Subline ---- */}
    <header class="bw-head">
      <h2 id="bewertungen-heading" class="bw-h2">
        <span class="bw-mask"
          ><span class="bw-mask-in"
            >{h.pre}<span class="marker"
              ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
                >{h.mark}</span
              ></span
            >{h.post}</span
          ></span
        >
      </h2>
      <p class="bw-sub" data-bw-sub>{subline}</p>
      {B.transNote && <p class="bw-transnote" data-bw-sub>{B.transNote}</p>}
    </header>

    {/* ---- Rating-Kacheln (jetzt Links → Store/Maps) ---- */}
    <ul class="bw-tiles">
      {
        tiles.map(({ rating: r, href }) => (
          <li>
            <a
              class="bw-tile"
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              data-cursor
              data-bw-tile
              aria-label={`${r.label}: ${fmtScore(r.stars)} — ${B.tileLabel.replace('{count}', String(r.count))}`}
            >
              <span class="bw-tpill">{r.label}</span>
              <span class="bw-score">{fmtScore(r.stars)}</span>
              <StarRating score={r.stars} size={20} empty="#c0c0c1" sr={B.starsSr.replace('{n}', fmtScore(r.stars))} />
              <span class="bw-count">{B.tileLabel.replace('{count}', String(r.count))}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  {/* ---- Zitat-Marquee (zwei gegenläufige Reihen, CSS-only) ---- */}
  <div class="bw-marquee">
    {
      rows.map((row) => (
        <div class:list={['bw-row', row.mod]} data-bw-marquee>
          <div class="bw-track">
            {/* Jedes Testimonial GENAU EINMAL im Server-HTML (halbe DOM-Last im
                kritischen Pfad). Das nahtlose Klon-Set für den -50%-Loop erzeugt
                initReviewMarquee() clientseitig NACH dem First Paint/LCP und setzt
                erst dann .is-marquee auf die Reihe (→ Loop startet nie ohne Klone). */}
            {row.items.map((r) => (
              <QuoteCard
                quote={r.text[lang]}
                author={r.author}
                platform={reviewPlatformLabel[r.platform]}
                stars={r.rating}
                srText={B.starsSr.replace('{n}', String(r.rating))}
              />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* =====================================================================
     Basis — heller Standard-Grau-Hintergrund, einheitlicher Rhythmus. Content-
     Einschub NUR auf Header/Kacheln (.bw-inner); die Marquee läuft full-bleed.
     ===================================================================== */
  .bw-section {
    position: relative;
    background-color: var(--color-grey);
    padding-block: var(--spacing-section);
    overflow: hidden; /* full-bleed Marquee darf keinen H-Scroll der Seite erzeugen */
  }
  .bw-inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: var(--spacing-inset);
  }

  /* ---- Header (zentriert) ---- */
  .bw-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }
  .bw-h2 {
    font-weight: 900;
    font-size: clamp(2.1rem, 5.4vw, 3.75rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--color-black);
  }
  .bw-mask {
    display: inline-block;
    overflow: hidden;
    padding-block: 0.12em;
    margin-block: -0.12em;
    padding-inline: 0.14em;
    margin-inline: -0.14em;
    vertical-align: top;
  }
  .bw-mask-in {
    display: inline-block;
    will-change: transform;
  }
  .bw-sub {
    margin-top: clamp(1rem, 2vw, 1.4rem);
    margin-inline: auto;
    max-width: 560px;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.5;
    color: rgb(59 59 58 / 0.78);
  }
  .bw-transnote {
    margin-top: 0.6rem;
    margin-inline: auto;
    font-size: 13px;
    color: var(--color-grey-text);
  }

  /* =====================================================================
     Rating-Kacheln (die 3 Gesamtbewertungen) — GELBE Karten (#fff03c), weiche große
     Elevation. Die Testimonial-Bubbles darunter bleiben grau (keine gelben mehr).
     ===================================================================== */
  .bw-tiles {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .bw-tiles > li {
    display: flex;
  }
  .bw-tile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    width: 100%;
    padding: 18px;
    border-radius: 16px;
    background: var(--color-yellow);
    box-shadow: 0 24px 50px -28px rgb(59 59 58 / 0.4);
    text-decoration: none;
    /* Hover-Lift wie die Ablauf-Tickets (nur transform/opacity + Schatten). */
    transition:
      transform 0.2s ease-out,
      box-shadow 0.2s ease-out;
  }
  @media (hover: hover) and (pointer: fine) {
    .bw-tile:hover {
      transform: translateY(-6px);
      box-shadow: 0 32px 60px -24px rgb(59 59 58 / 0.5);
    }
  }
  .bw-tile:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 3px;
  }
  .bw-tpill {
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--color-black);
    color: var(--color-yellow);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .bw-score {
    font-weight: 900;
    font-size: clamp(2.25rem, 3vw, 2.75rem);
    line-height: 1;
    color: var(--color-black);
  }
  .bw-count {
    font-size: 13px;
    color: var(--color-grey-text); /* gedämpftes, barrierefreies Grau */
  }

  /* =====================================================================
     Marquee — full-bleed, zwei gegenläufige Reihen. Reine CSS-Animation (transform),
     kein JS. Kanten weich ausgeblendet; Hover/Fokus pausiert.
     ===================================================================== */
  .bw-marquee {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .bw-row {
    /* Standard (kein .is-marquee → ohne JS UND unter reduced-motion): horizontal
       scrollbar → JEDES Testimonial bleibt erreichbar (die einfache, ungeklonte
       Reihe würde von reinem overflow:hidden geclippt). overflow-y bleibt hidden
       (Schatten-Clipping wie gehabt). Sobald JS die Klone erzeugt + .is-marquee
       setzt, kippt die Reihe auf reines overflow:hidden (Loop, keine Scrollbar). */
    overflow-x: auto;
    overflow-y: hidden;
    /* 4f: großzügiges Innen-Padding → overflow:hidden clippt NICHT die Karten-Schatten
       und die Sprechblasen-Spitze. Die negative margin-block kompensiert exakt (Netto
       ±10px wie zuvor) → Sektions-Rhythmus + Zeilenabstand bleiben identisch. */
    padding-block: 40px;
    margin-block: -30px;
    /* PERF (LCP-Render-Delay-Fix): Die zwei Marquee-Reihen sind ~49 % des gesamten
       Homepage-DOM (21 Karten × Klon-Set je Reihe) und liegen IMMER below-the-fold.
       `content-visibility: auto` überspringt Style/Layout/Paint der off-screen Reihe
       bis sie in Viewport-Nähe kommt → kappt den größten Brocken der initialen
       Style-&-Layout-Arbeit, die sonst den First Paint des LCP-Elements (Hero-Phone)
       blockiert. Ersetzt das frühere `contain: layout paint` (impliziert es). Rein
       CSS, kein JS; die Reihe hat KEINEN ScrollTrigger-Reveal (nur CSS-Marquee) →
       keine „leere Sektion"-Gefahr.
       contain-intrinsic-size: EXAKTE Reihenhöhe je Reihe/Breakpoint (unten pro
       .bw-row--1/--2 gesetzt). Die Karten sind fix breit (330 px Desktop · 280 px
       Mobil) → die Reihenhöhe = höchste Karte ist pro Breakpoint konstant. Ein zu
       großer Platzhalter (früher pauschal 400 px) ließ die Reihe beim ersten Render
       um ~244 px SCHRUMPFEN. Das ist zwar CLS-neutral (passiert below-the-fold), aber
       es verschob das (schon fixierte) Lenis-Anker-Ziel → Nav-Anker landeten beim
       ERSTEN Klick ~157 px zu tief (2. Klick saß). Exakte Höhe = kein Schrumpfen =
       kein Anker-Overshoot. `auto` korrigiert zusätzlich nach dem ersten Render. */
    content-visibility: auto;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .bw-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  /* Der Loop läuft ERST, wenn initReviewMarquee() clientseitig das Klon-Set erzeugt
     UND die Reihe als .is-marquee markiert hat — nie ein laufender Loop ohne Klone
     (sonst Sprung/Lücke). Ohne JS/vor dem Klonen: statische Reihe (via <noscript>
     bzw. reduced-motion horizontal scrollbar → alle Testimonials erreichbar). */
  /* Marquee aktiv (Klone da): reines overflow:hidden — keine Scrollbar, sauberer
     Loop. Höhere Spezifität als die Standard-Reihe → gewinnt, wenn JS .is-marquee
     setzt. Off-screen (content-visibility-Platzhalter) gesetzt → kein CLS. */
  .bw-row.is-marquee {
    overflow: hidden;
  }
  .bw-row.is-marquee .bw-track {
    animation: bw-marquee var(--dur, 80s) linear infinite;
  }
  /* Klon-Wrapper ohne eigene Box → seine Karten werden direkte Flex-Items des Tracks
     (uniformer Abstand via margin-right der Karte → nahtloser -50%-Loop über 2 Sets).
     :global ist PFLICHT, kein Stil-Zucker: das Klon-Set erzeugt initReviewMarquee()
     clientseitig via document.createElement — dieses <div> trägt NICHT das
     data-astro-cid, an das Astro eine skopte `.bw-clones`-Regel binden würde. Eine
     skopte Regel griffe also nie, der Wrapper bliebe display:block → alle Klone
     stapeln vertikal in EINER Track-Spalte (Reihe bläht auf ~2200px, Loop kaputt).
     Global bindet die Regel an die Klasse allein → greift auch am JS-Knoten. */
  :global(.bw-clones) {
    display: contents;
  }
  .bw-row--1 .bw-track {
    --dur: 80s;
  }
  .bw-row--2 .bw-track {
    --dur: 74s;
  }
  /* Exakte content-visibility-Platzhalterhöhe je Reihe (Desktop-Basis; Mobil im
     <768px-Block). = Höhe der höchsten fix-breiten Karte (330 px) der Reihe → beim
     ersten Render KEIN Schrumpfen mehr → kein Anker-Erstklick-Overshoot. */
  .bw-row--1 {
    contain-intrinsic-size: auto 256px;
  }
  .bw-row--2 {
    contain-intrinsic-size: auto 301px;
  }
  /* Gegenläufige zweite Reihe — Richtung im is-marquee-Scope (gleiche Spezifität wie
     die Animation, danach in der Quelle → überschreibt animation-direction:normal). */
  .bw-row--2.is-marquee .bw-track {
    animation-direction: reverse;
  }
  @keyframes bw-marquee {
    to {
      transform: translateX(-50%);
    }
  }
  /* Hover UND Tastatur-Fokus in der Reihe pausieren die Bewegung. Unter .is-marquee
     gescoped: (a) semantisch korrekt (Pause zählt nur bei laufendem Loop), (b) nötig,
     damit die Regel die gleich-scoped `animation`-Shorthand-Deklaration (die
     play-state implizit auf running setzt) in der Spezifität schlägt. */
  .bw-row.is-marquee:hover .bw-track,
  .bw-row.is-marquee:focus-within .bw-track {
    animation-play-state: paused;
  }

  /* =====================================================================
     Mobile — Kacheln untereinander, kompakter.
     ===================================================================== */
  /* Mobile (< 768px): drei Aggregat-Kacheln NEBENEINANDER (kompakt). Die volle
     5-Sterne-Reihe wäre in ~85px-Kacheln bei 320px zu breit → ausgeblendet und durch
     Zahl + EINEN Stern ersetzt (Score bleibt im aria-label der Kachel). Plattform-
     Label klein/eng, damit „GOOGLE MAPS" bei 320px passt. 768–1023px behalten die
     Basis (3 Kacheln mit voller Sterne-Reihe). */
  @media (max-width: 767.98px) {
    .bw-h2 {
      font-size: clamp(1.85rem, 8vw, 2.5rem);
    }
    /* Einheitlicher Kopf→Inhalt-Abstand (Mobile-Rhythmus, Block 7). */
    .bw-head {
      margin-bottom: var(--head-gap-mobile);
    }
    .bw-tiles {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }
    .bw-tile {
      align-items: center;
      text-align: center;
      gap: 5px;
      padding: 12px 6px;
      border-radius: 12px;
    }
    .bw-tpill {
      padding: 3px 6px;
      font-size: 9px;
      letter-spacing: 0.2px;
      white-space: nowrap;
    }
    /* Volle Sterne-Reihe raus; stattdessen Score + ein Stern (prominent). */
    .bw-tile :global(.star-rating) {
      display: none;
    }
    .bw-score {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      font-size: clamp(1.25rem, 6.5vw, 1.6rem);
    }
    .bw-score::after {
      content: '★';
      font-size: 0.66em;
      line-height: 1;
      color: var(--color-black);
    }
    .bw-count {
      font-size: 11px;
    }
    /* Mobil sind die Karten 280 px breit → Text bricht mehr um → höhere Reihen.
       Exakte Platzhalterhöhe je Reihe → kein Schrumpfen beim ersten Render. */
    .bw-row--1 {
      contain-intrinsic-size: auto 278px;
    }
    .bw-row--2 {
      contain-intrinsic-size: auto 346px;
    }
  }

  /* =====================================================================
     prefers-reduced-motion — keine Bewegung: Klone raus, Reihen nativ scrollbar
     (data-lenis-prevent verhindert Lenis-Hijack). Inhalte bleiben voll sichtbar.
     ===================================================================== */
  @media (prefers-reduced-motion: reduce) {
    .bw-track {
      animation: none;
    }
    /* Global (gleicher Grund wie oben: JS-erzeugter Klon-Knoten ohne data-astro-cid).
       Unter reduced-motion ruft animations.ts initReviewMarquee() ohnehin nicht auf →
       i. d. R. existiert gar kein Klon-Set; die Regel bleibt als Sicherung bestehen. */
    :global(.bw-clones) {
      display: none;
    }
    .bw-row {
      overflow-x: auto;
    }
  }
</style>
