---
/**
 * Header — Signature-Moment „Nav → Pille" (siehe CLAUDE.md).
 * scrollY < ~60px: volle Breite, transparent, kein Rand/Schatten.
 * Danach schrumpft die Nav weich zu einer zentrierten, schwebenden Pille
 * (offwhite/95 + backdrop-blur, weicher großer Schatten, deutlich vom Rand
 * abgesetzt — auch seitlich auf Mobile). Zitiert die App-Bottom-Bar.
 * Logo (echtes SVG), Links und der gelbe „Kostenlos testen"-CTA sind
 * durchgehend sichtbar/klickbar.
 */
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n';
import type { Locale } from '../../data/site';
import Logo from '../../assets/images/immobilien-bot-logo.svg';
import PillButton from '../ui/PillButton.astro';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath('/', lang);
const base = home === '/' ? '' : home.replace(/\/$/, '');

const navItems = [
  { label: t.nav.bot, href: `${base}/#problem` },
  { label: t.nav.features, href: `${base}/#features` },
  { label: t.nav.pricing, href: `${base}/#preise` },
  { label: t.nav.faq, href: `${base}/#faq` },
];
---

<header class="site-header" data-header>
  <div class="nav-inner">
    <a href={home} class="nav-logo-link" aria-label="Immobilien Bot – Startseite">
      <Logo class="nav-logo" aria-hidden="true" />
    </a>

    <nav class="hidden items-center gap-2.5 md:flex" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link" data-nav-link>
          <span class="nav-link__bg" aria-hidden="true"></span>
          <span class="nav-link__label">{item.label}</span>
        </a>
      ))}
    </nav>

    <PillButton href={`${base}/#preise`} size="sm" surface="light" icon="bolt">
      {/* Desktop: volle Variante ab sm (640px). Mobile (<640px): kurze Variante.
          Pille hat white-space:nowrap → bleibt immer einzeilig. */}
      <span class="hidden sm:inline">{t.nav.ctaFree}</span>
      <span class="sm:hidden">{t.nav.ctaShort}</span>
    </PillButton>
  </div>
</header>

<script>
  // Vollbreite ↔ Pille — rein CSS-getrieben (kein GSAP nötig).
  const header = document.querySelector('[data-header]');
  let ticking = false;
  function update() {
    header?.toggleAttribute('data-scrolled', window.scrollY > 60);
    ticking = false;
  }
  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  update();

  // Scroll-Spy: aktiver Menüpunkt je sichtbarer Sektion (gelber Unterstrich).
  // Läuft unabhängig von prefers-reduced-motion (reiner Zustand, keine Bewegung)
  // und in beiden Nav-Zuständen (voll/Pille). Ziel-Anchor aus dem href-Hash.
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'),
  );
  const linkById = new Map<string, HTMLAnchorElement>();
  for (const a of navLinks) {
    const href = a.getAttribute('href') || '';
    const i = href.indexOf('#');
    if (i >= 0) {
      const id = href.slice(i + 1);
      if (id) linkById.set(id, a);
    }
  }
  const sections = [...linkById.keys()]
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  if (sections.length) {
    const visible = new Set<Element>();
    const spy = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        }
        // Aktiv = die am weitesten oben liegende, aktuell im Mittelband sichtbare Sektion.
        let active: Element | null = null;
        let top = Infinity;
        for (const sec of visible) {
          const y = sec.getBoundingClientRect().top;
          if (y < top) {
            top = y;
            active = sec;
          }
        }
        for (const a of navLinks) a.classList.remove('is-active');
        if (active && active instanceof HTMLElement) {
          linkById.get(active.id)?.classList.add('is-active');
        }
      },
      // schmales Mittelband → i. d. R. genau eine aktive Sektion
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
    );
    for (const s of sections) spy.observe(s);
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    padding: 0;
    transition: padding 0.4s ease;
  }
  .site-header[data-scrolled] {
    /* schwebende Pille: vom oberen Rand UND (v. a. Mobile) von den Seiten abgesetzt */
    padding-top: 0.75rem;
    padding-inline: clamp(1.25rem, 6vw, 2.5rem);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-inline: auto;
    max-width: 72rem;
    padding: 0.85rem var(--spacing-inset);
    border-radius: 0;
    background-color: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    transition:
      max-width 0.45s ease,
      padding 0.45s ease,
      border-radius 0.45s ease,
      background-color 0.45s ease,
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }
  .site-header[data-scrolled] .nav-inner {
    max-width: 46rem;
    /* Feinschliff: etwas mehr horizontales Innen-Padding → Logo (links) und CTA
       (rechts) lösen sich vom Pillen-Rand (je ~0.25rem mehr). */
    padding: 0.55rem 0.95rem 0.55rem 1.5rem;
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-offwhite) 95%, transparent);
    border-color: rgb(59 59 58 / 0.06);
    box-shadow: 0 20px 45px -18px rgb(59 59 58 / 0.35);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }

  /* Logo auf Nav-Höhe, sauber vertikal zentriert (flex align-items: center). */
  .nav-logo-link {
    display: inline-flex;
    align-items: center;
  }
  .nav-logo {
    display: block;
    height: 1.9rem;
    width: auto;
  }

  /* ---- Menüpunkte — „Marker-Nav" (CD S. 29) ----
     Button-Typo (Roboto Black, uppercase, .8rem, Tracking .05em). Inaktiv #666665
     (≥4.5:1 auf #f6f6f6 UND #eaebeb — keine Opazität). Hover: dezenter grauer
     Marker-Wipe (#d9dada) in Marker-Geometrie. Aktiv (Scroll-Spy): gelber Marker.
     Rein CSS, nur transform/opacity; kein Layout-Shift (Marker absolut, skewX). */
  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.4em 0.55em;
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #666665;
    text-decoration: none;
    /* Immer einzeilig — sonst bricht „Der Bot" in der geschrumpften Pille um. */
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .nav-link__bg {
    position: absolute;
    inset: 0;
    background: var(--color-darkgrey); /* #d9dada */
    border-radius: 0.35em;
    transform: skewX(-8deg) scaleX(0);
    transform-origin: left center;
    transition:
      transform 0.28s cubic-bezier(0.65, 0, 0.35, 1),
      background-color 0.2s ease;
  }
  .nav-link__label {
    position: relative;
  }

  /* Hover NUR auf echten Zeigergeräten (kein Sticky-Hover auf Touch). */
  @media (hover: hover) and (pointer: fine) {
    .nav-link:hover {
      color: var(--color-black);
    }
    .nav-link:hover .nav-link__bg {
      transform: skewX(-8deg) scaleX(1);
    }
  }

  /* Fokus-Indikator — Pflicht, da der Unterstrich als Indikator wegfällt. */
  .nav-link:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
  }

  /* Aktiv (Scroll-Spy) NACH den Hover-Regeln → schlägt Hover: der aktive Punkt
     bleibt beim Hover GELB. Marker-Geometrie (skewX −8°) in jedem Zustand mitführen. */
  .nav-link.is-active {
    color: var(--color-black);
  }
  .nav-link.is-active .nav-link__bg {
    transform: skewX(-8deg) scaleX(1);
    background: var(--color-yellow);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .nav-inner,
    .nav-link,
    .nav-link__bg {
      transition: none;
    }
  }
</style>
