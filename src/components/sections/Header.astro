---
/**
 * Header — Signature-Moment „Nav → Pille" (siehe CLAUDE.md).
 * scrollY < ~60px: volle Breite, transparent, kein Rand/Schatten.
 * Danach schrumpft die Nav weich zu einer zentrierten, schwebenden Pille
 * (offwhite/95 + backdrop-blur, weicher großer Schatten, deutlich vom Rand
 * abgesetzt). Zitiert die App-Bottom-Bar.
 *
 * Nav-Reihenfolge: Features · Portale · Preise · FAQ · Über uns (Seite +
 * Dropdown) · Kontakt. Anchor-Links werden IMMER absolut gerendert
 * (/#features bzw. /en/#features) → funktionieren auch von Unterseiten aus.
 * Sprachumschalter „DE | EN" (statischer Link, kein JS) rechts vor dem CTA;
 * mobil im aufklappbaren Menü (natives <details>, ohne JS bedienbar).
 */
import { getLangFromUrl, useTranslations, localizePath, switchLangHref } from '../../i18n';
import type { Locale } from '../../data/site';
import Logo from '../../assets/images/immobilien-bot-logo.svg';
import PillButton from '../ui/PillButton.astro';
import StoreBadges from '../StoreBadges.astro';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath('/', lang);
const base = home === '/' ? '' : home.replace(/\/$/, '');
// Absolute In-Page-Anker (funktionieren auch von /ueber-uns, /impressum …).
const anchor = (id: string) => `${base}/#${id}`;

// „Über uns" ist eine echte Seite mit übersetztem Slug (/ueber-uns ↔ /en/about).
const aboutHref = lang === 'en' ? '/en/about' : '/ueber-uns';
const path = Astro.url.pathname;
const isAbout = path === aboutHref || path === `${aboutHref}/`;

// Section-Anchors (Scroll-Spy). Reihenfolge im Markup: features, portale, preise,
// faq, [Über uns], kontakt — „Über uns" ist ein Seitenlink (kein Scroll-Spy).
const navBefore = [
  { id: 'features', label: t.nav.features },
  { id: 'portale', label: t.nav.portale },
  { id: 'preise', label: t.nav.pricing },
  { id: 'faq', label: t.nav.faq },
];

// Sprachumschalter-Ziele (Sprach-Pendant der aktuellen Seite).
const deHref = switchLangHref(path, 'de');
const enHref = switchLangHref(path, 'en');

// Vollständige Menü-Reihenfolge fürs Mobile-Overlay (Features · Portale · Preise ·
// FAQ · Über uns · Kontakt). `section` = Scroll-Spy-ID (Über uns ist ein Seitenlink
// ohne Spy). Anchors absolut → funktionieren auch von Unterseiten.
const navItems = [
  ...navBefore.map((item) => ({ label: item.label, href: anchor(item.id), section: item.id })),
  { label: t.nav.about, href: aboutHref, section: undefined as string | undefined },
  { label: t.nav.contact, href: anchor('kontakt'), section: 'kontakt' },
];
---

<header class="site-header" data-header>
  <div class="nav-inner">
    <a href={home} class="nav-logo-link" aria-label="Immobilien Bot – Startseite">
      <Logo class="nav-logo" aria-hidden="true" />
    </a>

    {/* ---- Desktop-Nav (≥1280px) ---- */}
    <nav class="nav-desktop" aria-label="Hauptnavigation">
      {
        navBefore.map((item) => (
          <a href={anchor(item.id)} class="nav-link" data-nav-link>
            <span class="nav-link__bg" aria-hidden="true" />
            <span class="nav-link__label">{item.label}</span>
          </a>
        ))
      }

      {/* Über uns — Seitenlink mit Dropdown (Manifest · Das Team) */}
      <div class="nav-dropdown" data-dropdown>
        <a
          href={aboutHref}
          class:list={['nav-link', 'nav-link--about', { 'is-active': isAbout }]}
          data-about-link
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span class="nav-link__bg" aria-hidden="true"></span>
          <span class="nav-link__label"
            >{t.nav.about}<svg
              class="nav-caret"
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg
            ></span
          >
        </a>
        <div class="nav-submenu" data-submenu role="menu">
          <a href={`${aboutHref}#manifest`} class="nav-subitem" role="menuitem">
            {t.nav.aboutManifest}
          </a>
          <a href={`${aboutHref}#team`} class="nav-subitem" role="menuitem">
            {t.nav.aboutTeam}
          </a>
        </div>
      </div>

      <a href={anchor('kontakt')} class="nav-link" data-nav-link>
        <span class="nav-link__bg" aria-hidden="true"></span>
        <span class="nav-link__label">{t.nav.contact}</span>
      </a>
    </nav>

    {/* ---- Rechts: Sprachumschalter (Desktop) + CTA + Hamburger (Mobile) ---- */}
    <div class="nav-right">
      <div class="lang-switch" role="group" aria-label="Sprache / Language">
        <a
          href={deHref}
          hreflang="de"
          lang="de"
          class:list={['lang-opt', { 'is-active': lang === 'de' }]}
          aria-label={t.nav.langToDe}
          aria-current={lang === 'de' ? 'true' : undefined}>DE</a
        >
        <span class="lang-sep" aria-hidden="true">|</span>
        <a
          href={enHref}
          hreflang="en"
          lang="en"
          class:list={['lang-opt', { 'is-active': lang === 'en' }]}
          aria-label={t.nav.langToEn}
          aria-current={lang === 'en' ? 'true' : undefined}>EN</a
        >
      </div>

      <PillButton href={`${base}/#preise`} size="sm" surface="light" icon="bolt">
        <span class="hidden sm:inline">{t.nav.ctaFree}</span>
        <span class="sm:hidden">{t.nav.ctaShort}</span>
      </PillButton>

      {/* Mobile-Menü — Trigger (Vollbild-Overlay, JS-Enhancement; Overlay liegt
          BEWUSST außerhalb von .nav-inner, weil deren backdrop-filter im Scroll-
          Zustand sonst einen Containing-Block für position:fixed erzeugt). */}
      <button
        type="button"
        class="nav-burger"
        aria-label={t.nav.menuOpen}
        aria-controls="nav-overlay"
        aria-expanded="false"
        data-burger
      >
        <span class="burger-box" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>

  {/* ---- Vollbild-Menü-Overlay (nur <lg, JS-Enhancement) ---- */}
  <div id="nav-overlay" class="nav-overlay" data-overlay aria-hidden="true">
    {/* Eigener Schließen-Button (Kind des Overlays → unabhängig von Header-Zuständen).
        Der Burger im Header wird bei offenem Menü komplett versteckt. */}
    <button type="button" class="mo-close" data-mo-close aria-label={t.nav.menuClose}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
    </button>
    <nav class="mo-nav" aria-label={t.nav.menuOpen}>
      <ol class="mo-list">
        {
          navItems.map((item, i) => (
            <li class="mo-item" style={`--i:${i}`}>
              <a
                href={item.href}
                class="mo-link"
                data-mo-link
                data-section={item.section ?? ''}
              >
                <span class="mo-index" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="mo-mask">
                  <span class="mo-line">{item.label}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="mo-footer" style={`--i:${navItems.length}`}>
      <StoreBadges position="Homepage_MobileMenu" androidPosition="mobile_menu" class="mo-badges" />
      <div class="mo-lang" role="group" aria-label="Sprache / Language">
        <a
          href={deHref}
          hreflang="de"
          lang="de"
          class:list={['mo-lang-opt', { 'is-active': lang === 'de' }]}
          aria-label={t.nav.langToDe}
          aria-current={lang === 'de' ? 'true' : undefined}>DE</a
        >
        <span class="mo-lang-sep" aria-hidden="true">|</span>
        <a
          href={enHref}
          hreflang="en"
          lang="en"
          class:list={['mo-lang-opt', { 'is-active': lang === 'en' }]}
          aria-label={t.nav.langToEn}
          aria-current={lang === 'en' ? 'true' : undefined}>EN</a
        >
      </div>
    </div>
  </div>
</header>

<script>
  // Vollbreite ↔ Pille — rein CSS-getrieben (kein GSAP nötig).
  const header = document.querySelector('[data-header]');
  let ticking = false;
  function update() {
    header?.toggleAttribute('data-scrolled', window.scrollY > 60);
    ticking = false;
  }
  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  update();

  // Scroll-Spy: aktiver Menüpunkt je sichtbarer Sektion (gelber Marker). Nur die
  // Section-Anchors tragen [data-nav-link]; auf Seiten ohne die Sektionen (z. B.
  // /ueber-uns) findet der Spy keine Ziele und bleibt inaktiv.
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'),
  );
  const linkById = new Map<string, HTMLAnchorElement>();
  for (const a of navLinks) {
    const href = a.getAttribute('href') || '';
    const i = href.indexOf('#');
    if (i >= 0) {
      const id = href.slice(i + 1);
      if (id) linkById.set(id, a);
    }
  }
  const sections = [...linkById.keys()]
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  if (sections.length) {
    const visible = new Set<Element>();
    const spy = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        }
        let active: Element | null = null;
        let top = Infinity;
        for (const sec of visible) {
          const y = sec.getBoundingClientRect().top;
          if (y < top) {
            top = y;
            active = sec;
          }
        }
        for (const a of navLinks) a.classList.remove('is-active');
        if (active && active instanceof HTMLElement) {
          linkById.get(active.id)?.classList.add('is-active');
        }
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
    );
    for (const s of sections) spy.observe(s);
  }

  // Über-uns-Dropdown (Desktop): CSS zeigt das Submenü bei :hover / :focus-within.
  // JS pflegt nur aria-expanded (Screenreader) + Escape schließt (Fokus verlassen).
  const dd = document.querySelector<HTMLElement>('[data-dropdown]');
  const aboutLink = dd?.querySelector<HTMLElement>('[data-about-link]');
  if (dd && aboutLink) {
    const setExpanded = (v: boolean) => aboutLink.setAttribute('aria-expanded', v ? 'true' : 'false');
    dd.addEventListener('mouseenter', () => setExpanded(true));
    dd.addEventListener('mouseleave', () => setExpanded(false));
    dd.addEventListener('focusin', () => setExpanded(true));
    dd.addEventListener('focusout', (e) => {
      if (!dd.contains(e.relatedTarget as Node | null)) setExpanded(false);
    });
    dd.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        setExpanded(false);
        (document.activeElement as HTMLElement | null)?.blur();
      }
    });
  }

  // Mobile-Menü — Vollbild-Overlay (JS-Enhancement). Ohne JS bleibt der Seiten-
  // inhalt normal per Scroll erreichbar; das Overlay ist reine Zugabe.
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const overlay = document.querySelector<HTMLElement>('[data-overlay]');
  if (burger && overlay) {
    const openLabel = burger.getAttribute('aria-label') || 'Menü öffnen';
    const closeLabel = openLabel === 'Open menu' ? 'Close menu' : 'Menü schließen';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const closeX = overlay.querySelector<HTMLButtonElement>('[data-mo-close]');
    const links = Array.from(overlay.querySelectorAll<HTMLAnchorElement>('a[href]'));
    // Fokus-Trap innerhalb des Overlays: Schließen-✕ + alle Links (NICHT der Burger,
    // der bei offenem Menü versteckt ist).
    const focusables = [closeX, ...links].filter(Boolean) as HTMLElement[];
    let isOpen = false;

    const lockScroll = (v: boolean) => {
      document.documentElement.classList.toggle('menu-open', v);
      // Lenis (falls schon initialisiert) anhalten/fortsetzen; CSS-overflow ist der
      // Fallback für No-Lenis / vor der rIC-Initialisierung.
      const lenis = (window as unknown as { __lenis?: { stop(): void; start(): void } }).__lenis;
      if (lenis) v ? lenis.stop() : lenis.start();
    };

    // Aktiven Scroll-Spy-Punkt in die Overlay-Zeilen spiegeln (gelber Marker).
    const syncActive = () => {
      const activeId =
        document.querySelector<HTMLAnchorElement>('[data-nav-link].is-active')?.getAttribute('href')?.split('#')[1] || '';
      overlay.querySelectorAll<HTMLElement>('[data-mo-link]').forEach((a) => {
        a.classList.toggle('is-active', !!activeId && a.dataset.section === activeId);
      });
    };

    const open = () => {
      if (isOpen) return;
      isOpen = true;
      syncActive();
      overlay.setAttribute('aria-hidden', 'false');
      overlay.setAttribute('data-open', '');
      header?.setAttribute('data-menu-open', '');
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', closeLabel);
      lockScroll(true);
      // Fokus auf den ersten Link (nach dem Paint).
      requestAnimationFrame(() => links[0]?.focus());
    };

    const finishClose = () => {
      overlay.removeAttribute('data-open');
      overlay.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('is-closing');
    };
    const close = (returnFocus = true) => {
      if (!isOpen) return;
      isOpen = false;
      header?.removeAttribute('data-menu-open');
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', openLabel);
      lockScroll(false);
      if (reduce) {
        finishClose();
      } else {
        // Fade-out über die Overlay-Transition, dann Endzustand.
        overlay.classList.add('is-closing');
        overlay.removeAttribute('data-open');
        const done = () => {
          overlay.removeEventListener('transitionend', done);
          finishClose();
        };
        overlay.addEventListener('transitionend', done);
        window.setTimeout(() => {
          if (overlay.classList.contains('is-closing')) done();
        }, 400);
      }
      if (returnFocus) burger.focus();
    };

    burger.addEventListener('click', () => (isOpen ? close() : open()));
    closeX?.addEventListener('click', () => close());

    // Anchor-Tap: erst schließen (ohne Fokus-Rückgabe), dann übernimmt der globale
    // Lenis-Anchor-Handler den Smooth-Scroll. Instant schließen → Scroll startet sofort.
    links.forEach((a) => {
      a.addEventListener('click', () => {
        if (!isOpen) return;
        isOpen = false;
        header?.removeAttribute('data-menu-open');
        burger.setAttribute('aria-expanded', 'false');
        burger.setAttribute('aria-label', openLabel);
        lockScroll(false);
        finishClose();
      });
    });

    // ESC schließt; einfacher Fokus-Trap innerhalb des Overlays.
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'Tab') {
        const list = focusables.filter((el) => el.offsetParent !== null);
        if (!list.length) return;
        const first = list[0];
        const last = list[list.length - 1];
        const act = document.activeElement as HTMLElement;
        if (e.shiftKey && act === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && act === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    padding: 0;
    transition: padding 0.4s ease;
  }
  .site-header[data-scrolled] {
    padding-top: 0.75rem;
    padding-inline: clamp(1.25rem, 6vw, 2.5rem);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-inline: auto;
    max-width: 72rem;
    padding: 0.85rem var(--spacing-inset);
    border-radius: 0;
    background-color: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    transition:
      max-width 0.45s ease,
      padding 0.45s ease,
      border-radius 0.45s ease,
      background-color 0.45s ease,
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }
  .site-header[data-scrolled] .nav-inner {
    /* Breit genug für 6 Links + DE|EN + CTA ab 1280px (kein Umbruch). */
    max-width: 64rem;
    padding: 0.55rem 0.95rem 0.55rem 1.5rem;
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-offwhite) 95%, transparent);
    border-color: rgb(59 59 58 / 0.06);
    box-shadow: 0 20px 45px -18px rgb(59 59 58 / 0.35);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }

  .nav-logo-link {
    display: inline-flex;
    align-items: center;
  }
  .nav-logo {
    display: block;
    height: 1.9rem;
    width: auto;
  }

  /* ---- Desktop-Nav: erst ab 1280px (darunter Hamburger) ---- */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  @media (min-width: 1280px) {
    .nav-desktop {
      display: flex;
    }
  }

  /* ---- Menüpunkte — „Marker-Nav" (CD S. 29) ---- */
  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.4em 0.5em;
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #666665;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .nav-link__bg {
    position: absolute;
    inset: 0;
    background: var(--color-darkgrey);
    border-radius: 0.35em;
    transform: skewX(-8deg) scaleX(0);
    transform-origin: left center;
    transition:
      transform 0.28s cubic-bezier(0.65, 0, 0.35, 1),
      background-color 0.2s ease;
  }
  .nav-link__label {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
  }
  .nav-caret {
    opacity: 0.7;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .nav-link:hover {
      color: var(--color-black);
    }
    .nav-link:hover .nav-link__bg {
      transform: skewX(-8deg) scaleX(1);
    }
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
  }
  .nav-link.is-active {
    color: var(--color-black);
  }
  .nav-link.is-active .nav-link__bg {
    transform: skewX(-8deg) scaleX(1);
    background: var(--color-yellow);
  }

  /* ---- Über-uns-Dropdown ---- */
  .nav-dropdown {
    position: relative;
    display: inline-flex;
  }
  .nav-submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 11rem;
    padding: 0.4rem;
    display: flex;
    flex-direction: column;
    background: var(--color-offwhite);
    border: 1px solid rgb(59 59 58 / 0.08);
    border-radius: 0.9rem;
    box-shadow: 0 18px 40px -16px rgb(59 59 58 / 0.4);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s;
  }
  /* Öffnet bei Hover UND Tastatur-Fokus. Kleine Brücke (::before) verhindert, dass
     der Hover beim Weg zum Submenü abreißt. */
  .nav-dropdown::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 10px;
  }
  .nav-dropdown:hover .nav-submenu,
  .nav-dropdown:focus-within .nav-submenu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(2px);
  }
  .nav-dropdown:hover .nav-caret,
  .nav-dropdown:focus-within .nav-caret {
    transform: rotate(180deg);
  }
  .nav-subitem {
    padding: 0.5rem 0.7rem;
    border-radius: 0.55rem;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-black);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .nav-subitem:hover {
      background: var(--color-grey);
    }
  }
  .nav-subitem:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 1px;
  }

  /* ---- Sprachumschalter „DE | EN" (Nav-Variante B) ---- */
  .lang-switch {
    display: none;
    align-items: center;
    gap: 0.35rem;
  }
  @media (min-width: 1280px) {
    .lang-switch {
      display: inline-flex;
    }
  }
  .lang-opt {
    position: relative;
    padding: 0.15rem 0.05rem 0.2rem;
    font-weight: 400;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #666665;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  /* Dünne Linie (Hover) — Nav-Variante B. */
  .lang-opt::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.2s ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .lang-opt:hover {
      color: var(--color-black);
    }
    .lang-opt:hover::after {
      transform: scaleX(1);
    }
  }
  /* Aktive Sprache: Roboto Black + gelber Unterstrich (wie aktiver Nav-Punkt). */
  .lang-opt.is-active {
    font-weight: 900;
    color: var(--color-black);
  }
  .lang-opt.is-active::after {
    background: var(--color-yellow);
    transform: scaleX(1);
  }
  .lang-opt:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .lang-sep {
    color: var(--color-darkgrey);
    font-size: 0.8rem;
  }

  /* ---- Mobile-Menü: Hamburger-Trigger + Vollbild-Overlay (< 1280px = Burger-Range) ----
     Das Overlay ersetzt das frühere Dropdown-Panel im GESAMTEN Burger-Bereich (<1280).
