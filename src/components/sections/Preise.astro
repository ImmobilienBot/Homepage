---
/**
 * Preise — „Der Schalter". Gelbe Vollflächen-Sektion (#fff03c): links Argumente
 * (Eyebrow, H2 mit invertiertem Marker, Copy, vier Checks, 70-%-Stat, QR nur
 * Desktop), rechts eine weiße Karte mit Woche/Monat-Schalter, Preisblock, CTA und
 * Microcopy.
 *
 * Guardrails: Genau EINE H1 bleibt im Hero → hier H2. ALLE Zahlen (Preise, Tages-
 * preise, Spar-%) zur Buildzeit aus site.ts abgeleitet — nichts hart, kein Zahl-JS.
 * Beide Preise stehen immer im DOM (No-JS + Facts-Sync). Reveal-Startzustände nur
 * per gsap.set (initPreise) — ohne JS / reduced-motion alles im Endzustand. Store-
 * Routing via bestehende /go/app-Weiche (OS-Erkennung + UTM), wie beim QR.
 */
import { getLangFromUrl, useTranslations } from '../../i18n';
import { pricing, firstMonthSuccessRate } from '../../data/site';
import PillButton from '../ui/PillButton.astro';
import QrCode from '../QrCode.astro';
import StoreBadges from '../StoreBadges.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const P = t.sections.pricing;

const weekPlan = pricing.find((p) => p.id === 'week')!;
const monthPlan = pricing.find((p) => p.id === 'month')!;

// Preise ausschließlich aus site.ts, locale-abhängig via Intl formatiert.
const nf = (value: number, frac: number) =>
  new Intl.NumberFormat(lang === 'en' ? 'en-IE' : 'de-DE', {
    style: 'currency',
    currency: 'EUR',
    minimumFractionDigits: frac,
    maximumFractionDigits: frac,
  }).format(value);
const round2 = (n: number) => Math.round(n * 100) / 100;

const weekPrice = nf(weekPlan.priceValue, 2); // „2,99 €" / „€2.99"
const monthPrice = nf(monthPlan.priceValue, 2); // „7,99 €" / „€7.99"
// Tagespreis: Wochenpreis/7 bzw. Monatspreis/30, auf 2 Nachkommastellen (Intl → &nbsp; vor €).
const weekDay = P.day.replace('{price}', nf(round2(weekPlan.priceValue / 7), 2));
const monthDay = P.day.replace('{price}', nf(round2(monthPlan.priceValue / 30), 2));
// Spar-% = 1 − Monatspreis / (4 × Wochenpreis), gerundet (aktuell 33).
const savePct = Math.round((1 - monthPlan.priceValue / (4 * weekPlan.priceValue)) * 100);
const badge = P.badge.replace('{x}', String(savePct));
// 70-%-Stat aus site.ts; Quelle ² (Footer) wie in der Ablauf-Sektion.
const stat = P.stat.replace('{rate}', String(firstMonthSuccessRate));
const fnLabel = lang === 'en' ? 'Go to source' : 'Zur Quellenangabe';

// Buildzeit-Strings für den Schalter (JS erzeugt KEINE Zahlen, liest nur dieses JSON).
const toggleConfig = {
  week: { price: weekPrice, baseline: P.per.week, day: weekDay, desc: P.desc.week },
  month: { price: monthPrice, baseline: P.per.month, day: monthDay, desc: P.desc.month },
};

const CHECK_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="#fff03c" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5 10 17 19 7"/></svg>`;
---

<section id="preise" aria-labelledby="preise-h" class="pr2-section" data-pr2-section>
  <div class="pr2-inner">
    <div class="pr2-grid">
      {/* ================= INTRO (Eyebrow · H2 · Copy) =================
          DOM-Reihenfolge = mobile Lesereihenfolge: Intro → Karte → Rest. Desktop
          (≥960px) setzt die Blöcke per grid-template-areas zurück in die alte
          zweispaltige Anordnung (Intro+Rest links, Karte rechts, mittig) → visuell
          unverändert. Mobil steht so der Preis früh (H2 → Toggle/Karte → Vorteile). */}
      <div class="pr2-left pr2-intro">
        <p class="pr2-eyebrow" data-pr2-reveal>{P.eyebrow}</p>

        <h2 id="preise-h" class="pr2-h2">
          <span class="pr2-mask"><span class="pr2-line-in">{P.h2.line1}</span></span>
          <span class="pr2-mask"
            ><span class="pr2-line-in"
              ><span class="marker marker--dark"
                ><span class="marker__bg" aria-hidden="true"></span><span class="marker__label"
                  >{P.h2.line2}</span
                ></span
              ></span
            ></span
          >
          <span class="pr2-mask"><span class="pr2-line-in">{P.h2.line3}</span></span>
        </h2>

        <p class="pr2-copy" data-pr2-reveal>{P.copy}</p>
      </div>

      {/* ================= KARTE („Der Schalter") ================= */}
      <div class="pr2-card" data-pr2-card data-pr2 data-plan="month">
        {/* Schalter — Default MONAT (ohne JS vollständig korrekt). */}
        <div class="pr2-toggle" role="group" aria-label={P.toggleAria}>
          <span class="pr2-knob" data-pr2-knob aria-hidden="true"></span>
          <button type="button" class="pr2-tbtn" data-pr2-week aria-pressed="false">
            <span class="pr2-tbtn-label">{P.toggle.week}</span>
            <span class="pr2-tbtn-price">{weekPrice}</span>
          </button>
          <button type="button" class="pr2-tbtn" data-pr2-month aria-pressed="true">
            <span class="pr2-tbtn-label">{P.toggle.month}</span>
            <span class="pr2-tbtn-price">{monthPrice}</span>
          </button>
        </div>

        {/* Preisblock (aria-live: Zustandswechsel ansagen). */}
        <div class="pr2-live" aria-live="polite">
          <p class="pr2-priceblock">
            <span class="pr2-price" data-pr2-price>{monthPrice}</span>
            <span class="pr2-baseline" data-pr2-baseline>{P.per.month}</span>
          </p>
          <p class="pr2-day" data-pr2-day>{monthDay}</p>
          <p class="pr2-desc" data-pr2-desc>{P.desc.month}</p>
          <span class="pr2-badge" data-pr2-badge>{badge}</span>
        </div>

        <PillButton
          href="/go/app?c=preise_cta"
          surface="invert"
          size="md"
          block
          pulse
          class="pr2-cta"
          data-pr2-cta
        >
          {P.cta}
        </PillButton>

        <p class="pr2-micro">{P.micro}</p>

        {/* Buildzeit-Strings für den Schalter (kein Zahl-JS). */}
        <script type="application/json" data-pr2-config is:inline set:html={JSON.stringify(toggleConfig)} />
      </div>

      {/* ================= REST (Vorteile · Stat · App laden) ================= */}
      <div class="pr2-rest">
        <ul class="pr2-checks">
          {
            P.checks.map((c) => (
              <li class="pr2-check" data-pr2-reveal>
                <span class="pr2-check-ic" aria-hidden="true" set:html={CHECK_ICON} />
                <span class="pr2-check-tx">{c}</span>
              </li>
            ))
          }
        </ul>

        <p class="pr2-stat" data-pr2-reveal>
          {stat}
          <sup class="pr2-fn"><a href="#quellen" aria-label={fnLabel}>2</a></sup>
        </p>

        {/* App laden — Desktop: gemeinsame Floating-Karte (QR links · Hinweis + Badges
            rechts). Mobile: KEINE Karte, nur die Store-Badges (QR + Hinweis ausgeblendet). */}
        <div class="pr2-getapp" data-pr2-reveal>
          <div class="pr2-dlcard">
            <div class="pr2-qr">
              <QrCode
                campaign="preise_cta"
                size={116}
                surface="white"
                ariaLabel={
                  lang === 'en'
                    ? 'QR code: get the app — takes you to the right app store'
                    : 'QR-Code: App laden — führt zum passenden App-Store'
                }
              />
            </div>
            <div class="pr2-dlcard-right">
              <p class="pr2-dlhint">{P.qrCaption}</p>
              {/* Tracking pro Platzierung: iOS ct=Homepage_Pricing · Android utm_content=pricing. */}
              <StoreBadges position="Homepage_Pricing" androidPosition="pricing" class="pr2-badges" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Schalter-Island: liest nur die Buildzeit-Strings (data-pr2-config), tauscht Text
    // + Zustand. CSS treibt Knopf/Badge/Farben über [data-plan]. Ohne JS bleibt MONAT.
    const card = document.querySelector<HTMLElement>('[data-pr2]');
    if (card) {
      const cfgEl = card.querySelector('[data-pr2-config]');
      const cfg = cfgEl ? JSON.parse(cfgEl.textContent || '{}') : {};
      const week = card.querySelector<HTMLButtonElement>('[data-pr2-week]');
      const month = card.querySelector<HTMLButtonElement>('[data-pr2-month]');
      const priceEl = card.querySelector<HTMLElement>('[data-pr2-price]');
      const baseEl = card.querySelector<HTMLElement>('[data-pr2-baseline]');
      const dayEl = card.querySelector<HTMLElement>('[data-pr2-day]');
      const descEl = card.querySelector<HTMLElement>('[data-pr2-desc]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const apply = (plan: 'week' | 'month') => {
        const d = cfg[plan];
        if (!d || !priceEl || !baseEl || !dayEl || !descEl) return;
        priceEl.textContent = d.price;
        baseEl.textContent = d.baseline;
        dayEl.textContent = d.day;
        descEl.textContent = d.desc;
        week?.setAttribute('aria-pressed', String(plan === 'week'));
        month?.setAttribute('aria-pressed', String(plan === 'month'));
        card.dataset.plan = plan;
        // Preis-Pop (nur transform; reduced-motion: kein Pop).
        if (!reduce && priceEl.animate) {
          priceEl.animate(
            [{ transform: 'scale(1)' }, { transform: 'scale(1.12)' }, { transform: 'scale(1)' }],
            { duration: 160, easing: 'ease-out' },
          );
        }
      };
      week?.addEventListener('click', () => apply('week'));
      month?.addEventListener('click', () => apply('month'));
    }
  </script>
</section>

<style>
  /* =====================================================================
     Basis — gelbe Vollflächen-Sektion, Standard-Rhythmus + Content-Einschub.
     ===================================================================== */
  .pr2-section {
    position: relative;
    background-color: var(--color-yellow);
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
  }
  .pr2-inner {
    max-width: 72rem;
    margin-inline: auto;
  }
  .pr2-grid {
    display: grid;
    /* minmax(0,1fr): der einspaltige Track darf unter die Content-Min-Größe
       schrumpfen. Sonst bläht der H2-Marker (nowrap) den Track auf < 960px auf
       (v. a. EN „Everything included." als Phrasen-Marker) → horizontaler Overflow.
       Ab 960px überschreibt der Zwei-Spalten-Query diese Deklaration. */
    grid-template-columns: minmax(0, 1fr);
    gap: 40px;
    align-items: center;
  }
  /* Desktop: zwei Spalten (Argumente | Karte ~440px), vertikal zentriert. Intro und
     Rest liegen (via grid-areas) wieder gestapelt in der linken Spalte, die Karte
     rechts über beide Zeilen → optisch die alte einspaltige Argument-Kolumne. Der
     Row-Gap 18px entspricht exakt dem früheren .pr2-left-Flex-Gap → unverändert. */
  @media (min-width: 960px) {
    .pr2-grid {
      grid-template-columns: 1fr minmax(0, 440px);
      grid-template-areas:
        'intro card'
        'rest card';
      column-gap: 72px;
      row-gap: 18px;
    }
    .pr2-intro {
      grid-area: intro;
    }
    .pr2-rest {
      grid-area: rest;
    }
    .pr2-card {
      grid-area: card;
    }
  }

  /* =====================================================================
     Links — Argument-Stack (Intro + Rest teilen dieselbe Spalten-Optik).
     ===================================================================== */
  .pr2-left,
  .pr2-rest {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }
  /* Eyebrow: opacity zugunsten AA angehoben (auf reinem Gelb bleibt .55 unter 4.5:1). */
  .pr2-eyebrow {
    margin: 0;
    font-weight: 900;
    font-size: 13px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-black);
    opacity: 0.78;
  }
  .pr2-h2 {
    margin: 0;
    font-weight: 900;
    font-size: clamp(2.1rem, 5.4vw, 3.75rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-black);
  }
  /* Zeilen-Mask (Reveal klippt nur die einfahrende Zeile). */
  .pr2-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.08em;
    margin-block: -0.08em;
  }
  .pr2-line-in {
    display: inline-block;
    will-change: transform;
  }
  .pr2-copy {
    margin: 0;
    max-width: 420px;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.55;
    color: var(--color-black);
  }
  .pr2-checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pr2-check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-black);
  }
  .pr2-check-ic {
    flex: none;
    width: 20px;
    height: 20px;
    border-radius: 999px;
    background: var(--color-black);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .pr2-check-ic :global(svg) {
    width: 12px;
    height: 12px;
    display: block;
  }
  .pr2-stat {
    margin: 0;
    max-width: 420px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--color-black);
  }
  .pr2-fn {
    font-size: 0.6em;
    vertical-align: super;
    line-height: 0;
    margin-left: 0.1em;
  }
  .pr2-fn a {
    color: inherit;
    text-decoration: none;
  }
  .pr2-fn a:hover,
  .pr2-fn a:focus-visible {
    text-decoration: underline;
  }
  /* App-laden-Block. Mobile: KEINE Karte — nur die Badges (QR + Hinweis aus). */
  .pr2-getapp {
    margin-top: 4px;
  }
  .pr2-badges {
    --badge-h: 2.5rem;
  }
  .pr2-qr,
  .pr2-dlhint {
    display: none;
  }
  /* Desktop: gemeinsame Floating-Karte (Stil der Preis-Kacheln: off-white, Radius,
     weiche Elevation). Grid: QR (auto) | rechte Spalte (1fr), zentriert. */
  @media (min-width: 960px) {
    .pr2-dlcard {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 24px;
      align-items: center;
      background: var(--color-offwhite);
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 24px 60px rgb(59 59 58 / 0.18);
    }
    .pr2-qr {
      display: block;
    }
    .pr2-dlcard-right {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .pr2-dlhint {
      display: block;
      margin: 0;
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      line-height: 1.4;
      text-align: left;
      color: var(--color-black);
    }
  }

  /* =====================================================================
     Rechts — die Karte (weiß auf Gelb).
     ===================================================================== */
  .pr2-card {
    width: 100%;
    max-width: 440px;
    margin-inline: auto;
    background: var(--color-offwhite);
    border-radius: 24px;
    padding: 30px;
    box-shadow: 0 24px 60px rgb(59 59 58 / 0.18);
  }
  @media (min-width: 960px) {
    .pr2-card {
      margin-inline: 0;
      justify-self: end;
    }
  }

  /* ---- Schalter ---- */
  .pr2-toggle {
    position: relative;
    display: flex;
    background: var(--color-black);
    border-radius: 999px;
    padding: 5px;
  }
  .pr2-knob {
    position: absolute;
    top: 5px;
    bottom: 5px;
    left: 5px;
    width: calc(50% - 5px);
    border-radius: 999px;
    background: var(--color-yellow);
    z-index: 0;
    transition: transform 0.35s cubic-bezier(0.3, 1.5, 0.5, 1);
  }
  [data-plan='month'] .pr2-knob {
    transform: translateX(100%);
  }
  [data-plan='week'] .pr2-knob {
    transform: translateX(0);
  }
  .pr2-tbtn {
    position: relative;
    z-index: 1;
    flex: 1;
    min-height: 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    padding: 6px 8px;
    border: 0;
    background: transparent;
    border-radius: 999px;
    cursor: pointer;
    font-family: var(--font-sans);
    color: var(--color-offwhite);
    transition: color 0.25s ease;
  }
  .pr2-tbtn-label {
    font-size: 15px;
    font-weight: 900;
  }
  .pr2-tbtn-price {
    font-size: 11.5px;
    font-weight: 700;
  }
  /* Aktiver Button (auf gelbem Knopf) dunkel, inaktiver hell (Preiszeile gedämpft). */
  [data-plan='month'] [data-pr2-month],
  [data-plan='week'] [data-pr2-week] {
    color: var(--color-black);
  }
  .pr2-tbtn[aria-pressed='false'] .pr2-tbtn-price {
    opacity: 0.7;
  }
  .pr2-tbtn:focus-visible {
    outline: 2px solid var(--color-offwhite);
    outline-offset: 2px;
  }

  /* ---- Preisblock ---- */
  .pr2-live {
    text-align: center;
    margin-top: 24px;
  }
  .pr2-priceblock {
    margin: 0;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
  }
  .pr2-price {
    font-weight: 900;
    font-size: clamp(48px, 10vw, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-black);
    font-variant-numeric: tabular-nums;
    transform-origin: center;
    display: inline-block;
  }
  .pr2-baseline {
    font-size: 17px;
    font-weight: 700;
    /* AA: gedämpftes, geprüftes Grau statt 60 %-Opacity auf Weiß. */
    color: var(--color-grey-text);
  }
  .pr2-day {
    margin: 8px 0 0;
    font-size: 15px;
    font-weight: 900;
    color: var(--color-black);
  }
  .pr2-desc {
    margin: 8px 0 0;
    font-size: 13.5px;
    line-height: 1.4;
    color: var(--color-grey-text);
  }
  .pr2-badge {
    display: inline-block;
    margin-top: 14px;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--color-black);
    color: var(--color-yellow);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transform-origin: center;
    transition:
      transform 0.3s cubic-bezier(0.3, 1.6, 0.5, 1),
      opacity 0.3s cubic-bezier(0.3, 1.6, 0.5, 1);
  }
  /* Badge nur bei Monat sichtbar. */
  [data-plan='week'] .pr2-badge {
    transform: scale(0);
    opacity: 0;
  }

  /* ---- CTA + Microcopy ---- */
  .pr2-cta {
    margin-top: 24px;
  }
  .pr2-micro {
    margin: 14px 0 0;
    text-align: center;
    font-size: 12px;
    line-height: 1.45;
    /* AA: geprüftes Grau statt 65 %-Opacity. */
    color: var(--color-grey-text);
  }

  /* =====================================================================
     Mobile — einspaltig, kompaktere Karte.
     ===================================================================== */
  @media (max-width: 767.98px) {
    .pr2-card {
      padding: 24px;
    }
    /* „Preis zuerst": Preisbetrag mobil dominanter (moderat angehoben), da die Karte
       jetzt früh (direkt nach der H2) steht und der Preis der Ankerpunkt ist. */
    .pr2-price {
      font-size: clamp(52px, 15vw, 64px);
    }
    /* Backstop: H2 nie breiter als seine (einspaltige) Spalte — die Zeilen-Masks
       klippen etwaigen Rest. Greift nur, falls ein Zeilen-Marker die Spalte
       überragt (s. u. Font-Reduktion auf sehr schmalen Screens). */
    .pr2-h2 {
      max-width: 100%;
    }
  }
  /* Sehr schmale Phones (≤360px): der Phrasen-Marker der H2-Zeile 2 ist nowrap
     (Marker-Geometrie) — in EN „Everything included." ~297px bei 33,6px Schrift und
     sprengt die 272px-Spalte bei 320px. Headline hier dezent kleiner setzen, damit
     die längste Marker-Zeile in die Spalte passt (statt geklippt zu werden). DE
     („Alles drin.") ist kurz und bleibt ohnehin unauffällig. Ab 361px volle Größe. */
  @media (max-width: 360px) {
    .pr2-h2 {
      font-size: 1.75rem;
    }
  }

  /* =====================================================================
     prefers-reduced-motion — Zustandswechsel instant (kein Knopf-Slide, kein Badge-
     Pop). Der Puls-Dot + Preis-Pop sind separat gegated (PillButton bzw. JS).
     ===================================================================== */
  @media (prefers-reduced-motion: reduce) {
    .pr2-knob,
    .pr2-badge,
    .pr2-tbtn,
    .pr2-line-in {
      transition: none;
    }
  }
</style>
