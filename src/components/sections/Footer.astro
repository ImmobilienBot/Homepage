---
/**
 * Footer — letzter Block des One-Pagers, conversion-fokussiert (Store-CTAs).
 * CD-Grau (#eaebeb), Text CD-Schwarz (#3b3b3a). Desktop 4-spaltig (Rechtliches ·
 * Mehr · Sprache · Store-Badges + Copyright), Mobile 1-spaltig gestapelt.
 *
 * Statisch (keine Animationen). Texte aus i18n, Store-Links via <StoreBadges> mit
 * ct=footer. Der Quellen-Fußnotenblock (#quellen / #quelle-statistik) MUSS erhalten
 * bleiben — Problem-, Ablauf- und Preise-Sektion verankern dorthin.
 */
import { getLangFromUrl, useTranslations, switchLangHref, languages } from '../../i18n';
import type { Locale } from '../../data/site';
import StoreBadges from '../StoreBadges.astro';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const F = t.footer;

// Rechtliches — DE-only (kein EN-Pendant). Der EN-Footer verlinkt dieselben
// DE-Seiten mit dem Zusatz „(German)".
const legalSuffix = lang === 'en' ? ' (German)' : '';
const legalLinks = [
  { label: F.imprint + legalSuffix, href: '/impressum' },
  { label: F.privacy + legalSuffix, href: '/datenschutz' },
  { label: F.terms + legalSuffix, href: '/agb' },
];

// Sprachumschalter: beide Sprachen als Links (Sprach-Pendant der aktuellen Seite;
// übersetzte Slugs + DE-only-Seiten via switchLangHref).
const deHref = switchLangHref(Astro.url.pathname, 'de');
const enHref = switchLangHref(Astro.url.pathname, 'en');
---

<footer class="footer bg-grey px-inset pt-14 pb-8 text-black">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 items-start gap-10 sm:grid-cols-4 sm:gap-8">
      {/* Spalte 1 — Rechtliches */}
      <nav class="footer-col" aria-label={F.colLegal}>
        <p class="footer-label">{F.colLegal}</p>
        <ul class="footer-list">
          {legalLinks.map((l) => (
            <li>
              <a class="footer-link" href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Spalte 2 — Mehr */}
      <nav class="footer-col" aria-label={F.colMore}>
        <p class="footer-label">{F.colMore}</p>
        <ul class="footer-list">
          <li><a class="footer-link" href="/blog">{F.blog}</a></li>
        </ul>
      </nav>

      {/* Spalte 3 — Sprache */}
      <nav class="footer-col" aria-label={F.colLang}>
        <p class="footer-label">{F.colLang}</p>
        <p class="footer-lang">
          <a
            class="footer-link"
            href={deHref}
            hreflang="de"
            aria-current={lang === 'de' ? 'true' : undefined}
          >{languages.de}</a>
          <span class="footer-lang-sep" aria-hidden="true">·</span>
          <a
            class="footer-link"
            href={enHref}
            hreflang="en"
            aria-current={lang === 'en' ? 'true' : undefined}
          >{languages.en}</a>
        </p>
      </nav>

      {/* Spalte 4 — App laden: Label + Store-Badges + Copyright */}
      <section class="footer-col footer-col--badges" aria-label={F.colApp}>
        <p class="footer-label">{F.colApp}</p>
        <StoreBadges position="footer" class="footer-badges" />
        <p class="footer-copy">
          {F.copyright}<br />
          <span class="footer-tagline">{F.signature}</span>
        </p>
      </section>
    </div>

    {/* Quellen-Fußnoten — Anker #quellen / #quelle-statistik (nicht entfernen). */}
    <div class="footer-sources" id="quellen">
      {
        F.sources.map((s, i) => (
          <p class="footer-source" id={i === 0 ? 'quelle-statistik' : undefined}>
            <sup class="footer-source-num">{i + 1}</sup> {s}
          </p>
        ))
      }
    </div>
  </div>
</footer>

<style>
  .footer {
    font-size: 14px;
    line-height: 1.2;
  }
  /* Platz für die fixierte Smart-App-Bar (< lg): Höhe ~64px + 12px Abstand +
     Safe-Area, damit im Übergang kein Footer-Inhalt verdeckt wird. Desktop
     ≥1024px unverändert (Bar existiert dort nicht). */
  @media (max-width: 1023.98px) {
    .footer {
      /* env() MIT Fallback (sonst wäre die ganze calc()-Deklaration ohne env()-
         Support ungültig → kein Platz für die Smart-Bar). */
      padding-bottom: calc(2rem + 76px + env(safe-area-inset-bottom, 0px));
    }
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 16px; /* Label → Inhalt in allen Spalten identisch (mt-4) */
  }
  /* kleines Spalten-Label (bewusst KEIN Heading) */
  .footer-label {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-grey-text); /* AA-sicheres Grau auf #eaebeb (≥4,6:1) */
  }
  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-link {
    color: var(--color-black);
    text-decoration: none;
  }
  .footer-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer-link:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .footer-link[aria-current='true'] {
    font-weight: 700;
  }
  .footer-lang {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-lang-sep {
    color: var(--color-grey-text);
  }

  /* Spalte 4 — Badge-Höhe exakt 40px (wie Header-Format).
     !important schlägt die (höher spezifische, gescopte) Default-Var der Komponente. */
  :global(.footer-badges) {
    --badge-h: 2.5rem !important; /* 40px */
  }
  .footer-copy {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--color-grey-text);
  }
  .footer-tagline {
    font-style: italic;
  }

  /* Mobile-Pass (< 640px, gestapelt): Link-Zeilen auf volle 44px-Tap-Höhe. Greift
     NUR im 1-spaltigen Stapel — die 4-spaltige Anlage ab sm (≥640px, inkl. ≥1024px)
     bleibt kompakt/unverändert. */
  @media (max-width: 639.98px) {
    .footer-list {
      gap: 2px;
    }
    .footer-list .footer-link,
    .footer-lang .footer-link {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }

  /* Quellen-Fußnoten — dezent unter dem Grid, volle Breite. */
  .footer-sources {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--color-darkgrey);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-source {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--color-grey-text);
  }
  .footer-source-num {
    font-size: 0.85em;
    vertical-align: super;
    line-height: 0;
    margin-right: 0.15em;
  }
</style>
