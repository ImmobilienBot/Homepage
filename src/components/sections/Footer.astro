---
/**
 * Footer — Impressum · Datenschutz · AGB · Kontakt · Sprachumschalter · Store-Badges.
 * [Platzhalter-Struktur — finales Design folgt.]
 */
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  defaultLang,
} from '../../i18n';
import { site } from '../../data/site';
import type { Locale } from '../../data/site';
import Logo from '../../assets/images/immobilien-bot-logo.svg';

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang: Locale = lang === 'de' ? 'en' : 'de';
const home = localizePath('/', lang);
const base = home === '/' ? '' : home.replace(/\/$/, '');

const legalLinks = [
  { label: t.footer.imprint, href: localizePath('/impressum', lang) },
  { label: t.footer.privacy, href: localizePath('/datenschutz', lang) },
  { label: t.footer.terms, href: localizePath('/agb', lang) },
  { label: t.footer.contact, href: `${base}/#kontakt` },
];

const switchHref = localizePath(Astro.url.pathname, otherLang);
---

<footer class="bg-black px-inset py-12 text-offwhite">
  <div class="mx-auto flex max-w-6xl flex-col gap-8">
    <a href={home} class="footer-logo-link" aria-label={`${site.name} – Startseite`}>
      <Logo class="footer-logo" aria-hidden="true" />
    </a>

    <div
      class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
    >
      <nav class="flex flex-wrap gap-x-6 gap-y-2 text-body">
        {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        <a href={switchHref} hreflang={otherLang}>{t.footer.langSwitch}</a>
      </nav>

      {/* Store-Badges (Platzhalter) */}
      <div class="flex gap-3 text-body opacity-70">
        <span>[App Store Badge]</span>
        <span>[Google Play Badge]</span>
      </div>
    </div>

    <p class="text-body opacity-60">© {site.name} · {t.footer.signature}</p>

    {/* Fußnote zur Berlin-Statistik (Sternchen in der Problem-Story).
        TODO: „Berliner Zeitung" später mit dem echten Quell-Link versehen. */}
    <p class="footer-source" id="quelle-statistik">{t.footer.sourceNote}</p>
  </div>
</footer>

<style>
  .footer-logo-link {
    display: inline-flex;
    align-items: center;
  }
  .footer-logo {
    display: block;
    height: 2rem;
    width: auto;
    /* Logo ist CD-Schwarz → für den dunklen Footer auf Offwhite umfärben. */
    filter: brightness(0) invert(1);
    opacity: 0.92;
  }
  /* Kleine Quellen-Fußnote (Statistik-Sternchen). */
  .footer-source {
    font-size: 0.75rem;
    opacity: 0.5;
    letter-spacing: 0.01em;
  }
</style>
