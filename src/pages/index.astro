---
/**
 * Startseite DE (auf /).
 * Sektionen in der Reihenfolge:
 * Hero → Problem → Portale → Features → Ablauf → Bewertungen → Preise
 * → FAQ → Kontakt. (Header/Footer via BaseLayout.)
 * Portale folgt direkt auf die Problem-Sektion = erste konkrete Antwort
 * (der „Wir zeigen dir wie ↓"-Verweis der Problem-Sektion zeigt auf #portale).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';
import Hero from '../components/sections/Hero.astro';
import ProblemLoesung from '../components/sections/ProblemLoesung.astro';
import Features from '../components/sections/Features.astro';
import Portale from '../components/sections/Portale.astro';
import Ablauf from '../components/sections/Ablauf.astro';
import Bewertungen from '../components/sections/Bewertungen.astro';
import Preise from '../components/sections/Preise.astro';
import FAQ from '../components/sections/FAQ.astro';
import Kontakt from '../components/sections/Kontakt.astro';

const t = useTranslations('de');
---

<BaseLayout title={t.meta.title} description={t.meta.description}>
  <Hero />
  <ProblemLoesung />
  <Portale />
  <Features />
  <Ablauf />
  <Bewertungen />
  <Preise />
  <FAQ />
  <Kontakt />
</BaseLayout>
