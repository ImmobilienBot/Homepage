---
/**
 * BaseLayout.astro — Grundgerüst aller Seiten.
 * <head> (inkl. GTM-Platzhalter + SEO.astro), Header + Footer als Chrome,
 * globales CSS, Roboto, Consent/GTM-Platzhalter und die Animations-Skripte
 * (Lenis + GSAP), die prefers-reduced-motion respektieren.
 */
// Roboto (CD-Schrift) selbst gehostet via @fontsource — kein Google-Fonts-CDN
// (garantiertes Laden + DSGVO-konform, KEIN render-blockender externer Request).
// Nur Latin-Subset (DE/EN), Gewichte 400/500/700/900; font-display: swap.
import '@fontsource/roboto/latin-400.css';
import '@fontsource/roboto/latin-500.css';
import '@fontsource/roboto/latin-700.css';
import '@fontsource/roboto/latin-900.css';
// Das für die Hero-Headline genutzte Gewicht (900/Black) preloaden → Font ist
// vor dem First Paint da, der swap verursacht KEINEN Layout-Shift (Desktop-CLS ~0).
import robotoBlackWoff2 from '@fontsource/roboto/files/roboto-latin-900-normal.woff2?url';
import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import { GTM_ID } from '../data/site';
import { getLangFromUrl, useTranslations, hreflangCodes } from '../i18n';
import type { Locale } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** DE-only-Seite (Rechtsseiten): kein hreflang-Paar. */
  standalone?: boolean;
  /** Zusätzliche JSON-LD-Knoten (z. B. AboutPage) → an den @graph. */
  extraJsonLd?: unknown[];
}

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description, canonical, ogImage, noindex, standalone, extraJsonLd } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/* Roboto Black (Hero-Headline) früh preloaden → kein Font-Swap-Shift. */}
    <link
      rel="preload"
      href={robotoBlackWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {/* Markiert JS-Verfügbarkeit synchron (vor dem ersten Paint), damit
        Animations-Anfangszustände nur bei aktivem JS versteckt werden —
        ohne JS bleiben Inhalte sichtbar. */}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    {/* ---- Consent-Banner-Platzhalter (CookieYes) ----
        TODO(CLAUDE.md): CookieYes-Snippet im <head>, mit Consent Mode v2
        verknüpft. Default „denied" bis Einwilligung. */}
    {/* <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/XXXX/script.js"></script> */}

    {/* ---- Google Consent Mode v2 (Default: denied) ---- */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
    </script>

    {/* ---- Google Tag Manager (Platzhalter — echte ID via site.ts) ---- */}
    <script is:inline define:vars={{ GTM_ID }}>
      (function (w, d, s, l, i) {
        if (!i || i.indexOf('XXXX') !== -1) return; // Platzhalter-ID → nicht feuern
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', GTM_ID);
    </script>

    {/* Roboto wird selbst gehostet (siehe @fontsource-Imports oben) —
        kein externer Font-Request. */}

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
      lang={lang}
      standalone={standalone}
      extraJsonLd={extraJsonLd}
    />
  </head>

  <body class="min-h-screen flex flex-col">
    {/* ---- GTM noscript-Fallback ---- */}
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="gtm"></iframe>
    </noscript>

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-yellow focus:text-black focus:px-4 focus:py-2 focus:rounded-pill"
    >
      {t.nav.skipToContent}
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    {/* ---- Eigener Cursor (Signature-Moment) ----
        Nur aktiv bei (pointer:fine) und ohne prefers-reduced-motion — wird per
        JS in animations.ts angesteuert; sonst nativer Cursor. */}
    <div class="cursor" aria-hidden="true">
      {/* Alle drei sind reine Helligkeits-Invert-Linsen (grayscale→invert), auf jedem
          Hintergrund sichtbar. Lupe = Hover-Zustand in voller nativer Größe. */}
      <div class="cursor-lupe" data-cursor-lupe></div>
      <div class="cursor-ring" data-cursor-ring></div>
      <div class="cursor-dot" data-cursor-dot></div>
      {/* Mitlaufendes gelbes Pill-Label (Store-Badges) — KEINE Linse, unverändert. */}
      <div class="cursor-label" data-cursor-label-el></div>
    </div>

    {/* ---- Animations-Skripte: Lenis (Smooth Scroll) + GSAP/ScrollTrigger ----
        Nur clientseitig, respektiert prefers-reduced-motion. */}
    <script>
      import '../scripts/animations';
    </script>
  </body>
</html>
