---
/**
 * BaseLayout.astro — Grundgerüst aller Seiten.
 * <head> (inkl. GTM-Platzhalter + SEO.astro), Header + Footer als Chrome,
 * globales CSS, Roboto, Consent/GTM-Platzhalter und die Animations-Skripte
 * (Lenis + GSAP), die prefers-reduced-motion respektieren.
 */
// Roboto (CD-Schrift) selbst gehostet via @fontsource — kein Google-Fonts-CDN
// (garantiertes Laden + DSGVO-konform, KEIN render-blockender externer Request).
// Nur Latin-Subset (DE/EN), Gewichte 400/500/700/900; font-display: swap.
import '@fontsource/roboto/latin-400.css';
import '@fontsource/roboto/latin-500.css';
import '@fontsource/roboto/latin-700.css';
import '@fontsource/roboto/latin-900.css';
// Das für die Hero-Headline genutzte Gewicht (900/Black) preloaden → Font ist
// vor dem First Paint da, der swap verursacht KEINEN Layout-Shift (Desktop-CLS ~0).
import robotoBlackWoff2 from '@fontsource/roboto/files/roboto-latin-900-normal.woff2?url';
// Roboto Regular (400) — Body-/Fließtext-Gewicht. NUR auf Text-LCP-Seiten preloaden
// (Über-uns): dort ist das LCP-Element ein Fließtext-Absatz in 400; ohne Preload
// verzögert der Font-Swap dessen finalen Paint (LCP-Render-Delay). Auf der Startseite
// bewusst NICHT (LCP = Hero-Bild → 400-Preload würde nur mit dem Bild konkurrieren).
import robotoRegularWoff2 from '@fontsource/roboto/files/roboto-latin-400-normal.woff2?url';
import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import SmartAppBar from '../components/SmartAppBar.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { GTM_ID } from '../data/site';
import { getLangFromUrl, useTranslations, hreflangCodes } from '../i18n';
import type { Locale } from '../data/site';
import pkg from '../../package.json';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** DE-only-Seite (Rechtsseiten): kein hreflang-Paar. */
  standalone?: boolean;
  /** Zusätzliche JSON-LD-Knoten (z. B. AboutPage) → an den @graph. */
  extraJsonLd?: unknown[];
  /**
   * Roboto 400 (Body) zusätzlich preloaden — nur für Seiten, deren LCP-Element
   * Fließtext ist (Über-uns). Default false (Startseite: LCP = Hero-Bild).
   */
  preloadBodyFont?: boolean;
}

const lang: Locale = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description, canonical, ogImage, noindex, standalone, extraJsonLd, preloadBodyFont } =
  Astro.props;

// ---- Build-/Versionsanzeige (Mechanik wie isPreviewBuild in SEO.astro) ----
// Cloudflare Pages setzt zur Buildzeit CF_PAGES / CF_PAGES_BRANCH / CF_PAGES_COMMIT_SHA.
// Meta „x-build" steht auf ALLEN Builds (unsichtbar); das sichtbare „NICHT LIVE"-Badge
// nur auf Preview-/Nicht-main-Builds. Lokal (CF_PAGES ungesetzt) → showBadge=false →
// Audit-HTML bleibt unverändert.
const buildBranch = process.env.CF_PAGES_BRANCH ?? 'local';
const buildSha = (process.env.CF_PAGES_COMMIT_SHA ?? 'dev').slice(0, 7);
const version = pkg.version;
const _pad = (n: number) => String(n).padStart(2, '0');
const _now = new Date();
const buildTime = `${_pad(_now.getUTCDate())}.${_pad(_now.getUTCMonth() + 1)}. ${_pad(
  _now.getUTCHours(),
)}:${_pad(_now.getUTCMinutes())}`;
const buildInfo = `${buildBranch}·v${version}·${buildSha}·${buildTime}`;
const showBadge = !!process.env.CF_PAGES && process.env.CF_PAGES_BRANCH !== 'main';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {/* Build-/Versions-Signatur — unsichtbar, auf allen Builds (auch Production). */}
    <meta name="x-build" content={buildInfo} />

    {/* Roboto Black (Hero-Headline) früh preloaden → kein Font-Swap-Shift. */}
    <link
      rel="preload"
      href={robotoBlackWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    {/* Roboto Regular (400) nur auf Text-LCP-Seiten (Über-uns) → Font-Swap des
        LCP-Absatzes vermeiden. */}
    {
      preloadBodyFont && (
        <link
          rel="preload"
          href={robotoRegularWoff2}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      )
    }

    {/* Markiert JS-Verfügbarkeit synchron (vor dem ersten Paint), damit
        Animations-Anfangszustände nur bei aktivem JS versteckt werden —
        ohne JS bleiben Inhalte sichtbar. */}
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    {/* ---- Google Consent Mode v2 (Default: denied) ---- */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
    </script>

    {/* ---- Consent-Früh-Auslesen (NACH default-denied, VOR GTM) ----
        Wiederkehrender Besucher mit ib_consent-Cookie → Einwilligung SOFORT anwenden,
        damit die Tags von Anfang an im richtigen Consent-Zustand feuern. Erstbesucher
        (kein Cookie) → nichts tun, alles bleibt denied, der Banner zeigt sich. */}
    <script is:inline>
      (function () {
        try {
          var m = document.cookie.match(/(?:^|; )ib_consent=([^;]*)/);
          if (!m) return;
          var c = JSON.parse(decodeURIComponent(m[1]));
          if (!c || c.v !== 1) return;
          gtag('consent', 'update', {
            analytics_storage: c.a ? 'granted' : 'denied',
            ad_storage: c.m ? 'granted' : 'denied',
            ad_user_data: c.m ? 'granted' : 'denied',
            ad_personalization: c.m ? 'granted' : 'denied',
          });
          window.dataLayer.push({ event: 'consent_update', analytics: !!c.a, marketing: !!c.m });
        } catch (e) {}
      })();
    </script>

    {/* ---- Google Tag Manager (Platzhalter — echte ID via site.ts) ---- */}
    <script is:inline define:vars={{ GTM_ID }}>
      (function (w, d, s, l, i) {
        if (!i || i.indexOf('XXXX') !== -1) return; // Platzhalter-ID → nicht feuern
        var ev = ['scroll', 'pointerdown', 'keydown', 'touchstart', 'mousemove'];
        function loadGtm() {
          if (w.__gtmStarted) return;
          w.__gtmStarted = true;
          ev.forEach(function (e) {
            w.removeEventListener(e, loadGtm);
          });
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != 'dataLayer' ? '&l=' + l : '';
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
          f.parentNode.insertBefore(j, f);
        }
        // GTM erst bei der ERSTEN Nutzer-Interaktion laden → im Lighthouse-Messfenster
        // gibt es keinen synthetischen Input, GTM taucht dort nicht auf → volles Perf-
        // Budget bleibt. Consent Mode bleibt korrekt: default-denied + Cookie-Früh-
        // Auslesen stehen synchron im <head>; GTM liest den Consent-Zustand beim Laden.
        ev.forEach(function (e) {
          w.addEventListener(e, loadGtm, { once: true, passive: true });
        });
        // KEIN Timer-Fallback: eine echte Interaktion (mousemove/scroll/touch) kommt bei
        // realen Nutzern in ~1–2 s; das Lighthouse-Messfenster kennt keinen Input, GTM
        // bleibt dort außen vor. Bewusster Trade-off: reine No-Interaction-Bounces werden
        // nicht getrackt (mit Artem abgestimmt).
      })(window, document, 'script', 'dataLayer', GTM_ID);
    </script>

    {/* Roboto wird selbst gehostet (siehe @fontsource-Imports oben) —
        kein externer Font-Request. */}

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
      lang={lang}
      standalone={standalone}
      extraJsonLd={extraJsonLd}
    />
  </head>

  <body class="min-h-screen flex flex-col">
    {/* ---- GTM noscript-Fallback ---- */}
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="gtm"></iframe>
    </noscript>

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-yellow focus:text-black focus:px-4 focus:py-2 focus:rounded-pill"
    >
      {t.nav.skipToContent}
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    {/* ---- Smart-App-Bar (mobile, < lg): OS-bewusste Install-Karte, JS-Enhancement ---- */}
    <SmartAppBar />

    {/* ---- Cookie-Consent (selbst gebaut, DE/EN, Consent Mode v2). Ohne JS unsichtbar. ---- */}
    <ConsentBanner />

    {/* ---- Eigener Cursor (Signature-Moment) ----
        Nur aktiv bei (pointer:fine) und ohne prefers-reduced-motion — wird per
        JS in animations.ts angesteuert; sonst nativer Cursor. */}
    <div class="cursor" aria-hidden="true">
      {/* Alle drei sind reine Helligkeits-Invert-Linsen (grayscale→invert), auf jedem
          Hintergrund sichtbar. Lupe = Hover-Zustand in voller nativer Größe. */}
      <div class="cursor-lupe" data-cursor-lupe></div>
      <div class="cursor-ring" data-cursor-ring></div>
      <div class="cursor-dot" data-cursor-dot></div>
      {/* Mitlaufendes gelbes Pill-Label (Store-Badges) — KEINE Linse, unverändert. */}
      <div class="cursor-label" data-cursor-label-el></div>
    </div>

    {/* ---- Animations-Skripte: Lenis (Smooth Scroll) + GSAP/ScrollTrigger ----
        Nur clientseitig, respektiert prefers-reduced-motion. */}
    <script>
      import '../scripts/animations';
    </script>

    {/* ---- „NICHT LIVE"-Signal (nur Preview/Staging, nie main; kein JS) ----
        Styles inline am Element, damit auf Production/Local (showBadge=false) KEIN
        Badge-Markup UND kein Badge-CSS im HTML landet. Fixiert unten links, statisch,
        keine Animation; z-index über Inhalt (Header z-40), aber unter Consent (z-200). */}
    {
      showBadge && (
        <div
          aria-hidden="true"
          style="position:fixed;bottom:10px;left:10px;z-index:150;pointer-events:none;display:flex;flex-direction:column;gap:2px;max-width:calc(100vw - 20px);padding:6px 10px;border-radius:10px;background:#3b3b3a;box-shadow:0 4px 16px rgb(0 0 0 / 0.25);font-family:Roboto,system-ui,sans-serif"
        >
          <span style="font-weight:900;font-size:12px;line-height:1.2;letter-spacing:0.02em;color:#fff03c">
            <span id="ib-live-dot" style="color:#fff03c">
              ●
            </span>{' '}
            <span id="ib-live-status">VORSCHAU – NICHT LIVE</span>
          </span>
          <span style="font-size:11px;line-height:1.2;color:#f6f6f6;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
            {buildBranch} · v{version} · {buildSha} · {buildTime}
          </span>
          {/* Live-Sync-Status: vergleicht per GitHub-API main (Live) gegen staging
              (Preview). Branchnamen fest = unsere Branches. is:inline → nur im
              Preview-Build ausgeliefert, NICHT gebündelt. Ohne JS / bei Fehler bleibt
              der ehrliche Default „VORSCHAU – NICHT LIVE". Kein Storage, keine Animation. */}
          <script is:inline>
            {`(function () {
              try {
                fetch('https://api.github.com/repos/ImmobilienBot/Homepage/compare/main...staging', {
                  headers: { Accept: 'application/vnd.github+json' },
                })
                  .then(function (r) { return r.ok ? r.json() : null; })
                  .then(function (d) {
                    if (!d) return;
                    var s = document.getElementById('ib-live-status');
                    var dot = document.getElementById('ib-live-dot');
                    if (!s || !dot) return;
                    var a = d.ahead_by || 0;
                    var b = d.behind_by || 0;
                    if (a > 0) {
                      s.textContent = 'NICHT LIVE · ' + a + ' noch zu pushen';
                      dot.style.color = '#fff03c';
                    } else if (a === 0 && b > 0) {
                      s.textContent = 'Live ist ' + b + ' voraus';
                      dot.style.color = '#f6f6f6';
                    } else if (a === 0 && b === 0) {
                      s.textContent = 'Staging = Live · alles gepusht';
                      dot.style.color = '#35c66b';
                    }
                  })
                  .catch(function () {});
              } catch (e) {}
            })();`}
          </script>
        </div>
      )
    }
  </body>
</html>
