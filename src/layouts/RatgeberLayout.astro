---
/**
 * RatgeberLayout.astro — Layout der SEO-migrierten Ratgeber-Artikel.
 *
 * Standard-Header/-Footer (via BaseLayout), Lesebreite ~72ch, CD-Typografie,
 * genau EINE H1 (= Artikel-Title; der Markdown-Body nutzt ##/### → H2/H3).
 * DE-only → `standalone` (kein hreflang-Paar), Canonical = Astro.url (Trailing
 * Slash, wie die Quelle). Am Ende: gelbe CTA-Box + „Weitere Ratgeber" (interne
 * Verlinkung). Article-JSON-LD; author/publisher = Organization aus site.ts.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import StoreBadges from '../components/StoreBadges.astro';
import { useTranslations } from '../i18n';
import { site } from '../data/site';

interface RelatedPost {
  title: string;
  path: string;
}
interface Props {
  title: string;
  metaTitle: string;
  description: string;
  path: string;
  pubDate: string;
  datetime: string;
  heroImage?: ImageMetadata;
  heroAlt?: string;
  related: RelatedPost[];
}
const { title, metaTitle, description, path, pubDate, datetime, heroImage, heroAlt, related } =
  Astro.props;
const t = useTranslations('de');
const R = t.ratgeber;

const jsonLd = [
  {
    '@type': 'Article',
    headline: title,
    description,
    datePublished: datetime,
    inLanguage: 'de-DE',
    ...(heroImage ? { image: new URL(heroImage.src, site.url).href } : {}),
    author: { '@id': `${site.url}/#organization` },
    publisher: { '@id': `${site.url}/#organization` },
    mainEntityOfPage: `${site.url}/${path}/`,
  },
];
---

<BaseLayout title={metaTitle} description={description} standalone extraJsonLd={jsonLd}>
  <article class="rg">
    <div class="rg-inner">
      <p class="rg-meta">
        {R.publishedLabel} <time datetime={datetime}>{pubDate}</time>
      </p>
      <h1 class="rg-h1">{title}</h1>

      {
        heroImage && (
          <Image
          src={heroImage}
          alt={heroAlt ?? ''}
          class="rg-hero"
          widths={[480, 800, 1200]}
          sizes="(min-width: 768px) 720px, 100vw"
          loading="eager"
          fetchpriority="high"
        />
        )
      }

      <div class="rg-body">
        <slot />
      </div>

      {/* Conversion: gelbe CTA-Box (Texte aus i18n, Store-Position „ratgeber") */}
      <aside class="rg-cta">
        <p class="rg-cta-head">{R.cta.headline}</p>
        <p class="rg-cta-body">{R.cta.body}</p>
        <StoreBadges position="ratgeber" class="rg-cta-badges" />
      </aside>

      {/* Weitere Ratgeber — interne Verlinkung (sonst verwaist) */}
      {
        related.length > 0 && (
          <nav class="rg-more" aria-label={R.moreTitle}>
            <h2 class="rg-more-title">{R.moreTitle}</h2>
            <ul class="rg-more-list">
              {related.map((r) => (
                <li>
                  <a href={`/${r.path}/`}>{r.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .rg {
    background-color: var(--color-white);
    color: var(--color-black);
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
  }
  .rg-inner {
    max-width: 46rem; /* ~72ch Lesebreite */
    margin-inline: auto;
  }
  .rg-meta {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-grey-text);
  }
  .rg-h1 {
    margin: 0 0 0.6em;
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .rg-hero {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 18px;
    margin: 0 0 2rem;
  }

  /* ---- Markdown-Body (via <slot>; :global, da gescopte Styles den Slot nicht treffen) ---- */
  .rg-body {
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.7;
    color: #3b3b3a;
  }
  .rg-body :global(h2) {
    margin: 2em 0 0.6em;
    font-weight: 900;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-black);
  }
  .rg-body :global(h3) {
    margin: 1.6em 0 0.5em;
    font-weight: 900;
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    color: var(--color-black);
  }
  .rg-body :global(h4) {
    margin: 1.4em 0 0.4em;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-black);
  }
  .rg-body :global(p) {
    margin: 0 0 1.1em;
  }
  .rg-body :global(ul),
  .rg-body :global(ol) {
    margin: 0 0 1.2em;
    padding-left: 1.4em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }
  .rg-body :global(li) {
    line-height: 1.6;
  }
  .rg-body :global(a) {
    color: var(--color-black);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--color-yellow);
    text-underline-offset: 2px;
  }
  .rg-body :global(strong) {
    font-weight: 900;
    color: var(--color-black);
  }
  .rg-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 14px;
    margin: 1.6em 0;
  }
  .rg-body :global(blockquote) {
    margin: 1.6em 0;
    padding: 18px 22px;
    background: var(--color-grey);
    border-left: 4px solid var(--color-yellow);
    border-radius: 0 12px 12px 0;
  }
  .rg-body :global(blockquote) :global(p:last-child) {
    margin-bottom: 0;
  }
  .rg-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6em 0;
    font-size: 0.95em;
    display: block;
    overflow-x: auto;
  }
  .rg-body :global(th),
  .rg-body :global(td) {
    padding: 10px 12px;
    border: 1px solid var(--color-darkgrey);
    text-align: left;
    vertical-align: top;
  }
  .rg-body :global(th) {
    background: var(--color-grey);
    font-weight: 900;
  }
  .rg-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-darkgrey);
    margin: 2em 0;
  }

  /* ---- CTA-Box (gelb) ---- */
  .rg-cta {
    margin-top: clamp(3rem, 7vh, 4.5rem);
    padding: clamp(24px, 4vw, 36px);
    border-radius: 22px;
    background: var(--color-yellow);
    color: var(--color-black);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .rg-cta-head {
    margin: 0;
    font-weight: 900;
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }
  .rg-cta-body {
    margin: 0;
    max-width: 46ch;
    font-size: 1rem;
    line-height: 1.55;
  }
  .rg-cta :global(.rg-cta-badges) {
    margin-top: 6px;
  }

  /* ---- Weitere Ratgeber ---- */
  .rg-more {
    margin-top: clamp(2.5rem, 6vh, 3.5rem);
    padding-top: 22px;
    border-top: 1px solid var(--color-darkgrey);
  }
  .rg-more-title {
    margin: 0 0 14px;
    font-weight: 900;
    font-size: 1.25rem;
    color: var(--color-black);
  }
  .rg-more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rg-more-list a {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-black);
    text-decoration: none;
  }
  .rg-more-list a:hover {
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
</style>
