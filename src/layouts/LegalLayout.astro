---
/**
 * LegalLayout.astro — schlichtes, gut lesbares Layout für die Rechtsseiten
 * (Impressum, Datenschutz, AGB, Kontakt/Konto löschen).
 *
 * DE-only: wrappt BaseLayout mit `standalone` (kein hreflang-Paar), bleibt aber
 * indexierbar (kein noindex → in Sitemap). Rendert genau EIN <h1> = Dokumenttitel;
 * der Slot-Body nutzt <h2>/<h3> (keine übersprungenen Ebenen → Audit-konform).
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  /** Optionales „Stand"-Datum, falls in der Quelle vorhanden. */
  updated?: string;
}

const { title, description, updated } = Astro.props;
---

<BaseLayout title={`${title} · Immobilien Bot`} description={description} standalone>
  <section class="legal">
    <article class="legal__doc">
      <h1 class="legal__title">{title}</h1>
      {updated && <p class="legal__updated">Stand: {updated}</p>}
      <div class="legal__body">
        <slot />
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .legal {
    padding-block: var(--spacing-section);
    padding-inline: var(--spacing-inset);
  }

  .legal__doc {
    max-width: 72ch;
    margin-inline: auto;
    color: var(--color-black);
    font-size: 1rem;
    line-height: 1.6;
  }

  .legal__title {
    font-size: var(--text-h1);
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .legal__updated {
    color: var(--color-grey-text);
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
  }

  /* Ohne „Stand" trotzdem Abstand zum Body. */
  .legal__title:last-of-type {
    margin-bottom: 2.5rem;
  }

  .legal__body :global(h2) {
    font-size: var(--text-subhead);
    line-height: 1.2;
    font-weight: 900;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
  }

  .legal__body :global(h2:first-child) {
    margin-top: 0;
  }

  .legal__body :global(h3) {
    font-size: var(--text-h3);
    line-height: 1.2;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .legal__body :global(p) {
    margin-bottom: 1.1rem;
  }

  .legal__body :global(ul),
  .legal__body :global(ol) {
    margin: 0 0 1.1rem 1.4rem;
    padding: 0;
  }

  .legal__body :global(ul) {
    list-style: disc;
  }

  .legal__body :global(ol) {
    list-style: decimal;
  }

  .legal__body :global(li) {
    margin-bottom: 0.4rem;
  }

  .legal__body :global(a) {
    color: var(--color-black);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    word-break: break-word;
  }

  @media (hover: hover) and (pointer: fine) {
    .legal__body :global(a:hover) {
      background-color: var(--color-yellow);
      text-decoration: none;
    }
  }

  .legal__body :global(strong),
  .legal__body :global(b) {
    font-weight: 700;
  }
</style>
